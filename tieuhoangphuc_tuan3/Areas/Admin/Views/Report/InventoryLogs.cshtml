@model List<WebBanDienThoai.Models.InventoryLog>
@{
    ViewData["Title"] = "Nhật ký biến động kho hàng - MobiStore";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark m-0"><i class="bi bi-journal-text text-info"></i> Nhật ký Kho Hàng</h2>
        <a href="/Admin/Report/Index" class="btn btn-secondary btn-sm fw-bold shadow-sm">
            <i class="bi bi-arrow-left"></i> Quay lại Báo cáo kho
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-bordered mb-0 align-middle">
                    <thead class="table-dark">
                        <tr class="text-center">
                            <th style="width: 15%;">Thời gian</th>
                            <th style="width: 20%;" class="text-start ps-3">Sản phẩm</th>
                            <th style="width: 15%;">Hành động</th>
                            <th style="width: 10%;">Số lượng</th>
                            <th style="width: 25%;" class="text-start ps-3">Nội dung chi tiết</th>
                            <th style="width: 15%;">Người thực hiện</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Chưa có lịch sử biến động kho nào được ghi nhận.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var log in Model)
                            {
                                <tr>
                                    <td class="text-center small text-secondary">@log.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</td>

                                    <td class="fw-bold text-primary text-start ps-3">@log.Product?.Name</td>

                                    <td class="text-center">
                                        @if (log.Type == "NHAP")
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success px-2 py-1" style="border-radius:4px; font-size: 12px;">
                                                ➕ Nhập hàng
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-2 py-1" style="border-radius:4px; font-size: 12px;">
                                                ➖ Xuất kho (Bán)
                                            </span>
                                        }
                                    </td>

                                    <td class="text-center fw-bold fs-6 @(log.Type == "NHAP" ? "text-success" : "text-danger")">
                                        @(log.Type == "NHAP" ? "+" : "-")@log.Quantity
                                    </td>

                                    <td class="text-start ps-3 text-muted">@log.Note</td>

                                    <td class="text-center text-dark font-monospace" style="font-size: 13px;">@log.ActionBy</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>