@model IEnumerable<WebBanDienThoai.Models.Product>
@{
    ViewData["Title"] = "Quản lý cấu hình sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-3">Quản lý cấu hình sản phẩm</h2>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text"
               name="searchTerm"
               value="@ViewBag.CurrentSearch"
               class="form-control"
               placeholder="Tìm theo tên hoặc mô tả sản phẩm..." />
        <button class="btn btn-primary" type="submit">Tìm kiếm</button>
    </div>
</form>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>Id</th>
            <th>Tên sản phẩm</th>
            <th>Giá</th>
            <th>Cấu hình</th>
            <th style="width: 160px;">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Id</td>
                <td>@p.Name</td>
                <td>@p.DiscountedPrice.ToString("N0") ₫</td>
                <td>
                    @if (p.Specs != null)
                    {
                        <span class="badge bg-success">Đã có</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Chưa có</span>
                    }
                </td>
                <td>
                    <a asp-area="Admin"
                       asp-controller="ProductSpecs"
                       asp-action="Edit"
                       asp-route-id="@p.Id"
                       class="btn btn-sm btn-primary">
                        Chỉnh sửa cấu hình
                    </a>

                    @* Nếu bạn muốn xem nhanh (Details) *@
                    @if (p.Specs != null)
                    {
                        <a asp-area="Admin"
                           asp-controller="ProductSpecs"
                           asp-action="Details"
                           asp-route-id="@p.Id"
                           class="btn btn-sm btn-outline-secondary ms-1">
                            Xem
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
