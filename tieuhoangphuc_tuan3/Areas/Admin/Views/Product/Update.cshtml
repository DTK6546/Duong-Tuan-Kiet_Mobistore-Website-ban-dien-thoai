@model WebBanDienThoai.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Cập nhật sản phẩm";
}

<h2 class="mb-4 text-warning">✏️ Cập Nhật Sản Phẩm</h2>

<form asp-area="Admin" asp-controller="Product" asp-action="Update" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label asp-for="Name" class="form-label">Tên sản phẩm</label>
        <input asp-for="Name" class="form-control" required />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Price" class="form-label">Giá sản phẩm (VNĐ)</label>
        <input asp-for="Price" type="number" class="form-control" required />
    </div>

    <div class="form-group mb-3">
        <label asp-for="DiscountPercent" class="form-label">Giảm giá (%)</label>
        <input asp-for="DiscountPercent" type="number" class="form-control" min="0" max="100" />
    </div>

    <!-- ⚙️ Tồn kho -->
    <div class="form-group mb-3">
        <label asp-for="Quantity" class="form-label">Số lượng tồn kho</label>
        <input asp-for="Quantity" type="number" class="form-control" min="0" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="MinStockLevel" class="form-label">Ngưỡng cảnh báo tồn kho</label>
        <input asp-for="MinStockLevel" type="number" class="form-control" min="0" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="CategoryId" class="form-label">Danh mục</label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
            <option value="">-- Chọn danh mục --</option>
        </select>
    </div>

    <div class="form-group mb-3">
        <label asp-for="SubCategoryId" class="form-label">Phân loại nhỏ</label>
        <select asp-for="SubCategoryId" class="form-select" id="SubCategoryId">
            <option value="">-- Chọn phân loại nhỏ --</option>
            @if (ViewBag.SubCategories != null)
            {
                foreach (var sub in (SelectList)ViewBag.SubCategories)
                {
                    int.TryParse(sub.Value, out int subId);
                    <option value="@sub.Value" selected="@(Model.SubCategoryId == subId)">@sub.Text</option>
                }
            }
        </select>
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Ảnh hiện tại</label><br />
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="Ảnh sản phẩm" width="120" class="rounded shadow-sm mb-2" />
        }
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Chọn ảnh mới (nếu muốn thay)</label>
        <input type="file" name="imageUrl" class="form-control" id="imageInput" accept="image/*" />
        <div class="mt-2">
            <img id="previewImage" src="#" alt="Ảnh xem trước" class="d-none"
                 style="max-width: 200px; border: 1px solid #ddd; padding: 5px;" />
        </div>
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Ảnh phụ mới (có thể chọn nhiều)</label>
        <input type="file" name="additionalImages" class="form-control" id="additionalImagesInput" accept="image/*" multiple />
        <small class="text-muted">Giữ Ctrl/Shift để chọn nhiều hình</small>

        <div id="previewAdditionalImages" class="mt-2 d-flex flex-wrap"></div>
    </div>

    @if (Model.Images != null && Model.Images.Any())
    {
        <div class="form-group mb-3">
            <label class="form-label">Ảnh phụ hiện tại</label>
            <div class="d-flex flex-wrap">
                @foreach (var img in Model.Images)
                {
                    <div class="text-center me-3 mb-3">
                        <img src="@img.Url"
                             style="max-width:80px;max-height:80px;object-fit:cover;border:1px solid #ddd;padding:3px;" />
                        <div class="form-check mt-1">
                            <input class="form-check-input" type="checkbox"
                                   name="deleteImageIds" value="@img.Id" id="img_@img.Id" />
                            <label class="form-check-label" for="img_@img.Id">
                                Xoá
                            </label>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <div class="form-group mb-3">
        <label asp-for="Description" class="form-label">Mô tả sản phẩm</label>
        <textarea asp-for="Description" class="form-control" id="editor" rows="5"></textarea>
    </div>

    <!-- 🟢 LỜI CAM KẾT DỊCH VỤ -->
    <div class="form-group mb-3">
        <label asp-for="ServiceCommitment" class="form-label">Lời cam kết dịch vụ</label>
        <textarea asp-for="ServiceCommitment" class="form-control" rows="4"
                  placeholder="Mỗi dòng là 1 cam kết. Ví dụ:
Máy mới 100%, nguyên seal
Bảo hành chính hãng 12 tháng
Hỗ trợ đổi trả 7 ngày"></textarea>
        <span asp-validation-for="ServiceCommitment" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">💾 Cập nhật</button>
    <a asp-action="Index" asp-area="Admin" asp-controller="Product" class="btn btn-secondary ms-2">⬅️ Quay lại</a>
</form>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.0/classic/ckeditor.js"></script>
    <script>
        // CKEditor cho mô tả
        ClassicEditor
            .create(document.querySelector('#editor'))
            .catch(console.error);

        // Preview ảnh chính
        const mainImageInput = document.getElementById("imageInput");
        if (mainImageInput) {
            mainImageInput.addEventListener("change", e => {
                const file = e.target.files[0];
                const img = document.getElementById("previewImage");

                if (!file) {
                    if (img) {
                        img.classList.add("d-none");
                        img.src = "#";
                    }
                    return;
                }

                const reader = new FileReader();
                reader.onload = ev => {
                    if (img) {
                        img.src = ev.target.result;
                        img.classList.remove("d-none");
                    }
                };
                reader.readAsDataURL(file);
            });
        }

        // Preview nhiều ảnh phụ
        const additionalImagesInput = document.getElementById("additionalImagesInput");
        if (additionalImagesInput) {
            additionalImagesInput.addEventListener("change", function () {
                const container = document.getElementById("previewAdditionalImages");
                if (!container) return;

                container.innerHTML = "";

                if (this.files.length === 0) return;

                Array.from(this.files).forEach(file => {
                    const reader = new FileReader();
                    reader.onload = e => {
                        const img = document.createElement("img");
                        img.src = e.target.result;
                        img.style.maxWidth = "80px";
                        img.style.maxHeight = "80px";
                        img.style.objectFit = "cover";
                        img.style.border = "1px solid #ddd";
                        img.style.padding = "3px";
                        img.style.marginRight = "6px";
                        img.style.marginBottom = "6px";
                        container.appendChild(img);
                    };
                    reader.readAsDataURL(file);
                });
            });
        }

        // Load phân loại nhỏ theo danh mục
        const categorySelect = document.getElementById("CategoryId");
        if (categorySelect) {
            categorySelect.addEventListener("change", function () {
                const catId = this.value;
                const subSelect = document.getElementById("SubCategoryId");
                if (!subSelect) return;

                subSelect.innerHTML = '<option value="">-- Chọn phân loại nhỏ --</option>';

                if (catId) {
                    fetch('/Admin/Product/GetSubCategories?categoryId=' + catId)
                        .then(r => r.json())
                        .then(data => data.forEach(i => {
                            const opt = document.createElement("option");
                            opt.value = i.id;
                            opt.text = i.name;
                            subSelect.appendChild(opt);
                        }))
                        .catch(console.error);
                }
            });
        }
    </script>

    @await Html.PartialAsync("_ValidationScriptsPartial")
}
