@model WebBanDienThoai.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Thêm sản phẩm";
}

<h2 class="mb-4 text-primary">➕ Thêm Sản Phẩm Mới</h2>

<form asp-area="Admin" asp-controller="Product" asp-action="Add" method="post" enctype="multipart/form-data">
    <div class="form-group mb-3">
        <label asp-for="Name" class="form-label">Tên sản phẩm</label>
        <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm..." required />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Price" class="form-label">Giá sản phẩm (VNĐ)</label>
        <input asp-for="Price" type="number" class="form-control" placeholder="Nhập giá..." required />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="DiscountPercent" class="form-label">Giảm giá (%)</label>
        <input asp-for="DiscountPercent" type="number" class="form-control" placeholder="Nhập giảm giá (0 - 100)" min="0" max="100" />
        <span asp-validation-for="DiscountPercent" class="text-danger"></span>
    </div>

    <!-- ⚙️ Tồn kho -->
    <div class="form-group mb-3">
        <label asp-for="Quantity" class="form-label">Số lượng tồn kho</label>
        <input asp-for="Quantity" type="number" class="form-control" placeholder="Nhập số lượng tồn..." min="0" required />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="MinStockLevel" class="form-label">Ngưỡng cảnh báo tồn kho</label>
        <input asp-for="MinStockLevel" type="number" class="form-control" placeholder="Nhập ngưỡng cảnh báo (VD: 5)" min="0" />
        <span asp-validation-for="MinStockLevel" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="CategoryId" class="form-label">Danh mục</label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-control" required>
            <option value="">-- Chọn danh mục --</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="SubCategoryId" class="form-label">Hãng</label>
        <select asp-for="SubCategoryId" class="form-control" id="SubCategoryId">
            <option value="">-- Chọn hãng --</option>
            @if (ViewBag.SubCategories != null)
            {
                foreach (var sub in (SelectList)ViewBag.SubCategories)
                {
                    <option value="@sub.Value">@sub.Text</option>
                }
            }
        </select>
    </div>

    <div class="form-group mb-3">
        <label asp-for="ImageUrl" class="form-label">Ảnh sản phẩm</label>
        <input type="file" name="imageUrl" class="form-control" id="imageInput" accept="image/*" required />
        <div class="mt-2">
            <img id="previewImage" src="#" alt="Ảnh xem trước" class="d-none"
                 style="max-width: 200px; border: 1px solid #ddd; padding: 5px;" />
        </div>
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Ảnh phụ (có thể chọn nhiều)</label>
        <input type="file" name="additionalImages" class="form-control" accept="image/*" multiple />
        <small class="text-muted">Giữ Ctrl hoặc Shift để chọn nhiều hình</small>

        <div id="previewAdditionalImages" class="mt-2"></div>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Description" class="form-label">Mô tả sản phẩm</label>
        <textarea asp-for="Description" class="form-control" id="editor" rows="5" placeholder="Nhập mô tả..." required></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <!-- 🟢 LỜI CAM KẾT DỊCH VỤ -->
    <div class="form-group mb-3">
        <label asp-for="ServiceCommitment" class="form-label">Lời cam kết dịch vụ</label>
        <textarea asp-for="ServiceCommitment" class="form-control" rows="4"
                  placeholder="Mỗi dòng là 1 cam kết. Ví dụ:
Máy mới 100%, nguyên seal
Bảo hành chính hãng 12 tháng
Hỗ trợ đổi trả 7 ngày"></textarea>
        <span asp-validation-for="ServiceCommitment" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">💾 Lưu sản phẩm</button>
    <a asp-action="Index" asp-area="Admin" asp-controller="Product" class="btn btn-secondary ms-2">⬅️ Quay lại</a>
</form>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.0/classic/ckeditor.js"></script>
    <script>
        // CKEditor cho ô mô tả
        ClassicEditor
            .create(document.querySelector('#editor'))
            .catch(console.error);

        // Preview ảnh chính
        const mainImageInput = document.getElementById("imageInput");
        if (mainImageInput) {
            mainImageInput.addEventListener("change", e => {
                const file = e.target.files[0];
                const img = document.getElementById("previewImage");

                if (!file) {
                    if (img) {
                        img.classList.add("d-none");
                        img.src = "#";
                    }
                    return;
                }

                const reader = new FileReader();
                reader.onload = ev => {
                    if (img) {
                        img.src = ev.target.result;
                        img.classList.remove("d-none");
                    }
                };
                reader.readAsDataURL(file);
            });
        }

        // Preview nhiều ảnh phụ
        const additionalImagesInput = document.getElementById("additionalImagesInput");
        if (additionalImagesInput) {
            additionalImagesInput.addEventListener("change", function () {
                const container = document.getElementById("previewAdditionalImages");
                if (!container) return;

                container.innerHTML = "";

                if (this.files.length === 0) return;

                Array.from(this.files).forEach(file => {
                    const reader = new FileReader();
                    reader.onload = e => {
                        const img = document.createElement("img");
                        img.src = e.target.result;
                        img.style.maxWidth = "80px";
                        img.style.maxHeight = "80px";
                        img.style.objectFit = "cover";
                        img.style.border = "1px solid #ddd";
                        img.style.padding = "3px";
                        img.style.marginRight = "6px";
                        img.style.marginBottom = "6px";
                        container.appendChild(img);
                    };
                    reader.readAsDataURL(file);
                });
            });
        }

        // Load hãng (SubCategory) theo Danh mục (Category)
        const categorySelect = document.getElementById("CategoryId");
        if (categorySelect) {
            categorySelect.addEventListener("change", function () {
                const categoryId = this.value;
                const subDropdown = document.getElementById("SubCategoryId");
                if (!subDropdown) return;

                subDropdown.innerHTML = '<option value="">-- Chọn hãng --</option>';

                if (categoryId) {
                    fetch('/Admin/Product/GetSubCategories?categoryId=' + categoryId)
                        .then(r => r.json())
                        .then(data => data.forEach(i => {
                            const option = document.createElement("option");
                            option.value = i.id;
                            option.text = i.name;
                            subDropdown.appendChild(option);
                        }))
                        .catch(console.error);
                }
            });
        }
    </script>

    @await Html.PartialAsync("_ValidationScriptsPartial")
}
