@using WebBanDienThoai.Models
@model ProductVariant

@{
    ViewData["Title"] = "Sửa biến thể";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2>Sửa biến thể – @ViewBag.ProductName</h2>

<a asp-area="Admin"
   asp-controller="ProductVariant"
   asp-action="Index"
   asp-route-productId="@ViewBag.ProductId"
   class="btn btn-secondary mb-3">
    ← Quay lại danh sách biến thể
</a>

<form asp-area="Admin"
      asp-controller="ProductVariant"
      asp-action="Edit"
      asp-route-id="@Model.Id"
      method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ProductId" />

    <div class="mb-3">
        <label asp-for="Color" class="form-label"></label>
        <input asp-for="Color" class="form-control" />
        <span asp-validation-for="Color" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Storage" class="form-label"></label>
        <input asp-for="Storage" class="form-control" />
        <span asp-validation-for="Storage" class="text-danger"></span>
    </div>

    <!-- ⭐ RAM -->
    <div class="mb-3">
        <label asp-for="Ram" class="form-label"></label>
        <input asp-for="Ram" class="form-control" />
        <span asp-validation-for="Ram" class="text-danger"></span>
    </div>

    <!-- ⭐ Dung lượng còn lại (khả dụng) -->
    <div class="mb-3">
        <label asp-for="StorageAvailable" class="form-label"></label>
        <input asp-for="StorageAvailable" class="form-control" />
        <span asp-validation-for="StorageAvailable" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Stock" class="form-label"></label>
        <input asp-for="Stock" class="form-control" />
        <span asp-validation-for="Stock" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Cập nhật</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
