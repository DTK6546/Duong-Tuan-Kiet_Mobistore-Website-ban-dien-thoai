@model List<WebBanDienThoai.Models.Province>

@{
    ViewData["Title"] = "Quản lý Tỉnh/TP";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Quản lý Tỉnh/TP</h2>
    <a asp-area="Admin" asp-controller="Province" asp-action="Create" class="btn btn-primary">
        + Thêm Tỉnh/TP
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-bordered table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th style="width:140px">Code</th>
            <th>Tên</th>
            <th style="width:180px" class="text-end">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (Model == null || !Model.Any())
        {
            <tr><td colspan="3" class="text-center text-muted">Chưa có dữ liệu.</td></tr>
        }
        else
        {
            foreach (var p in Model)
            {
                <tr>
                    <td><b>@p.Code</b></td>
                    <td>@p.Name</td>
                    <td class="text-end">
                        <a asp-area="Admin" asp-controller="Province" asp-action="Edit" asp-route-id="@p.Id"
                           class="btn btn-sm btn-warning">Sửa</a>

                        <form asp-area="Admin" asp-controller="Province" asp-action="Delete" asp-route-id="@p.Id"
                              method="post" class="d-inline"
                              onsubmit="return confirm('Xóa Tỉnh/TP này?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
