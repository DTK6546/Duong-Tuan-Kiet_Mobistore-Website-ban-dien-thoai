@model WebBanDienThoai.Models.Province

@{
    ViewData["Title"] = "Thêm Tỉnh/TP";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2>Thêm Tỉnh/TP</h2>

<a asp-area="Admin" asp-controller="Province" asp-action="Index" class="btn btn-secondary mb-3">
    ← Quay lại
</a>

<form asp-area="Admin" asp-controller="Province" asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Mã (VD: HCM, HN)</label>
        <input asp-for="Code" class="form-control" />
        <span asp-validation-for="Code" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Tên Tỉnh/TP</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="text-danger mb-2">
        @Html.ValidationSummary(excludePropertyErrors: true)
    </div>

    <button type="submit" class="btn btn-success">Lưu</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
