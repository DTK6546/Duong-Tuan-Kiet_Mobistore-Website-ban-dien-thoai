@model List<WebBanDienThoai.Models.ProductRating>
@using WebBanDienThoai.Models
@using System.Linq

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý đánh giá sản phẩm";

    var products = ViewBag.Products as List<Product> ?? new();
    int totalCount = ViewBag.TotalCount ?? 0;
    int pageSize = ViewBag.PageSize ?? 5;
    int currentPage = ViewBag.CurrentPage ?? 1;

    string search = ViewBag.Search as string ?? "";
    int productId = ViewBag.ProductId ?? 0;
    int star = ViewBag.Star ?? 0;

    double avgStars = (double)(ViewBag.AvgStars ?? 0.0);
    List<int> starCounts = ViewBag.StarCounts as List<int> ?? new List<int> { 0, 0, 0, 0, 0 };

    int totalPages = (int)System.Math.Ceiling((double)totalCount / pageSize);

    int editingReplyId = 0;
    if (!string.IsNullOrEmpty(Context.Request.Query["editingReplyId"]))
    {
        int.TryParse(Context.Request.Query["editingReplyId"], out editingReplyId);
    }

    string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        name = name.Trim();
        return name.Substring(0, 1).ToUpper();
    }
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Quản lý đánh giá sản phẩm</h2>
            <div class="text-muted small">Duyệt nhanh đánh giá, phản hồi, ảnh / vote / báo cáo.</div>
        </div>
        <span class="badge bg-dark px-3 py-2">Tổng: @totalCount đánh giá</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- FILTER -->
    <div class="bg-white p-4 rounded-4 shadow-sm mb-4 border">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-lg-4 col-md-6">
                <label class="form-label fw-bold small text-uppercase text-muted">Tìm kiếm</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                    <input name="search" class="form-control bg-light border-start-0"
                           value="@search"
                           placeholder="Tên khách, nội dung bình luận, tên sản phẩm..." />
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <label class="form-label fw-bold small text-uppercase text-muted">Sản phẩm</label>
                <select name="productId" class="form-select bg-light">
                    @if (productId == 0)
                    {
                        <option value="0" selected="selected">Tất cả điện thoại</option>
                    }
                    else
                    {
                        <option value="0">Tất cả điện thoại</option>
                    }

                    @foreach (var p in products)
                    {
                        if (p.Id == productId)
                        {
                            <option value="@p.Id" selected="selected">@p.Name</option>
                        }
                        else
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="col-lg-2 col-md-6">
                <label class="form-label fw-bold small text-uppercase text-muted">Số sao</label>
                <select name="star" class="form-select bg-light">
                    @if (star == 0)
                    {
                        <option value="0" selected="selected">Tất cả sao</option>
                    }
                    else
                    {
                        <option value="0">Tất cả sao</option>
                    }

                    @for (int i = 5; i >= 1; i--)
                    {
                        if (star == i)
                        {
                            <option value="@i" selected="selected">@i sao</option>
                        }
                        else
                        {
                            <option value="@i">@i sao</option>
                        }
                    }
                </select>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="d-flex gap-2">
                    <button class="btn btn-primary w-100 fw-bold" type="submit">
                        <i class="bi bi-funnel me-1"></i> Áp dụng
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary" title="Reset">
                        <i class="bi bi-arrow-clockwise"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>

    <!-- STATS (chỉ khi chọn sản phẩm) -->
    @if (productId > 0)
    {
        <div class="row bg-white p-4 rounded-4 shadow-sm mb-4 mx-1 border align-items-center">
            <div class="col-md-4 text-center border-end">
                <div class="display-3 fw-bold text-primary">@avgStars.ToString("0.0")</div>
                <div class="text-warning mb-2 fs-4">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi @(i <= System.Math.Round(avgStars) ? "bi-star-fill" : "bi-star")"></i>
                    }
                </div>
                <p class="text-muted small mb-0">Điểm trung bình (theo bộ lọc hiện tại)</p>
            </div>
            <div class="col-md-8 ps-md-5">
                @{
                    int starLevel = 5;
                }
                @foreach (var count in starCounts)
                {
                    <div class="d-flex align-items-center mb-2">
                        <span class="fw-bold small" style="width: 60px;">
                            @starLevel <i class="bi bi-star-fill text-warning"></i>
                        </span>
                        <div class="progress flex-grow-1 mx-3" style="height: 12px; border-radius: 10px;">
                            <div class="progress-bar bg-warning" role="progressbar"
                                 style="width: @(totalCount > 0 ? (count * 100 / totalCount) : 0)%"
                                 aria-valuenow="@count" aria-valuemin="0" aria-valuemax="@totalCount"></div>
                        </div>
                        <span class="text-muted small" style="width: 40px;">@count</span>
                    </div>
                    starLevel--;
                }
            </div>
        </div>
    }

    <!-- LIST -->
    @if (Model != null && Model.Any())
    {
        foreach (var r in Model)
        {
            var productName = r.Product?.Name ?? "Sản phẩm";
            var userName = r.User?.FullName ?? r.User?.UserName ?? "Người dùng";
            var comment = string.IsNullOrWhiteSpace(r.Comment) ? "(Không có nhận xét)" : r.Comment.Trim();

            // ✅ Nếu navigation null thì vẫn chạy bình thường
            var replies = r.Replies ?? new List<ProductRatingReply>();
            var images = r.Images ?? new List<ProductRatingImage>();
            var votes = r.Votes ?? new List<ProductRatingVote>();
            var reports = r.Reports ?? new List<ProductRatingReport>();

            var likes = votes.Count(v => v.IsLike);
            var dislikes = votes.Count(v => !v.IsLike);

            var reportCollapseId = $"reportCollapse_{r.Id}";
            <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
                <div class="card-body p-4">

                    <!-- HEADER -->
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <div class="d-flex align-items-center flex-wrap gap-2">
                            <div class="rounded-circle bg-secondary text-white fw-bold d-flex align-items-center justify-content-center"
                                 style="width:40px;height:40px;">
                                @Initials(userName)
                            </div>

                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 ms-2">
                                <i class="bi bi-phone me-1"></i> @productName
                            </span>

                            <h5 class="fw-bold mb-0 mx-2">@userName</h5>

                            @if (r.IsVerifiedPurchase)
                            {
                                <span class="badge bg-success text-white px-2 py-1 small shadow-sm"
                                      title="Người dùng đã mua và nhận hàng thành công">
                                    <i class="bi bi-patch-check-fill me-1"></i> Đã mua hàng
                                </span>
                            }
                        </div>

                        <div class="text-end">
                            <div class="text-warning fs-5">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= r.Stars ? "bi-star-fill" : "bi-star")"></i>
                                }
                            </div>
                            <small class="text-muted">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            @if (r.UpdatedAt.HasValue)
                            {
                                <div class="small text-muted">(đã sửa)</div>
                            }
                        </div>
                    </div>

                    <!-- COMMENT -->
                    <div class="p-3 bg-light rounded-3 mb-3 border-start border-4 border-primary">
                        <div class="mb-0 text-dark" style="white-space:pre-line;">“@comment”</div>
                    </div>

                    <!-- IMAGES -->
                    @if (images.Any())
                    {
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            @foreach (var img in images.OrderBy(x => x.CreatedAt))
                            {
                                <a href="@img.Url" target="_blank" title="Mở ảnh">
                                    <img src="@img.Url" class="rounded shadow-sm"
                                         style="width:110px;height:110px;object-fit:cover;" />
                                </a>
                            }
                        </div>
                    }

                    <!-- VOTES + REPORT COUNT -->
                    <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
                        <span class="btn btn-outline-success btn-sm px-3 py-1">
                            <i class="bi bi-hand-thumbs-up-fill me-1"></i> @likes
                        </span>
                        <span class="btn btn-outline-danger btn-sm px-3 py-1">
                            <i class="bi bi-hand-thumbs-down-fill me-1"></i> @dislikes
                        </span>

                        <button class="btn btn-outline-secondary btn-sm px-3 py-1 ms-2"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#@reportCollapseId"
                                aria-expanded="false">
                            <i class="bi bi-flag-fill me-1"></i> Báo cáo: @reports.Count
                        </button>

                        @if (reports.Any())
                        {
                            <span class="badge bg-danger">Có báo cáo</span>
                        }
                    </div>

                    <!-- REPORTS DETAILS (COLLAPSE) -->
                    <div class="collapse mb-3" id="@reportCollapseId">
                        <div class="p-3 rounded-3 border" style="background:#fff5f5;">
                            <div class="fw-bold text-danger mb-2">
                                <i class="bi bi-flag-fill me-1"></i> Danh sách báo cáo
                            </div>

                            @if (!reports.Any())
                            {
                                <div class="text-muted small fst-italic">Chưa có báo cáo nào.</div>
                            }
                            else
                            {
                                @foreach (var rep in reports.OrderByDescending(x => x.CreatedAt))
                                {
                                    <div class="mb-2 pb-2 border-bottom">
                                        <div class="small text-muted">
                                            @(rep.User?.FullName ?? rep.User?.UserName ?? rep.UserId)
                                            • @rep.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                        </div>
                                        <div>@rep.Reason</div>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <!-- REPLIES -->
                    <div class="ms-md-5 p-3 rounded-4" style="background-color:#f8f9fa; border:1px dashed #dee2e6;">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                            <h6 class="fw-bold text-secondary mb-0">
                                <i class="bi bi-reply-all-fill me-2"></i>Phản hồi điều hành
                            </h6>
                            <span class="small text-muted">@replies.Count phản hồi</span>
                        </div>

                        @if (!replies.Any())
                        {
                            <div class="text-muted small fst-italic">Chưa có phản hồi nào.</div>
                        }
                        else
                        {
                            @foreach (var reply in replies.OrderBy(x => x.CreatedAt))
                            {
                                <div class="d-flex gap-3 mb-3 pb-2 border-bottom border-white shadow-none">
                                    <div class="avatar-sm bg-info text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                         style="width:35px;height:35px;">
                                        <i class="bi bi-person-badge"></i>
                                    </div>

                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between flex-wrap gap-2">
                                            <span class="fw-bold text-info">@(reply.User?.FullName ?? reply.User?.UserName ?? "Quản trị viên")</span>
                                            <small class="text-muted">@reply.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                        </div>

                                        @if (editingReplyId == reply.Id)
                                        {
                                            <form asp-action="EditReply" method="post" class="mt-2">
                                                <input type="hidden" name="id" value="@reply.Id" />
                                                <input type="hidden" name="search" value="@search" />
                                                <input type="hidden" name="productId" value="@productId" />
                                                <input type="hidden" name="star" value="@star" />
                                                <input type="hidden" name="page" value="@currentPage" />

                                                <div class="input-group shadow-sm">
                                                    <input name="content" class="form-control" value="@reply.Content" required />
                                                    <button class="btn btn-success" type="submit">Lưu</button>
                                                    <a href="@Url.Action("Index", new { search, productId, star, page = currentPage })"
                                                       class="btn btn-secondary text-white">Hủy</a>
                                                </div>
                                            </form>
                                        }
                                        else
                                        {
                                            <p class="mb-1 mt-1 text-secondary" style="white-space:pre-line;">@reply.Content</p>

                                            <div class="mt-2">
                                                <a href="@Url.Action("Index", new { search, productId, star, page = currentPage, editingReplyId = reply.Id })"
                                                   class="btn btn-link btn-sm text-warning p-0 me-3 text-decoration-none fw-bold">
                                                    Chỉnh sửa
                                                </a>

                                                <form asp-action="DeleteReply" asp-route-id="@reply.Id" method="post" class="d-inline">
                                                    <button type="submit"
                                                            class="btn btn-link btn-sm text-danger p-0 text-decoration-none fw-bold"
                                                            onclick="return confirm('Bạn chắc chắn muốn xóa phản hồi này?')">
                                                        Xóa bỏ
                                                    </button>
                                                </form>
                                            </div>

                                            @if (reply.UpdatedAt.HasValue)
                                            {
                                                <div class="small text-muted mt-1">(đã cập nhật)</div>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        }

                        <!-- ADD REPLY -->
                        <form asp-action="AddReply" method="post" class="mt-3">
                            <input type="hidden" name="ratingId" value="@r.Id" />
                            <div class="input-group">
                                <input name="content" class="form-control border-info"
                                       placeholder="Nhập nội dung phản hồi khách hàng..."
                                       required autocomplete="off" />
                                <button class="btn btn-info text-white fw-bold px-4" type="submit">
                                    <i class="bi bi-send me-1"></i> Gửi
                                </button>
                            </div>
                            <div class="small text-muted mt-1">
                                Gợi ý: phản hồi ngắn gọn, lịch sự, nêu hướng xử lý.
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm border">
            <i class="bi bi-chat-dots display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">Không tìm thấy đánh giá nào!</h4>
            <p class="text-muted mb-0">Vui lòng thay đổi bộ lọc hoặc từ khóa tìm kiếm.</p>
        </div>
    }

    <!-- PAGINATION -->
    @if (totalPages > 1)
    {
        <nav class="d-flex justify-content-center my-5">
            <ul class="pagination shadow-sm">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search, productId, star, page = currentPage - 1 })">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    if (i == 1 || i == totalPages || System.Math.Abs(i - currentPage) <= 1)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link px-4" href="@Url.Action("Index", new { search, productId, star, page = i })">@i</a>
                        </li>
                    }
                    else if (i == currentPage - 2 || i == currentPage + 2)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search, productId, star, page = currentPage + 1 })">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

<style>
    .pagination > li > a, .pagination > li > span {
        border-radius: 1.5rem !important;
        margin: 0 2px;
        min-width: 42px;
        text-align: center;
    }

    .bg-light {
        background: #f8f9fb !important;
    }

    .rounded-4 {
        border-radius: 1.2rem !important;
    }

    .card.rounded-4 {
        border-radius: 1.2rem !important;
    }

    .badge.bg-primary, .badge.bg-info {
        font-size: 1rem;
        padding: .4em 1.1em .45em 1.1em;
        border-radius: 1.2rem;
    }
</style>
