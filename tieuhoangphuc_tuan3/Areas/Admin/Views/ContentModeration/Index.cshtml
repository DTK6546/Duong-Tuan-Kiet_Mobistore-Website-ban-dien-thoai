@model List<WebBanDienThoai.Models.ProductRating>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml"; // Nếu file layout của bạn tên là _Layout.cshtml
    ViewData["Title"] = "Kiểm duyệt nội dung & Chặn Spammer";
}

<div class="container-fluid px-4 mt-4">
    <h2 class="mt-4 text-dark"><i class="bi bi-shield-lock-fill text-danger"></i> Bảo mật & Kiểm duyệt nội dung</h2>
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mt-4">
        <div class="col-xl-8">
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-dark text-white fw-semibold">
                    <i class="bi bi-chat-square-quote me-1"></i> Danh sách bình luận đánh giá mới cập nhật
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Khách hàng</th>
                                    <th>Sản phẩm</th>
                                    <th>Nội dung bình luận</th>
                                    <th>Trạng thái</th>
                                    <th class="text-center">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model)
                                {
                                    <tr>
                                        <td>
                                            <strong>@r.User?.FullName</strong><br />
                                            <span class="small text-muted">@r.User?.Email</span>
                                        </td>
                                        <td class="small">@r.Product?.Name</td>
                                        <td>
                                            <div class="text-warning small mb-1">
                                                @for (int i = 1; i <= r.Stars; i++)
                                                {
                                                    <i class="bi bi-star-fill"></i>
                                                }
                                            </div>
                                            <span class="text-secondary small">@r.Comment</span>
                                        </td>
                                        <td>
                                            @if (r.IsApproved)
                                            {
                                                <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1">Đang hiển thị</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-2 py-1">Đang bị ẩn</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (!r.IsApproved)
                                            {
                                                <form asp-action="ApproveComment" asp-route-id="@r.Id" method="post" class="d-inline">
                                                    <button class="btn btn-sm btn-success px-2 py-1 small">Duyệt</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-action="HideComment" asp-route-id="@r.Id" method="post" class="d-inline">
                                                    <button class="btn btn-sm btn-outline-secondary px-2 py-1 small">Ẩn bài</button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-danger text-white fw-semibold">
                    <i class="bi bi-person-x-fill me-1"></i> Danh sách đen & Chặn Spammer
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @foreach (var u in ViewBag.Users as List<WebBanDienThoai.Models.ApplicationUser>)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                <div>
                                    <div class="fw-bold text-dark">@u.FullName</div>
                                    <div class="small text-muted">@u.Email</div>
                                </div>
                                <form asp-action="ToggleBanUser" method="post">
                                    <input type="hidden" name="userId" value="@u.Id" />
                                    @if (u.IsBanned)
                                    {
                                        <button type="submit" class="btn btn-sm btn-success rounded-pill px-3">Mở khóa</button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-danger rounded-pill px-3">Chặn Nick</button>
                                    }
                                </form>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>