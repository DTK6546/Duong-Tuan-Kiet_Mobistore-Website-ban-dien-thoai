@model WebBanDienThoai.Models.Order
@using WebBanDienThoai.Extensions
@using WebBanDienThoai.Models

@{
    ViewData["Title"] = "Chi tiết đơn hàng Admin";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    string customerName = Model.ApplicationUser?.FullName ?? (Model.Notes?.Contains("Khách hàng:") == true ? Model.Notes.Split('.')[0].Replace("Khách hàng:", "").Trim() : "Khách vãng lai");

    Func<WebBanDienThoai.Models.OrderStatus, string> statusClass = s =>
    {
        switch (s)
        {
            case WebBanDienThoai.Models.OrderStatus.ChoXacNhan: return "badge bg-secondary";
            case WebBanDienThoai.Models.OrderStatus.DangXuLy: return "badge bg-warning text-dark";
            case WebBanDienThoai.Models.OrderStatus.DangGiao: return "badge bg-info text-dark";
            case WebBanDienThoai.Models.OrderStatus.DaGiao: return "badge bg-success";
            case WebBanDienThoai.Models.OrderStatus.DaHuy: return "badge bg-danger";
            case WebBanDienThoai.Models.OrderStatus.TraHang: return "badge bg-dark";
            case WebBanDienThoai.Models.OrderStatus.HoanTat: return "badge bg-primary";
            default: return "badge bg-light text-dark";
        }
    };

    Func<WebBanDienThoai.Models.OrderStatus, string> statusIcon = s =>
    {
        switch (s)
        {
            case WebBanDienThoai.Models.OrderStatus.ChoXacNhan: return "bi-hourglass-split";
            case WebBanDienThoai.Models.OrderStatus.DangXuLy: return "bi-gear";
            case WebBanDienThoai.Models.OrderStatus.DangGiao: return "bi-truck";
            case WebBanDienThoai.Models.OrderStatus.DaGiao: return "bi-check-circle";
            case WebBanDienThoai.Models.OrderStatus.DaHuy: return "bi-x-circle";
            case WebBanDienThoai.Models.OrderStatus.TraHang: return "bi-arrow-repeat";
            case WebBanDienThoai.Models.OrderStatus.HoanTat: return "bi-check2-all";
            default: return "bi-info-circle";
        }
    };

    var subTotal = Model.Subtotal;
    if (subTotal == 0)
    {
        subTotal = Model.OrderDetails.Sum(od => (od.Price + (od.Warranties?.Sum(w => w.Price) ?? 0)) * od.Quantity);
    }
    var discount = Model.DiscountAmount;
    
    // =========================================================================
    // 💸 CẬP NHẬT: BỐC THUỘC TÍNH TRỢ GIÁ THU CŨ ĐỔI MỚI (TRADE-IN VALUE) ĐỂ HIỂN THỊ
    // =========================================================================
    var tradeInDiscount = Model.TradeInDiscount;
    var afterDiscountReal = Math.Max(0, subTotal - discount - tradeInDiscount);

    var shippers = ViewBag.Shippers as List<Shipper> ?? new List<Shipper>();
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3" role="alert">
        <i class="bi bi-check-circle-fill me-1"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light d-flex align-items-center">
        <div>
            <span class="fs-4 fw-bold">Chi tiết đơn hàng #@Model.Id</span>
            <span class="@statusClass(Model.Status) ms-2 px-3 py-2">
                <i class="bi @statusIcon(Model.Status)"></i>
                @Model.Status.ToVietnameseStatus()
            </span>
        </div>
        <a href="@Url.Action("Index", "Order", new { area = "Admin" })" class="btn btn-outline-primary btn-sm ms-auto">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>
    <div class="card-body">
        <dl class="row mb-3">
            <dt class="col-sm-3">Khách hàng:</dt>
            <dd class="col-sm-9 fw-bold text-primary">@customerName</dd>

            <dt class="col-sm-3">Ngày đặt:</dt>
            <dd class="col-sm-9">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Phương thức nhận hàng:</dt>
            <dd class="col-sm-9">
                @(Model.DeliveryMethod == 0 ? "Giao hàng tận nơi" : "Nhận tại cửa hàng")
            </dd>

            @if (Model.DeliveryMethod == 0)
            {
                <dt class="col-sm-3">Khu vực giao:</dt>
                <dd class="col-sm-9">@Model.DistrictCode, @Model.ProvinceCode</dd>

                <dt class="col-sm-3">Địa chỉ chi tiết:</dt>
                <dd class="col-sm-9">@Model.ShippingAddress</dd>
            }

            @if (Model.DeliveryMethod == 1 && Model.Store != null)
            {
                <dt class="col-sm-3">Cửa hàng nhận:</dt>
                <dd class="col-sm-9">
                    <strong>@Model.Store.Name</strong><br />
                    <span class="small text-muted">@Model.Store.Address</span>
                </dd>
            }

            <dt class="col-sm-3">Ghi chú từ hệ thống:</dt>
            <dd class="col-sm-9 text-muted small">@Model.Notes</dd>
        </dl>

        <form method="post" asp-action="UpdateStatus" class="row g-2 align-items-center border-top pt-3">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="col-auto">
                <label for="status" class="form-label fw-semibold mb-0">Cập nhật trạng thái:</label>
            </div>
            <div class="col-auto">
                <select id="status" name="status" class="form-select border-primary form-select-sm" style="min-width:200px">
                    @foreach (var s in Enum.GetValues(typeof(WebBanDienThoai.Models.OrderStatus)))
                    {
                        var value = (int)s;
                        <option value="@value" selected="@(Model.Status == (OrderStatus)s ? "selected" : null)">
                            @(((OrderStatus)s).ToVietnameseStatus())
                        </option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-success btn-sm px-4 shadow-sm">
                    <i class="bi bi-save"></i> Lưu trạng thái
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.Status != OrderStatus.DaHuy && Model.Status != OrderStatus.HoanTat)
{
    <div class="card shadow-sm mb-4 border border-warning border-opacity-50">
        <div class="card-header bg-warning bg-opacity-10 py-3">
            <h5 class="mb-0 text-warning-emphasis fw-bold">
                <i class="bi bi-truck me-1"></i> Điều phối Vận chuyển & Logistics
            </h5>
        </div>
        <div class="card-body">
            <form asp-action="UpdateLogistics" asp-controller="Order" asp-area="Admin" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.Id" />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-secondary">Chọn Shipper / Đơn vị phụ trách</label>
                        <select name="shipperId" class="form-select form-select-sm" required>
                            <option value="">-- Chọn nhân viên giao hàng --</option>
                            @foreach (var s in shippers)
                            {
                                <option value="@s.Id" selected="@(Model.ShipperId == s.Id ? "selected" : null)">
                                    @s.FullName (@s.CompanyName)
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-secondary">Mã vận đơn điện tử (Tracking ID)</label>
                        <input type="text" name="trackingNumber" value="@Model.TrackingNumber" class="form-control form-control-sm" placeholder="Ví dụ: GHN987654321VN" required />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-secondary">Nhật ký mốc lộ trình hiện tại</label>
                        <input type="text" name="initialLogDescription" class="form-control form-control-sm" placeholder="Ví dụ: Đơn hàng đã rời kho phân loại..." />
                    </div>
                </div>

                <div class="mt-3 text-end">
                    <button type="submit" class="btn btn-sm btn-warning fw-semibold px-4 shadow-sm text-dark">
                        <i class="bi bi-check-circle-fill me-1"></i> Xác nhận điều phối & Phát hành hành trình
                    </button>
                </div>
            </form>
        </div>
    </div>
}

<div class="card shadow-sm mb-4 border border-info border-opacity-50">
    <div class="card-header bg-info bg-opacity-10 fw-bold text-info-emphasis">
        <i class="bi bi-bezier2 me-1"></i> Nhật ký hành trình Tracking di chuyển thực tế
    </div>
    <div class="card-body">
        @if (Model.OrderLogs != null && Model.OrderLogs.Any())
        {
            <div class="position-relative ps-3 ms-2" style="border-left: 2px solid #0ea5e9;">
                @foreach (var log in Model.OrderLogs.OrderByDescending(l => l.LogDate))
                {
                    <div class="mb-3 position-relative">
                        <div class="position-absolute bg-info rounded-circle" style="width: 10px; height: 10px; left: -20px; top: 6px; border: 2px solid #fff;"></div>
                        <div class="small fw-bold text-dark">@log.LogDate.ToString("dd/MM/yyyy HH:mm:ss")</div>
                        <div class="small text-secondary">
                            @log.StatusDescription
                            @if (!string.IsNullOrEmpty(log.Location))
                            {
                                <span class="badge bg-light text-secondary border ms-1">@log.Location</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-muted text-center py-2 small">
                <i class="bi bi-info-circle me-1"></i> Chưa có nhật ký hành trình logistics chi tiết cho đơn hàng này.
            </div>
        }
    </div>
</div>

<div class="card shadow">
    <div class="card-header bg-light fw-bold">Danh sách sản phẩm</div>
    <div class="card-body p-0">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Sản phẩm</th>
                    <th class="text-center">Đơn giá</th>
                    <th class="text-center">Số lượng</th>
                    <th class="text-end">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderDetails)
                {
                    var warrantyPrice = item.Warranties?.Sum(w => w.Price) ?? 0;
                    <tr>
                        <td>
                            <div class="fw-semibold">@(string.IsNullOrEmpty(item.ProductName) ? item.Product?.Name : item.ProductName)</div>
                            @if (item.Warranties != null && item.Warranties.Any())
                            {
                                foreach (var w in item.Warranties)
                                {
                                    <div class="small text-success ms-2">
                                        <i class="bi bi-shield-check"></i> Bảo hành: @w.Name (+@w.Price.ToString("N0") đ)
                                    </div>
                                }
                            }
                        </td>
                        <td class="text-center">@item.Price.ToString("N0") đ</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end fw-bold">@(((item.Price + warrantyPrice) * item.Quantity).ToString("N0")) đ</td>
                    </tr>
                }
            </tbody>
            <tfoot class="bg-light">
                <tr>
                    <td colspan="3" class="text-end">Tạm tính:</td>
                    <td class="text-end fw-semibold">@subTotal.ToString("N0") đ</td>
                </tr>
                @if (discount > 0)
                {
                    <tr>
                        <td colspan="3" class="text-end text-danger">Giảm giá @(!string.IsNullOrEmpty(Model.CouponCode) ? $"({Model.CouponCode})" : ""):</td>
                        <td class="text-end fw-semibold text-danger">-@discount.ToString("N0") đ</td>
                    </tr>
                }

                @* =========================================================================
                // 💸 CẬP NHẬT GIAO DIỆN ADMIN: RENDER DÒNG KHẤU TRỪ MÁY CŨ TRÊN HÓA ĐƠN CHI TIẾT
                // ========================================================================= *@
                @if (tradeInDiscount > 0)
                {
                    <tr style="background-color: #fff5f5;">
                        <td colspan="3" class="text-end text-danger fw-bold"><i class="bi bi-arrow-left-right"></i> Trợ giá thu cũ đổi mới:</td>
                        <td class="text-end fw-bold text-danger">-@tradeInDiscount.ToString("N0") đ</td>
                    </tr>
                }

                <tr>
                    <td colspan="3" class="text-end">Thành tiền (chưa VAT):</td>
                    <td class="text-end fw-semibold">@afterDiscountReal.ToString("N0") đ</td>
                </tr>
                <tr>
                    <td colspan="3" class="text-end">VAT (10%):</td>
                    <td class="text-end fw-semibold">@Model.VatAmount.ToString("N0") đ</td>
                </tr>
                <tr>
                    <td colspan="3" class="text-end fw-bold">Phí vận chuyển:</td>
                    <td class="text-end fw-bold text-dark">@Model.ShippingFee.ToString("N0") đ</td>
                </tr>
                <tr class="table-warning">
                    <td colspan="3" class="text-end fw-bold fs-5">TỔNG CỘNG:</td>
                    <td class="text-end fw-bold fs-5 text-danger">@Model.TotalPrice.ToString("N0") đ</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>