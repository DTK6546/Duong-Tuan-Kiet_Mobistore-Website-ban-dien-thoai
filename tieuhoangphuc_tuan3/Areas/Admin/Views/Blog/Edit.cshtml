@model WebBanDienThoai.Models.BlogPost
@{
    ViewData["Title"] = "Chỉnh sửa Bài viết";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4" style="max-width: 900px;">
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-sm btn-light rounded-circle me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h3 class="fw-bold text-dark mb-0"><i class="bi bi-pencil-square text-warning me-2"></i> Chỉnh sửa bài viết</h3>
        </div>

        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <input type="hidden" asp-for="Id" />

            <div class="row g-3">
                <div class="col-md-8">
                    <div class="form-group mb-3">
                        <label asp-for="Title" class="form-label fw-semibold text-dark">Tiêu đề bài viết <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control rounded-3" placeholder="Nhập tiêu đề bài viết..." required />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label class="form-label fw-semibold text-dark">Danh mục bài viết</label>
                        <select asp-for="BlogCategoryId" class="form-select rounded-3" asp-items="ViewBag.BlogCategoryId"></select>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Summary" class="form-label fw-semibold text-dark">Tóm tắt ngắn</label>
                <textarea asp-for="Summary" class="form-control rounded-3" rows="2" placeholder="Nội dung tóm tắt ngắn ngoài danh sách..."></textarea>
                <span asp-validation-for="Summary" class="text-danger small"></span>
            </div>

            <div class="row g-3 align-items-end">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label class="form-label fw-semibold text-dark">Thay ảnh đại diện mới (Thumbnail)</label>
                        <input type="file" name="thumbnailFile" class="form-control rounded-3" accept="image/*" />

                        @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
                        {
                            <div class="mt-2 p-2 border rounded-3 bg-light d-inline-block">
                                <small class="text-muted d-block mb-1">Ảnh hiện tại:</small>
                                <img src="@Model.ThumbnailUrl" class="rounded border shadow-sm" style="max-height: 80px; object-fit: cover;" alt="Current Thumbnail">
                            </div>
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="VideoEmbedUrl" class="form-label fw-semibold text-dark">Link Video Review (YouTube)</label>
                        <input asp-for="VideoEmbedUrl" class="form-control rounded-3" placeholder="Dán link thường hoặc link share..." />
                        <span asp-validation-for="VideoEmbedUrl" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Content" class="form-label fw-semibold text-dark">Nội dung chi tiết bài viết <span class="text-danger">*</span></label>
                <textarea asp-for="Content" id="BlogContentEditor" class="form-control rounded-3" rows="12" placeholder="Viết nội dung bài hướng dẫn hoặc review tại đây..." required></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2 justify-content-end border-top pt-3">
                <a asp-action="Index" class="btn btn-light rounded-pill px-4">Hủy bỏ</a>
                <button type="submit" class="btn btn-warning text-dark fw-bold rounded-pill px-5">Cập nhật ngay</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}