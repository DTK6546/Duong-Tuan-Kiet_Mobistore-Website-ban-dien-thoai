@model IEnumerable<WebBanDienThoai.Models.Coupon>

@{
    ViewData["Title"] = "Quản lý mã giảm giá";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2>@ViewData["Title"]</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<p>
    <a asp-action="Add" class="btn btn-primary">+ Thêm mã giảm giá</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Mã</th>
            <th>Giảm (VNĐ)</th>
            <th>Giảm (%)</th>
            <th>Đơn tối thiểu</th>
            <th>Tổng lượt</th>
            <th>Đã dùng</th>
            <th>Còn lại</th>
            <th>Thời gian</th>
            <th>Trạng thái</th>
            <th>Khách hàng đã sử dụng</th> <!-- Mới thêm cột này -->
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var remaining = item.Quantity - item.CurrentUsage;
            var now = DateTime.Now;

            <tr class="@(remaining <= 0 || !item.IsActive ? "table-secondary" : "")">
                <td>@item.Code</td>

                <td>
                    @(item.DiscountAmount.HasValue
                                    ? item.DiscountAmount.Value.ToString("N0")
                                    : "")
                                     </td>

                <td>
                    @(item.DiscountPercent.HasValue
                                    ? item.DiscountPercent.Value + "%"
                                    : "")
            </td>

                <td>@item.MinOrderValue.ToString("N0")</td>

                <td>@item.Quantity</td>

                <td>@item.CurrentUsage</td>

                <td>
                @if (remaining > 0)
                    {
                        @remaining
                    }
                    else
                    {
                        <span class="text-danger">Hết lượt</span>
                    }
                </td>

                <td>
                    @item.StartDate.ToString("dd/MM/yyyy") - @item.EndDate.ToString("dd/MM/yyyy")
                </td>

                <td>
                    @if (!item.IsActive)
                    {
                        <span class="badge badge-secondary">Ngưng</span>
                    }
                    else if (item.EndDate < now)
                    {
                        <span class="badge badge-danger">Hết hạn</span>
                    }
                    else if (remaining <= 0)
                    {
                        <span class="badge badge-danger">Hết lượt</span>
                    }
                    else if (item.StartDate > now)
                    {
                        <span class="badge badge-warning">Chưa bắt đầu</span>
                    }
                    else
                    {
                        <span class="badge badge-success">Đang hoạt động</span>
                    }
                </td>

                <!-- Thêm cột để xem khách hàng đã sử dụng mã này -->
                <td>
                    <a asp-action="UsedByCustomers" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                        Xem khách hàng
                    </a>
                </td>

                <td>
                    <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                        Sửa
                    </a>

                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline">
                        <button type="submit"
                                class="btn btn-sm btn-danger"
                                onclick="return confirm('Xóa mã này?');">
                            Xóa
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
