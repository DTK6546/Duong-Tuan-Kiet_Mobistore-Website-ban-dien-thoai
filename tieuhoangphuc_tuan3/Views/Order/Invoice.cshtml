@model WebBanDienThoai.Models.Order
@{
    Layout = null;

    decimal subTotal = Model.Subtotal;
    decimal vat = Model.VatAmount;
    decimal ship = Model.ShippingFee;
    decimal discount = Model.DiscountAmount;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">

    <title>Hóa đơn #@Model.Id</title>

    <style>

        body {
            font-family: Arial;
            margin: 40px;
            background: #fff;
        }

        .container {
            width: 800px;
            margin: auto;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo img {
            height: 60px;
        }

        .shop-info {
            text-align: right;
        }

        .shop-name {
            font-size: 22px;
            color: #ee4d2d;
            font-weight: bold;
        }

        .order-code {
            text-align: center;
            margin-top: 15px;
            font-size: 28px;
            font-weight: bold;
            color: #ee4d2d;
        }

        .title {
            text-align: center;
            font-size: 20px;
            margin-top: 10px;
            margin-bottom: 25px;
        }

        .customer {
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

            table th {
                background: #ee4d2d;
                color: white;
            }

            table th, table td {
                border: 1px solid #ddd;
                padding: 10px;
            }

        .total {
            width: 350px;
            margin-top: 20px;
            margin-left: auto;
        }

            .total td {
                padding: 6px;
            }

            .total .grand {
                font-size: 18px;
                color: #ee4d2d;
                font-weight: bold;
            }

        .code-area {
            margin-top: 30px;
            display: flex;
            justify-content: space-between;
        }

            .code-area img {
                height: 120px;
            }

        .sign {
            margin-top: 60px;
            display: flex;
            justify-content: space-between;
        }

        .sign-box {
            text-align: center;
        }

        .sign-line {
            margin-top: 70px;
        }

        .footer {
            margin-top: 40px;
            text-align: center;
            color: #888;
        }

        .print {
            margin-top: 20px;
            text-align: center;
        }

        button {
            padding: 10px 20px;
            border: none;
            background: #ee4d2d;
            color: white;
            cursor: pointer;
        }

    </style>

</head>

<body>

    <div class="container">

        <div class="header">

            <div class="logo">
                <img src="/images/mobistore-logo.png">
            </div>

            <div class="shop-info">

                <div class="shop-name">Mobistore</div>

                Ngày: @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")

            </div>

        </div>

        <div class="order-code">
            MÃ ĐƠN HÀNG: #@Model.Id
        </div>

        <div class="title">
            HÓA ĐƠN THANH TOÁN
        </div>

        <div class="customer">

            <b>Khách hàng:</b> @Model.ApplicationUser?.FullName <br>
            <b>Địa chỉ:</b> @Model.ShippingAddress

        </div>

        <table>

            <tr>
                <th>Sản phẩm</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
                <th>Thành tiền</th>
            </tr>

            @foreach (var item in Model.OrderDetails)
            {
                var total = item.Price * item.Quantity;

                <tr>

                    <td>@item.Product?.Name</td>

                    <td>@item.Quantity</td>

                    <td>@item.Price.ToString("N0") đ</td>

                    <td>@total.ToString("N0") đ</td>

                </tr>

            }

        </table>

        <table class="total">

            <tr>
                <td>Tạm tính</td>
                <td align="right">@subTotal.ToString("N0") đ</td>
            </tr>

            @if (discount > 0)
            {
                <tr>
                    <td>Giảm giá</td>
                    <td align="right">-@discount.ToString("N0") đ</td>
                </tr>
            }

            <tr>
                <td>VAT (10%)</td>
                <td align="right">@vat.ToString("N0") đ</td>
            </tr>

            <tr>
                <td>Phí vận chuyển</td>
                <td align="right">@ship.ToString("N0") đ</td>
            </tr>

            <tr class="grand">
                <td>Tổng cộng</td>
                <td align="right">@Model.TotalPrice.ToString("N0") đ</td>
            </tr>

        </table>

        <div class="code-area">

            <div>

                <img src="https://barcode.tec-it.com/barcode.ashx?data=@Model.Id&code=Code128&dpi=96">

                <p>Mã vạch đơn hàng</p>

            </div>

            <div>

                <img src="https://api.qrserver.com/v1/create-qr-code/?size=120x120&data=https://localhost:7105/Order/Details/@Model.Id">

                <p>QR tra cứu đơn</p>

            </div>

        </div>

        <div class="sign">

            <div class="sign-box">

                <b>Khách hàng</b>

                <div class="sign-line">
                    (Ký và ghi rõ họ tên)
                </div>

            </div>

            <div class="sign-box">

                <b>Mobistore</b>

                <div class="sign-line">
                    (Ký xác nhận)
                </div>

            </div>

        </div>

        <div class="print">

            <button onclick="window.print()">
                In hóa đơn
            </button>

        </div>

        <div class="footer">

            Cảm ơn bạn đã mua hàng tại <b>Mobistore</b>

        </div>

    </div>

</body>
</html>