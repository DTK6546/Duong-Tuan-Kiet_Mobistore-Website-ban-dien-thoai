@model WebBanDienThoai.Models.Order
@using WebBanDienThoai.Extensions

@{
    ViewData["Title"] = "Chi tiết đơn hàng";

    bool canCancel = Model.Status == WebBanDienThoai.Models.OrderStatus.ChoXacNhan
                  || Model.Status == WebBanDienThoai.Models.OrderStatus.DangXuLy;

    Func<WebBanDienThoai.Models.OrderStatus, string> statusClass = s =>
    {
        switch (s)
        {
            case WebBanDienThoai.Models.OrderStatus.ChoXacNhan: return "badge bg-secondary";
            case WebBanDienThoai.Models.OrderStatus.DangXuLy: return "badge bg-warning text-dark";
            case WebBanDienThoai.Models.OrderStatus.DangGiao: return "badge bg-info text-dark";
            case WebBanDienThoai.Models.OrderStatus.DaGiao: return "badge bg-success";
            case WebBanDienThoai.Models.OrderStatus.DaHuy: return "badge bg-danger";
            default: return "badge bg-light text-dark";
        }
    };

    // ===== Tạm tính, giảm giá, VAT =====
    // Ưu tiên dùng dữ liệu đã lưu trong Order
    decimal subTotal = Model.Subtotal;
    decimal discount = Model.DiscountAmount;
    decimal vat = Model.VatAmount;

    // Fallback cho các đơn cũ (khi Subtotal = 0)
    if (subTotal == 0 && Model.OrderDetails != null && Model.OrderDetails.Any())
    {
        subTotal = Model.OrderDetails.Sum(od =>
        {
            var warrantyPerItem = od.Warranties?.Sum(w => w.Price) ?? 0m;
            return (od.Price + warrantyPerItem) * od.Quantity;
        });
    }
}

<div class="container mt-4 mb-4">
    <div class="card shadow rounded-4 mx-auto" style="max-width: 1100px;">

        <!-- HEADER -->
        <div class="card-header bg-light d-flex flex-wrap align-items-center justify-content-between">
            <div class="d-flex align-items-center">
                <h3 class="mb-0 fw-bold">Chi tiết đơn hàng #@Model.Id</h3>
                <span class="@statusClass(Model.Status) ms-3 px-3 py-2 fs-6">
                    @Model.Status.ToVietnameseStatus()
                </span>
            </div>

            <div class="mt-2 mt-md-0">
                <a href="@Url.Action("MyOrders", "Order")" class="btn btn-outline-primary px-4 me-2 rounded-pill">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>

                @if (canCancel)
                {
                    <form asp-action="CancelOrder" method="post" class="d-inline"
                          onsubmit="return confirm('Bạn chắc chắn muốn hủy đơn hàng này?');">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger px-4 rounded-pill">
                            <i class="bi bi-x-circle"></i> Hủy đơn
                        </button>
                    </form>
                }

                @if (Model.Status == WebBanDienThoai.Models.OrderStatus.DaGiao)
                {
                    <form asp-action="ConfirmReceived" method="post" class="d-inline"
                          onsubmit="return confirm('Xác nhận đã nhận hàng?');">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-success px-4 rounded-pill">
                            <i class="bi bi-check2-circle"></i> Đã nhận hàng
                        </button>
                    </form>
                }
            </div>
        </div>

        <!-- THÔNG TIN ĐƠN -->
        <div class="row mb-2 mt-3 px-3">
            <div class="col-md-4 text-md-end fw-semibold text-muted">Ngày đặt:</div>
            <div class="col-md-8 mb-2">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>

            @* Địa chỉ / cửa hàng tuỳ theo DeliveryMethod *@
            @if (Model.DeliveryMethod == DeliveryMethod.ShipToHome)
            {
                <div class="col-md-4 text-md-end fw-semibold text-muted">Địa chỉ giao hàng:</div>
                <div class="col-md-8 mb-2">@Model.ShippingAddress</div>
            }
            else if (Model.DeliveryMethod == DeliveryMethod.PickupAtStore && Model.Store != null)
            {
                <div class="col-md-4 text-md-end fw-semibold text-muted">Nhận tại cửa hàng:</div>
                <div class="col-md-8 mb-2">
                    @Model.Store.Name - @Model.Store.Address
                </div>
            }

            <div class="col-md-4 text-md-end fw-semibold text-muted">Phương thức nhận hàng:</div>
            <div class="col-md-8 mb-2">
                @(Model.DeliveryMethod == DeliveryMethod.ShipToHome
                                ? "Giao hàng tận nơi"
                                : "Nhận tại cửa hàng")
            </div>

            <div class="col-md-4 text-md-end fw-semibold text-muted">Ghi chú:</div>
            <div class="col-md-8 mb-3">@Model.Notes</div>
        </div>

        <!-- DANH SÁCH SẢN PHẨM -->
        <div class="card-footer bg-white pt-3">
            <div class="table-responsive">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Giá</th>
                            <th>Số lượng</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderDetails)
                        {
                            // Giá bảo hành / 1 sản phẩm
                            var warrantyPerItem = item.Warranties?.Sum(w => w.Price) ?? 0m;
                            // Thành tiền = (giá sp + bảo hành) * số lượng
                            var thanhTien = (item.Price + warrantyPerItem) * item.Quantity;

                            <tr>
                                <td>
                                    @{
                                        // Ưu tiên dùng tên đã lưu trong OrderDetail; nếu null thì fallback về Product.Name (cho các đơn cũ)
                                        var displayName = !string.IsNullOrEmpty(item.ProductName)
                                        ? item.ProductName
                                        : item.Product?.Name;
                                    }

                                    <div class="fw-bold">@displayName</div>

                                    <!-- GÓI BẢO HÀNH ĐÃ MUA -->
                                    @{
                                        var warranties = item.Warranties?.ToList()
                                        ?? new List<WebBanDienThoai.Models.OrderDetailWarranty>();
                                    }

                                    @if (warranties.Any())
                                    {
                                        <div class="mt-1 p-2 bg-light rounded border">
                                            <div class="fw-semibold mb-1">
                                                <i class="bi bi-shield-check text-success"></i>
                                                Gói bảo hành đã mua:
                                            </div>

                                            @foreach (var w in warranties)
                                            {
                                                <div class="d-flex justify-content-between small ps-3">
                                                    <span>• @w.Name (@w.Months tháng)</span>
                                                    <span class="text-danger fw-bold">
                                                        +@w.Price.ToString("N0") đ
                                                    </span>
                                                </div>
                                            }
                                        </div>
                                    }
                                </td>

                                <td>@item.Price.ToString("N0") đ</td>
                                <td>@item.Quantity</td>
                                <td>@thanhTien.ToString("N0") đ</td>
                            </tr>
                        }
                    </tbody>

                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Tạm tính:</td>
                            <td class="fw-bold">@subTotal.ToString("N0") đ</td>
                        </tr>

                        @if (discount > 0)
                        {
                            <tr>
                                <td colspan="3" class="text-end fw-bold">
                                    Giảm giá
                                    @if (!string.IsNullOrEmpty(Model.CouponCode))
                                    {
                                        <span class="text-muted">(Mã: @Model.CouponCode)</span>
                                    }
                                </td>
                                <td class="fw-bold text-danger">-@discount.ToString("N0") đ</td>
                            </tr>
                        }

                        <tr>
                            <td colspan="3" class="text-end fw-bold">Thành tiền (chưa VAT):</td>
                            <td class="fw-bold">@((subTotal - discount).ToString("N0")) đ</td>
                        </tr>

                        <tr>
                            <td colspan="3" class="text-end fw-bold">VAT (10%):</td>
                            <td class="fw-bold">@vat.ToString("N0") đ</td>
                        </tr>

                        <tr>
                            <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                            <td class="fw-bold">@Model.TotalPrice.ToString("N0") đ</td>
                        </tr>
                    </tfoot>

                </table>
            </div>
        </div>
    </div>
</div>

<script>
    window.onload = function () {
        var adBanner = document.querySelector('.carousel');
        if (adBanner) adBanner.style.display = 'none';
    };
</script>
