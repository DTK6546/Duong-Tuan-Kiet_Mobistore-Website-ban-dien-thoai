@model WebBanDienThoai.Models.Order
@using WebBanDienThoai.Extensions
@using WebBanDienThoai.Models

@{
    ViewData["Title"] = "Chi tiết đơn hàng";

    bool canCancel = Model.Status == OrderStatus.ChoXacNhan || Model.Status == OrderStatus.DangXuLy;
    bool canCancelReceived = Model.Status == OrderStatus.DaGiao;
    bool canReturn = Model.Status == OrderStatus.HoanTat;

    string storeName = Model.Store?.Name ?? "Mobistore";
    string customerName = Model.ApplicationUser?.FullName ?? (Model.Notes?.Contains("Khách hàng:") == true ? Model.Notes.Split('.')[0] : "Khách hàng");

    Func<OrderStatus, string> statusClass = s => s switch
    {
        OrderStatus.ChoXacNhan => "badge bg-secondary",
        OrderStatus.DangXuLy => "badge bg-warning text-dark",
        OrderStatus.DangGiao => "badge bg-info text-dark",
        OrderStatus.DaGiao => "badge bg-success",
        OrderStatus.HoanTat => "badge bg-primary",
        OrderStatus.DaHuy => "badge bg-danger",
        OrderStatus.TraHang => "badge bg-dark",
        _ => "badge bg-light text-dark",
    };

    // ⚡ ĐỒNG BỘ: Sử dụng SubTotal tính toán động truyền từ Controller
    decimal subTotal = ViewBag.SubTotal ?? Model.Subtotal;
    decimal discount = Model.DiscountAmount;
    decimal tradeInDiscount = Model.TradeInDiscount;

    if (subTotal == 0 && Model.OrderDetails != null && Model.OrderDetails.Any())
    {
        subTotal = Model.OrderDetails.Sum(od =>
        {
            var warrantyPerItem = od.Warranties?.Sum(w => w.Price) ?? 0m;
            return (od.Price + warrantyPerItem) * od.Quantity;
        });
    }

    decimal afterDiscountReal = Math.Max(0, subTotal - discount - tradeInDiscount);
    decimal vat = Model.VatAmount > 0 ? Model.VatAmount : Math.Round(afterDiscountReal * 0.10m, 0);

    // ⚡ ĐỒNG BỘ: Phí vận chuyển tự động tính từ Controller
    decimal shipFee = ViewBag.ShippingFee ?? Model.ShippingFee;
    bool isFreeShip = ViewBag.IsFreeShip ?? (shipFee == 0);

    bool isCancelled = Model.Status == OrderStatus.DaHuy;
    bool isReturn = Model.Status == OrderStatus.TraHang;

    int progressIndex = Model.Status switch
    {
        OrderStatus.ChoXacNhan => 0,
        OrderStatus.DangXuLy => 1,
        OrderStatus.DangGiao => 2,
        OrderStatus.DaGiao => 3,
        OrderStatus.HoanTat => 4,
        _ => -1
    };

    var steps = new (string Title, string Icon)[]
    {
        ("Chờ xác nhận", "bi-hourglass-split"),
        ("Đang xử lý", "bi-gear"),
        ("Vận chuyển", "bi-truck"),
        ("Đã giao", "bi-box-seam"),
        ("Hoàn thành", "bi-check2-circle"),
    };

    string DeliveryText() => Model.DeliveryMethod == 0 ? "Giao hàng tận nơi" : "Nhận tại cửa hàng";
}

<style>
    .od-card {
        border: 1px solid rgba(0,0,0,.06);
        border-radius: 1rem;
        box-shadow: 0 .125rem .25rem rgba(0,0,0,.075);
        height: auto !important;
        transform: none !important;
        transition: none !important;
    }

        .od-card .card-body {
            display: block !important;
            justify-content: unset !important;
            text-align: left !important;
            flex-grow: 0 !important;
        }

    .od-page {
        padding-bottom: 40px;
    }

    .od-muted {
        color: #6c757d;
    }

    /* Progress Timeline */
    .od-progress {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
    }

    .od-step {
        text-align: center;
        position: relative;
        padding: 6px 4px;
    }

        .od-step .dot {
            width: 34px;
            height: 34px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 2px solid rgba(0,0,0,.15);
            background: #fff;
            z-index: 1;
            position: relative;
        }

        .od-step.done .dot, .od-step.active .dot {
            border-color: currentColor;
        }

        .od-step.done {
            color: #198754;
        }

        .od-step.active {
            color: #0d6efd;
        }

        .od-step .label {
            font-weight: 600;
            font-size: .9rem;
            margin-top: 6px;
        }

        .od-step::after {
            content: "";
            position: absolute;
            top: 23px;
            left: calc(50% + 20px);
            right: calc(-50% + 20px);
            height: 3px;
            background: rgba(0,0,0,.08);
            z-index: 0;
        }

        .od-step:last-child::after {
            display: none;
        }

        .od-step.done::after {
            background: rgba(25,135,84,.35);
        }

        .od-step.active::after {
            background: rgba(13,110,253,.35);
        }

    /* Items layout */
    .od-item {
        padding: .9rem 0;
    }

        .od-item + .od-item {
            border-top: 1px dashed rgba(0,0,0,.10);
        }

    .od-thumb {
        width: 72px;
        height: 72px;
        border-radius: 14px;
        overflow: hidden;
        background: #f8f9fa;
        border: 1px solid rgba(0,0,0,.06);
        flex: 0 0 auto;
    }

        .od-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .od-price {
        min-width: 170px;
    }

    .od-summary-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: .35rem 0;
    }

    .animate-flicker {
        animation: flickerAnimation 1.5s infinite;
    }

    @@keyframes flickerAnimation {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }

        100% {
            opacity: 1;
        }
    }
</style>

<div class="od-page">
    <div class="container mt-4 mb-4" style="max-width: 1100px;">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
            <div>
                <h3 class="fw-bold mb-1">Chi tiết đơn hàng #@Model.Id</h3>
                <div class="od-muted small">Đặt lúc @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                <div class="text-primary fw-semibold small">Khách hàng: @customerName</div>
            </div>

            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="@statusClass(Model.Status) px-3 py-2">@Model.Status.ToVietnameseStatus()</span>
                <a href="@Url.Action("MyOrders", "Order")" class="btn btn-outline-primary rounded-pill px-4"><i class="bi bi-arrow-left"></i> Quay lại</a>

                @if (Model.Status == OrderStatus.DaGiao || Model.Status == OrderStatus.HoanTat)
                {
                    <a href="@Url.Action("Invoice", "Order", new { id = Model.Id })" class="btn btn-success rounded-pill px-4"><i class="bi bi-receipt"></i> Xuất hóa đơn</a>
                    <a href="/Order/ExportInvoicePdf/@Model.Id" class="btn btn-dark rounded-pill px-4"><i class="bi bi-file-earmark-pdf"></i> Tải PDF</a>
                }

                @if (canCancel)
                {
                    <form asp-action="CancelOrder" method="post" class="d-inline" onsubmit="return confirm('Bạn chắc chắn muốn hủy đơn hàng này?');">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger rounded-pill px-4"><i class="bi bi-x-circle"></i> Hủy đơn</button>
                    </form>
                }

                @if (canCancelReceived)
                {
                    <form asp-action="ConfirmReceived" method="post" class="d-inline" onsubmit="return confirm('Xác nhận đã nhận hàng?');">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-success rounded-pill px-4"><i class="bi bi-check2-circle"></i> Đã nhận hàng</button>
                    </form>
                }

                @if (canReturn)
                {
                    <form asp-action="ReturnOrder" method="post" class="d-inline" onsubmit="return confirm('Bạn muốn yêu cầu trả hàng/hoàn tiền cho đơn này?');">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-dark rounded-pill px-4"><i class="bi bi-arrow-repeat"></i> Trả hàng</button>
                    </form>
                }
            </div>
        </div>

        <div class="card od-card mb-4">
            <div class="card-body">
                @if (isCancelled)
                {
                    <div class="alert alert-danger mb-0 rounded-4">
                        <div class="fw-bold"><i class="bi bi-x-octagon"></i> Đơn hàng đã bị hủy</div>
                        <div class="small">Nếu đây là nhầm lẫn, bạn có thể đặt lại sản phẩm từ trang sản phẩm.</div>
                    </div>
                }
                else if (isReturn)
                {
                    <div class="alert alert-dark mb-0 rounded-4">
                        <div class="fw-bold"><i class="bi bi-arrow-repeat"></i> Đơn hàng đang ở trạng thái Trả hàng/Hoàn tiền</div>
                        <div class="small">Bộ phận hỗ trợ sẽ xử lý yêu cầu của bạn theo chính sách.</div>
                    </div>
                }
                else
                {
                    <div class="od-progress">
                        @for (int i = 0; i < steps.Length; i++)
                        {
                            var cls = i < progressIndex ? "od-step done" : (i == progressIndex ? "od-step active" : "od-step");
                            <div class="@cls">
                                <div class="dot"><i class="bi @steps[i].Icon"></i></div>
                                <div class="label">@steps[i].Title</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        @if (Model.Status == OrderStatus.DangGiao || Model.Status == OrderStatus.DaGiao)
        {
            <div class="row g-3 mb-4">
                <div class="col-md-7">
                    <div class="card od-card border-primary border-opacity-25 rounded-4 h-100 shadow-sm overflow-hidden">
                        <div class="card-header bg-primary bg-opacity-10 py-3 fw-bold text-primary">
                            <i class="bi bi-geo-alt-fill text-danger animate-flicker"></i> Theo dõi vị trí bưu tá Real-time
                        </div>
                        <div class="position-relative" style="height: 280px; background: #e5e7eb;">
                            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.1232970596356!2d106.71212877573617!3d10.801874258721644!2m3!1f0!2f0!3f0!3m2!1i1020!2i768!4f13.1!3m3!1m2!1s0x317528a459b1de3d%3A0x2f60f6fc413009a9!2zVHLGsOG7nW5nIMSQ4bqhaSBo4buNYyBDw7RuZyBuZ2jhu4cgVFAuSENNIC0gSFVURUNI!5e0!3m2!1svi!2s!4v1710000000000!5m2!1svi!2s" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
                            <div class="position-absolute top-3 start-3 bg-dark text-white bg-opacity-75 px-3 py-2 rounded-3 small shadow-sm">
                                <i class="bi bi-bicycle text-warning me-1"></i> Bưu tá: <b>@(Model.Shipper?.FullName ?? "Nội bộ")</b><br>
                                <i class="bi bi-hourglass-split text-success me-1"></i> Dự kiến đến trong: <b>15 phút nữa</b>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-5">
                    <div class="card od-card border-success border-opacity-25 rounded-4 h-100 shadow-sm d-flex flex-column">
                        <div class="card-header bg-success bg-opacity-10 py-3 fw-bold text-success">
                            <i class="bi bi-chat-left-dots-fill me-1"></i> – Liên hệ nhanh bưu tá phụ trách
                        </div>
                        <div class="card-body p-3 flex-grow-1 bg-light overflow-auto" style="height: 180px;">
                            <div class="mb-2">
                                <div class="p-2 bg-white text-dark rounded-3 shadow-sm small d-inline-block" style="max-width: 85%;">
                                    "Chào bạn, mình cầm đơn hàng #@Model.Id của bạn rồi nhé, mình đang đóng gói và chuẩn bị phóng xe đi giao qua luôn đây."
                                    <span class="d-block text-end text-muted mt-1" style="font-size:9px;">10 phút trước</span>
                                </div>
                            </div>
                            <div class="mb-2 text-start">
                                <div class="p-2 bg-white text-dark rounded-3 shadow-sm small d-inline-block" style="max-width: 85%;">
                                    "Mình đang chạy đến đoạn đường gần trường Đại học HUTECH rồi, tầm 5 phút nữa tới nơi mình gọi bạn nhận điện thoại nha!"
                                    <span class="d-block text-end text-muted mt-1" style="font-size:9px;">Vừa xong</span>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 p-2">
                            <div class="input-group input-group-sm">
                                <input type="text" class="form-control" placeholder="Nhắn tin cho shipper...">
                                <button class="btn btn-success" type="button" onclick="alert('Tin nhắn phản hồi của bạn đã được gửi đến thiết bị shipper!')">Gửi</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="card od-card mb-4 border border-primary border-opacity-25 rounded-4 shadow-sm">
            <div class="card-header bg-primary bg-opacity-10 py-3">
                <h5 class="mb-0 text-primary-emphasis fw-bold">
                    <i class="bi bi-list-task text-primary me-1"></i> Nhật ký lộ trình bưu kiện chi tiết
                </h5>
            </div>
            <div class="card-body p-4">
                <div class="row g-4">
                    <div class="col-md-5 border-end">
                        <div class="fw-semibold text-secondary mb-2 small"><i class="bi bi-patch-check"></i> Đơn vị phụ trách giao hàng:</div>
                        @if (Model.Shipper != null)
                        {
                            <div class="d-flex align-items-center gap-3 bg-light p-3 rounded-3 border">
                                <div class="fs-1 text-primary"><i class="bi bi-person-circle"></i></div>
                                <div>
                                    <h6 class="fw-bold mb-1 text-dark">@Model.Shipper.FullName</h6>
                                    <div class="small text-muted mb-1">Đối tác: @Model.Shipper.CompanyName</div>
                                    <div class="small text-muted mb-1">Biển số: @Model.Shipper.VehicleNumber</div>
                                    <div class="mt-2">
                                        <a href="tel:@Model.Shipper.PhoneNumber" class="btn btn-sm btn-success px-3 rounded-pill small">
                                            <i class="bi bi-telephone-fill me-1"></i>Gọi Shipper: @Model.Shipper.PhoneNumber
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="text-muted bg-light p-3 rounded-3 text-center border border-dashed small">
                                <i class="bi bi-clock-history me-1"></i> Hệ thống đang điều phối nhân sự hoặc đồng bộ mã vận đơn đối tác...
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.TrackingNumber))
                        {
                            <div class="mt-3 small text-secondary">
                                Mã vận đơn điện tử: <strong class="text-dark bg-warning bg-opacity-25 px-2 py-1 rounded">@Model.TrackingNumber</strong>
                            </div>
                        }
                    </div>

                    <div class="col-md-7 ps-md-4">
                        <div class="fw-semibold text-secondary mb-3 small"><i class="bi bi-bezier2"></i> Mốc lộ trình di chuyển của gói hàng:</div>
                        @if (Model.OrderLogs != null && Model.OrderLogs.Any())
                        {
                            <div class="position-relative ps-3" style="border-left: 2px solid #0ea5e9;">
                                @foreach (var log in Model.OrderLogs.OrderByDescending(l => l.LogDate))
                                {
                                    <div class="mb-3 position-relative">
                                        <div class="position-absolute bg-primary rounded-circle" style="width: 10px; height: 10px; left: -20px; top: 6px; border: 2px solid #fff;"></div>
                                        <div class="fw-bold text-dark small">@log.LogDate.ToString("dd/MM/yyyy HH:mm")</div>
                                        <div class="text-secondary small">
                                            @log.StatusDescription
                                            @if (!string.IsNullOrEmpty(log.Location))
                                            {
                                                <span class="badge bg-light text-secondary border ms-1">@log.Location</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="position-relative ps-3" style="border-left: 2px solid #ced4da;">
                                <div class="mb-2 position-relative">
                                    <div class="position-absolute bg-success rounded-circle" style="width: 10px; height: 10px; left: -20px; top: 6px; border: 2px solid #fff;"></div>
                                    <div class="fw-bold text-success small">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                                    <div class="text-dark small">Đơn hàng khởi tạo thành công tại hệ thống @storeName.</div>
                                </div>
                                @if (Model.Status >= OrderStatus.DangXuLy)
                                {
                                    <div class="mt-3 position-relative">
                                        <div class="position-absolute bg-warning rounded-circle" style="width: 10px; height: 10px; left: -20px; top: 6px; border: 2px solid #fff;"></div>
                                        <div class="fw-bold text-warning-emphasis small">Đang đóng gói</div>
                                        <div class="text-muted small">Nhân viên kho hoàn tất dán nhãn niêm phong gói hàng.</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-lg-5">
                <div class="card od-card">
                    <div class="card-header bg-white border-0 pt-3">
                        <div class="fw-bold"><i class="bi bi-geo-alt"></i> Thông tin giao hàng</div>
                        <div class="od-muted small">Phương thức: @DeliveryText()</div>
                    </div>
                    <div class="card-body pt-2">
                        @if (Model.DeliveryMethod == 0)
                        {
                            <div class="mb-2">
                                <div class="od-muted small">Địa chỉ giao hàng</div>
                                <div class="fw-semibold">@Model.ShippingAddress</div>
                            </div>
                        }
                        else if (Model.DeliveryMethod == 1 && Model.Store != null)
                        {
                            <div class="mb-2">
                                <div class="od-muted small">Nhận tại cửa hàng</div>
                                <div class="fw-semibold">@Model.Store.Name</div>
                                <div class="od-muted">@Model.Store.Address</div>
                            </div>
                        }
                        <div class="mb-2">
                            <div class="od-muted small">Ghi chú</div>
                            <div>@(string.IsNullOrWhiteSpace(Model.Notes) ? "(Không có)" : Model.Notes)</div>
                        </div>
                    </div>
                </div>

                <div class="card od-card mt-3">
                    <div class="card-header bg-white border-0 pt-3">
                        <div class="fw-bold"><i class="bi bi-receipt"></i> Thanh toán</div>
                    </div>
                    <div class="card-body pt-2">
                        <div class="od-summary-row"><div class="od-muted">Tạm tính</div><div class="fw-semibold">@subTotal.ToString("N0") đ</div></div>
                        @if (discount > 0)
                        {
                            <div class="od-summary-row">
                                <div class="od-muted">
                                    Giảm giá Voucher @if (!string.IsNullOrEmpty(Model.CouponCode))
                                    {
                                        <span class="small">(Mã: @Model.CouponCode)</span>
                                    }
                                </div>
                                <div class="fw-semibold text-danger">-@discount.ToString("N0") đ</div>
                            </div>
                        }

                        @if (tradeInDiscount > 0)
                        {
                            <div class="od-summary-row text-danger fw-bold rounded p-1" style="background-color: #fff5f5; border: 1px dashed #f5c2c2;">
                                <div><i class="bi bi-arrow-left-right"></i> Trợ giá thu cũ đổi mới:</div>
                                <div>-@tradeInDiscount.ToString("N0") đ</div>
                            </div>
                        }

                        <div class="od-summary-row"><div class="od-muted">Thành tiền (chưa VAT)</div><div class="fw-semibold">@afterDiscountReal.ToString("N0") đ</div></div>
                        <div class="od-summary-row"><div class="nav-icon od-muted">VAT (10%)</div><div class="fw-semibold">@vat.ToString("N0") đ</div></div>

                        <div class="od-summary-row">
                            <div class="od-muted">Phí vận chuyển</div>
                            <div class="fw-semibold">
                                @if (isFreeShip)
                                {
                                    <span class="text-decoration-line-through text-muted small me-1">30.000 đ</span>
                                    <span class="badge bg-success text-uppercase">Miễn phí tự động</span>
                                }
                                else
                                {
                                    <span>@shipFee.ToString("N0") đ</span>
                                }
                            </div>
                        </div>
                        <hr />
                        <div class="od-summary-row align-items-center"><div class="fw-bold">Tổng cộng</div><div class="fs-5 fw-bold text-danger">@Model.TotalPrice.ToString("N0") đ</div></div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="card od-card">
                    <div class="card-header bg-white border-0 pt-3 d-flex flex-wrap align-items-center justify-content-between gap-2">
                        <div class="fw-bold"><i class="bi bi-shop"></i> @storeName</div>
                        <div class="od-muted small">Mã đơn: #@Model.Id</div>
                    </div>

                    <div class="card-body pt-2">
                        @foreach (var item in Model.OrderDetails ?? new List<OrderDetail>())
                        {
                            var warrantyPerItem = item.Warranties?.Sum(w => w.Price) ?? 0m;
                            var lineTotal = (item.Price + warrantyPerItem) * item.Quantity;
                            var displayName = !string.IsNullOrWhiteSpace(item.ProductName) ? item.ProductName : item.Product?.Name;
                            var img = item.Product?.ImageUrl;

                            <div class="od-item d-flex gap-3">
                                <div class="od-thumb">
                                    @if (!string.IsNullOrWhiteSpace(img))
                                    {
                                        <img src="@img" alt="@displayName" />
                                    }
                                    else
                                    {
                                        <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted"><i class="bi bi-phone fs-4"></i></div>
                                    }
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold">@displayName</div>
                                    @if (item.Warranties != null && item.Warranties.Any())
                                    {
                                        <div class="mt-2 p-2 bg-light rounded border">
                                            <div class="fw-semibold mb-1 small"><i class="bi bi-shield-check text-success"></i> Gói bảo hành đã mua</div>
                                            @foreach (var w in item.Warranties)
                                            {
                                                <div class="d-flex justify-content-between small ps-2">
                                                    <span>• @w.Name (@w.Months tháng)</span>
                                                    <span class="text-danger fw-semibold">+@w.Price.ToString("N0") đ</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                                <div class="text-end od-price">
                                    <div class="od-muted small">x@(item.Quantity)</div>
                                    <div class="fw-semibold">@item.Price.ToString("N0") đ</div>
                                    <div class="fw-bold mt-1">@lineTotal.ToString("N0") đ</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    window.addEventListener('load', function () {
        var adBanner = document.querySelector('.carousel');
        if (adBanner) adBanner.style.display = 'none';
    });
</script>