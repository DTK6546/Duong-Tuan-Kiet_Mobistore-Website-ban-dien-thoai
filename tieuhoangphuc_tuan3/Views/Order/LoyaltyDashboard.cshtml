@model List<WebBanDienThoai.Models.LoyaltyReward>
@{
    ViewData["Title"] = "Trung tâm khách hàng thân thiết - MobiStore";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var vi = new System.Globalization.CultureInfo("vi-VN");
}

<div class="container my-5" style="max-width: 950px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 p-3 shadow-sm mb-4" role="alert">
            <h5 class="fw-bold"><i class="bi bi-patch-check-fill me-1"></i> Chúc mừng!</h5>
            <div>@Html.Raw(TempData["SuccessMessage"])</div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger rounded-4 p-3 mb-4 shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-1"></i> @TempData["ErrorMessage"]
        </div>
    }

    @if (ViewBag.IsBirthdayToday == true)
    {
        <div class="p-3 mb-4 rounded-4 shadow-sm border border-danger d-flex align-items-center justify-content-between text-white" style="background: linear-gradient(135deg, #f43f5e, #be123c); border-radius: 12px;">
            <div>
                <h5 class="fw-bold m-0">🎂 Happy Birthday! Chúc mừng sinh nhật bạn!</h5>
                <span class="small opacity-90">MobiStore đã gửi tặng riêng bạn +50 điểm vào ví thành viên điện tử hôm nay.</span>
            </div>
            <span class="fs-1">🎁</span>
        </div>
    }

    <!-- =========================================================================
         🚀 KHỐI CARD THÀNH VIÊN VÀ QUY CHẾ TÍCH ĐIỂM (GIỮ NGUYÊN CỦA KIỆT)
         ========================================================================= -->
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card border-0 rounded-4 shadow-lg p-4 h-100 @ViewBag.CardClass position-relative overflow-hidden"
                 style="min-height: 240px; background-size: cover; z-index: 1; border-radius: 16px;">

                <div class="position-absolute top-0 start-0 end-0 bottom-0 bg-black bg-opacity-10" style="z-index: -1;"></div>

                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <span class="text-uppercase fw-bold tracking-wider opacity-75" style="font-size: 11px; letter-spacing: 1px;">MobiStore Privilege Card</span>
                        <h4 class="fw-bold m-0 mt-2" style="font-family: monospace; font-size: 1.3rem; word-break: break-all; line-height: 1.2;">
                            @User.Identity?.Name
                        </h4>
                    </div>
                    <span class="fs-2 opacity-75"><i class="bi bi-cpu-fill"></i></span>
                </div>

                <div class="mb-4" style="margin-top: 15px;">
                    <span class="d-block small fw-semibold opacity-75" style="font-size: 12px;">CẤP BẬC HIỆN TẠI:</span>
                    <span class="fs-5 fw-bold"><i class="bi bi-shield-fill-check"></i> @ViewBag.MemberLevel</span>
                </div>

                <div class="mt-auto pt-3 border-top border-white border-opacity-25 d-flex justify-content-between align-items-center">
                    <div>
                        <span class="d-block small fw-semibold opacity-75" style="font-size: 11px;">VÍ ĐIỂM TIÊU DÙNG</span>
                        <span class="fs-3 fw-bold">@ViewBag.CurrentPoints</span> <span class="small fw-bold">điểm</span>
                    </div>
                    <div class="text-end">
                        <span class="d-block small fw-semibold opacity-75" style="font-size: 11px;">TÍCH LŨY HẠNG</span>
                        <span class="fs-5 fw-bold">@ViewBag.RankingPoints Đ</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-white border border-light" style="border-radius: 16px;">
                <h5 class="fw-bold text-dark mb-3"><i class="bi bi-award-fill text-primary"></i> Quy chế tích lũy điểm</h5>
                <p class="small text-muted mb-3">💸 <b>Tích điểm tự động:</b> Mỗi đơn hàng hoàn tất sẽ tự động tích lũy điểm thưởng bằng <b>1% giá trị đơn hàng</b> (Cứ mỗi 100.000 ₫ hóa đơn = +1 điểm vào ví tiêu dùng).</p>

                <div class="border-top pt-2">
                    <span class="fw-bold text-secondary small d-block mb-2">🏅 CƠ CHẾ XETS HẠNG THÀNH VIÊN:</span>
                    <ul class="list-unstyled small text-dark mb-0">
                        <li class="mb-2 d-flex align-items-center">
                            <i class="bi bi-circle-fill text-info me-2" style="font-size: 8px;"></i>
                            <span>Tích lũy từ 10.000 điểm <i class="bi bi-arrow-right text-muted mx-1"></i> Lên hạng <b>Bạc (Silver)</b></span>
                        </li>
                        <li class="mb-2 d-flex align-items-center">
                            <i class="bi bi-circle-fill text-warning me-2" style="font-size: 8px;"></i>
                            <span>Tích lũy từ 20.000 điểm <i class="bi bi-arrow-right text-muted mx-1"></i> Lên hạng <b>Vàng (Gold)</b></span>
                        </li>
                        <li class="mb-2 d-flex align-items-center">
                            <i class="bi bi-circle-fill text-info me-2" style="font-size: 8px;"></i>
                            <span>Tích lũy từ 35.000 điểm <i class="bi bi-arrow-right text-muted mx-1"></i> Hạng <b>Bạch Kim (Platinum)</b></span>
                        </li>
                        <li class="d-flex align-items-center">
                            <i class="bi bi-circle-fill text-dark me-2" style="font-size: 8px;"></i>
                            <span>Tích lũy từ 50.000 điểm <i class="bi bi-arrow-right text-muted mx-1"></i> Lên hạng <b>Kim Cương (Diamond)</b></span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- =========================================================================
         📊 MỚI: KHỐI CHỈ SỐ CRM PHÂN TÍCH SÂU LỊCH SỬ ĐƠN HÀNG CHI TIẾT
         ========================================================================= -->
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 bg-white border border-light mb-5" style="border-radius: 16px;">
        <h5 class="fw-bold text-dark mb-3"><i class="bi bi-person-lines-fill text-primary"></i> Phân tích lịch sử mua sắm (CRM Insights)</h5>
        <div class="row g-3 text-center">
            <div class="col-6 col-md-3">
                <div class="p-3 bg-light rounded-4 h-100">
                    <span class="text-muted small fw-semibold d-block"><i class="bi bi-cart-check text-success"></i> Đơn thành công</span>
                    <h4 class="fw-bold text-dark mt-2 mb-0">@ViewBag.SuccessOrdersCount <span class="fs-6 text-muted">/ @ViewBag.TotalOrdersCount đơn</span></h4>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="p-3 bg-light rounded-4 h-100">
                    <span class="text-muted small fw-semibold d-block"><i class="bi bi-pie-chart text-primary"></i> Tỷ lệ nhận hàng</span>
                    <h4 class="fw-bold text-primary mt-2 mb-0">@ViewBag.SuccessRate%</h4>
                </div>
            </div>
            <div class="col-12 col-md-6">
                <div class="p-3 bg-light rounded-4 h-100 text-md-start d-flex align-items-center gap-3">
                    <div class="fs-2 text-danger bg-danger bg-opacity-10 px-3 py-2 rounded-3"><i class="bi bi-heart-fill"></i></div>
                    <div>
                        <span class="text-muted small fw-semibold d-block">Sản phẩm chi tiêu yêu thích nhất:</span>
                        <h6 class="fw-bold text-danger mt-1 mb-0" style="word-break: break-word;">@ViewBag.FavoriteProduct</h6>
                    </div>
                </div>
            </div>
        </div>

        <!-- BIỂU ĐỒ CỘT THỜI GIAN THỰC TẦN SUẤT CHI TIÊU -->
        <div class="mt-4 pt-3 border-top">
            <span class="fw-bold text-secondary small d-block mb-3"><i class="bi bi-bar-chart-line"></i> BIỂU ĐỒ TẦN SUẤT CHI TIÊU NĂM 2026 (VND):</span>
            <div class="p-2 bg-light rounded-4">
                <canvas id="crmSpentChart" style="max-height: 240px; width: 100%;"></canvas>
            </div>
        </div>
    </div>

    <!-- =========================================================================
         🎁 KHỐI ĐỔI ĐIỂM THƯỞNG VOUCHER (GIỮ NGUYÊN CỦA KIỆT)
         ========================================================================= -->
    <h4 class="fw-bold text-dark mb-4 text-center text-md-start"><i class="bi bi-gift-fill text-danger"></i> Đổi điểm lấy Voucher ưu đãi</h4>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
        @if (Model != null && Model.Any())
        {
            foreach (var reward in Model)
            {
                bool canRedeem = ViewBag.CurrentPoints >= reward.PointsRequired;
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-4 p-4 text-center bg-white border border-light position-relative" style="border-radius: 16px;">
                        <div class="fs-1 mb-2 text-danger"><i class="bi bi-ticket-perforated-fill"></i></div>
                        <h6 class="fw-bold text-dark mb-1">@reward.Title</h6>
                        <p class="text-muted small mb-3">Yêu cầu: <span class="text-primary fw-bold">@reward.PointsRequired điểm</span></p>

                        <div class="mt-auto pt-2 border-top border-light">
                            <form asp-action="RedeemPoints" method="post" onsubmit="return confirm('Bạn chắc chắn muốn dùng @reward.PointsRequired điểm để đổi phần quà này?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="rewardId" value="@reward.Id" />
                                <button type="submit" class="btn btn-sm w-100 rounded-pill fw-bold py-2 @(canRedeem ? "btn-danger shadow-sm" : "btn-outline-secondary disabled")">
                                    @(canRedeem ? "🎁 Đổi quà ngay" : "🔒 Chưa đủ điểm")
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted py-5 border border-dashed rounded-4 bg-white shadow-sm">
                <i class="bi bi-inboxes fs-1 d-block mb-2 text-secondary"></i>
                Chưa có phần thưởng nào được cấu hình từ hệ thống Admin.
            </div>
        }
    </div>
</div>

@section Scripts {
    <!-- Thư viện đồ họa siêu nhẹ render chart -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
        // Nạp dữ liệu chi tiêu 12 tháng năm 2026 từ C# đổ ngầm vào mảng JS
        const monthlyData = @Html.Raw(ViewBag.MonthlyDataJson);

        const ctx = document.getElementById('crmSpentChart').getContext('2d');
        new Chart(ctx, {
        type: 'bar',
        data: {
        labels: ['Th 1', 'Th 2', 'Th 3', 'Th 4', 'Th 5', 'Th 6', 'Th 7', 'Th 8', 'Th 9', 'Th 10', 'Th 11', 'Th 12'],
        datasets: [{
        label: 'Số tiền mua sắm (đ)',
        data: monthlyData,
        backgroundColor: 'rgba(14, 165, 233, 0.7)',
        borderColor: '#0ea5e9',
        borderWidth: 2,
        borderRadius: 5
        }]
        },
        options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
        y: {
        beginAtZero: true,
        ticks: {
        callback: function(value) { return value.toLocaleString('vi-VN') + ' đ'; }
        }
        }
        }
        }
        });
        });
    </script>
}