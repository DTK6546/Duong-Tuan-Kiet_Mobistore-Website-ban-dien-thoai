@model WebBanDienThoai.Models.News
@using WebBanDienThoai.Models
@using System.Globalization

@{
    ViewData["Title"] = Model.Title;

    bool hasCoupon = ViewBag.HasCoupon ?? false;
    bool hasUsed = ViewBag.HasUsed ?? false;
    bool couponAlive = ViewBag.CouponAlive ?? false;
    int remaining = ViewBag.Remaining ?? 0;

    var coupon = Model.Coupon;
    var vi = CultureInfo.GetCultureInfo("vi-VN");
}

@section Meta {

    <meta name="description" content="@Model.Summary">

    <meta property="og:title" content="@Model.Title">
    <meta property="og:description" content="@Model.Summary">
    <meta property="og:image" content="@Model.ImageUrl">
    <meta property="og:type" content="article">

}

<div class="container mt-4 mb-5">

    <div class="row">

        <!-- LEFT CONTENT -->

        <div class="col-lg-8">

            <nav aria-label="breadcrumb">

                <ol class="breadcrumb small bg-light rounded px-3 py-2 mb-3">

                    <li class="breadcrumb-item">
                        <a href="/" class="text-primary text-decoration-none">
                            <i class="bi bi-house"></i> Trang chủ
                        </a>
                    </li>

                    <li class="breadcrumb-item">
                        <a href="/News" class="text-info text-decoration-none">
                            Tin tức
                        </a>
                    </li>

                    <li class="breadcrumb-item active text-secondary">
                        @Model.Title
                    </li>

                </ol>

            </nav>

            <div class="news-detail-box p-4 bg-white rounded-4 shadow-sm">

                <h1 class="fw-bold mb-3 news-title text-primary">
                    @Model.Title
                </h1>

                <div class="d-flex align-items-center text-muted mb-3" style="gap:20px;">

                    <span>
                        <i class="bi bi-clock"></i>
                        @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                    </span>

                    <span>
                        <i class="bi bi-eye"></i>
                        @Model.Views lượt xem
                    </span>

                </div>

                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="text-center mb-4">

                        <img src="@Model.ImageUrl"
                             loading="lazy"
                             alt="@Model.Title"
                             class="img-fluid rounded-4 border news-detail-img shadow"
                             style="max-height:420px;object-fit:cover;" />

                    </div>
                }

                @if (coupon != null)
                {
                    <div class="mb-4">

                        <div class="card border-success shadow-sm">

                            <div class="card-body">

                                <h5 class="card-title text-success mb-2">
                                    🎁 Chương trình khuyến mãi
                                </h5>

                                <p class="card-text small mb-2">

                                    <strong>Mã:</strong> @coupon.Code <br>

                                    <strong>Giảm:</strong>

                                    @(
                                                                    coupon.DiscountPercent.HasValue && coupon.DiscountPercent > 0
                                                                    ? $"{coupon.DiscountPercent}%"
                                                                    : $"{(coupon.DiscountAmount ?? 0).ToString("N0", vi)} VNĐ"
                                                                    )

                                <br>

                                    <strong>Đơn tối thiểu:</strong>
                                    @coupon.MinOrderValue.ToString("N0", vi) VNĐ <br>

                                    <strong>Thời gian:</strong>
                                    @coupon.StartDate.ToString("dd/MM/yyyy")
                                    -
                                    @coupon.EndDate.ToString("dd/MM/yyyy") <br>

                                    <strong>Còn lại:</strong> @remaining mã

                                </p>

                            @if (!couponAlive || remaining <= 0)
                                {
                                    <div class="alert alert-secondary small mb-0">
                                        Mã giảm giá đã hết hạn hoặc đã hết lượt.
                                    </div>
                                }
                                else if (!User.Identity.IsAuthenticated)
                                {
                                    <div class="alert alert-info small mb-0">
                                        Vui lòng <a href="/Identity/Account/Login">đăng nhập</a>
                                        để sử dụng mã <strong>@coupon.Code</strong>.
                                    </div>
                                }
                                else if (hasUsed)
                                {
                                    <div class="alert alert-warning small mb-0">
                                        Bạn đã sử dụng mã này rồi.
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-success small mb-0">
                                        Hãy vào <a href="/ShoppingCart">giỏ hàng</a>
                                        và nhập mã <strong>@coupon.Code</strong>.
                                    </div>
                                }

                            </div>

                        </div>

                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Summary))
                {
                    <h5 class="mb-3 text-secondary news-summary">
                        @Model.Summary
                    </h5>
                }

                <article class="news-content mb-4">
                    @Html.Raw(Model.Content)
                </article>

                <div class="mt-4 mb-4">

                    <span class="fw-bold me-2">Chia sẻ:</span>

                    <a href="https://www.facebook.com/sharer/sharer.php?u=@Context.Request.Scheme://@Context.Request.Host@Context.Request.Path"
                       target="_blank"
                       class="btn btn-sm btn-primary">

                        <i class="bi bi-facebook"></i>
                        Facebook

                    </a>

                    <button class="btn btn-sm btn-secondary"
                            onclick="navigator.clipboard.writeText(window.location.href)">

                        <i class="bi bi-link-45deg"></i>
                        Copy link

                    </button>

                </div>

                @if (ViewBag.RelatedNews != null)
                {
                    var related = ViewBag.RelatedNews as List<WebBanDienThoai.Models.News>;

                    <h4 class="fw-bold mb-3 mt-5">
                        Tin tức liên quan
                    </h4>

                    <div class="row">

                        @foreach (var item in related)
                        {

                            <div class="col-md-4 mb-3">

                                <a href="/News/Detail/@item.Id"
                                   class="text-decoration-none text-dark">

                                    <div class="card shadow-sm h-100">

                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl"
                                                 loading="lazy"
                                                 class="card-img-top"
                                                 style="height:150px;object-fit:cover;">
                                        }

                                        <div class="card-body">

                                            <h6 class="fw-bold">
                                                @item.Title
                                            </h6>

                                        </div>

                                    </div>

                                </a>

                            </div>

                        }

                    </div>

                }

                <a href="/News"
                   class="btn btn-outline-primary px-4 mt-2">

                    <i class="bi bi-arrow-left"></i>
                    Quay lại

                </a>

            </div>

        </div>

        <!-- SIDEBAR -->

        <div class="col-lg-4">

            <div class="card shadow-sm mb-4">

                <div class="card-header fw-bold">
                    🔥 Tin nổi bật
                </div>

                <div class="list-group list-group-flush">

                    @foreach (var item in ViewBag.HotNews)
                    {

                        <a href="/News/Detail/@item.Id"
                           class="list-group-item list-group-item-action">

                            <div class="d-flex gap-2">

                                <img src="@item.ImageUrl"
                                     style="width:70px;height:50px;object-fit:cover;">

                                <div>

                                    <div style="font-size:14px;font-weight:600">
                                        @item.Title
                                    </div>

                                    <small class="text-muted">
                                        👁 @item.Views
                                    </small>

                                </div>

                            </div>

                        </a>

                    }

                </div>

            </div>

        </div>

    </div>

</div>