@model WebBanDienThoai.Models.ProductWithSoldCount
@using System.Linq

@{
    var isFlashSale = ViewData["FlashSale"] as bool? == true;

    var hasVariants = Model.Variants != null && Model.Variants.Any();
    var capacities = hasVariants
        ? Model.Variants.Select(v => v.Storage).Distinct().ToList()
        : new List<string>();

    var defaultVariant = hasVariants ? Model.Variants.First() : null;
}

<div class="product-card shadow-sm h-100" data-product-id="@Model.Id">
    @* hidden lưu biến thể đang chọn trên card này *@
    @if (hasVariants && defaultVariant != null)
    {
        <input type="hidden" class="selected-variant-id" value="@defaultVariant.Id" />
    }

    <div class="position-relative">
        <a href="@Url.Action("Display", "Product", new { id = Model.Id })">
            <img src="@Model.ImageUrl" class="product-image w-100" alt="@Model.Name">
        </a>
        @if (isFlashSale)
        {
            <span class="flash-sale-badge">FLASH SALE</span>
        }
        @if (Model.DiscountPercent > 0)
        {
            <span class="discount-badge">-@Model.DiscountPercent%</span>
        }
        @if (ViewBag.HotSale != null && (bool)ViewBag.HotSale)
        {
            <span class="hot-label bg-warning text-dark"><i class="bi bi-fire"></i> Bán chạy</span>
        }
        else if (ViewBag.Discount != null && (bool)ViewBag.Discount)
        {
            <span class="hot-label bg-danger text-white"><i class="bi bi-cash-coin"></i> Giảm giá</span>
        }
        else if (ViewBag.New != null && (bool)ViewBag.New)
        {
            <span class="hot-label bg-success text-white"><i class="bi bi-star-fill"></i> Mới ra mắt</span>
        }
    </div>

    <div class="card-body text-center">
        <h5 class="card-title fw-bold">@Model.Name</h5>

        <div class="d-flex justify-content-center gap-2 mt-2 mb-2">
            <span class="category-badge">@Model.Category?.Name</span>
            @if (Model.SubCategory != null)
            {
                <span class="category-badge">@Model.SubCategory.Name</span>
            }
        </div>

        <div class="sold-count text-muted small mb-2">
            <i class="bi bi-bag-check-fill text-danger me-1"></i> Đã bán @Model.SoldCount
        </div>

        <!-- Rating -->
        <div class="rating-stars mb-2">
            @{
                double avg = Model.Rating;
                int fullStars = (int)Math.Floor(avg);
                bool hasHalf = avg - fullStars >= 0.5;
            }
            @for (int i = 1; i <= 5; i++)
            {
                if (i <= fullStars)
                {
                    <i class="bi bi-star-fill text-warning"></i>
                }
                else if (i == fullStars + 1 && hasHalf)
                {
                    <i class="bi bi-star-half text-warning"></i>
                }
                else
                {
                    <i class="bi bi-star text-warning"></i>
                }
            }
            <span class="text-muted ms-2">(@avg.ToString("0.0"))</span>
        </div>

        <!-- GIÁ (đổi theo biến thể nếu có) -->
        <div class="product-price mb-2">
            @if (hasVariants && defaultVariant != null)
            {
                <h6 class="text-danger fw-bold mb-0">
                    <span class="variant-price">
                        @defaultVariant.Price.ToString("N0") VNĐ
                    </span>
                </h6>
            }
            else
            {
                @if (Model.DiscountPercent > 0)
                {
                    <del>@Model.Price.ToString("N0") VNĐ</del>
                    <h6 class="text-danger fw-bold">@Model.DiscountedPrice.ToString("N0") VNĐ</h6>
                }
                else
                {
                    <h6 class="text-danger fw-bold">@Model.Price.ToString("N0") VNĐ</h6>
                }
            }
        </div>

        <!-- NÚT DUNG LƯỢNG (biến thể) -->
        @if (hasVariants && capacities.Any())
        {
            <div class="variant-capacity-group mb-2">
                @for (int i = 0; i < capacities.Count; i++)
                {
                    var cap = capacities[i];
                    var vCap = Model.Variants.First(v => v.Storage == cap);

                    <button type="button"
                            class="btn btn-outline-secondary btn-sm me-1 mb-1 variant-capacity-btn @(i == 0 ? "active" : "")"
                            data-product-id="@Model.Id"
                            data-capacity="@cap"
                            data-price="@vCap.Price"
                            data-variant-id="@vCap.Id">
                        @cap
                    </button>
                }
            </div>
        }

        <!-- Nút Mua -->
        <div class="d-flex justify-content-center gap-2 mt-2">
            @if (User.Identity.IsAuthenticated && !User.IsInRole("Admin") && !User.IsInRole("Employer"))
            {
                <a href="@Url.Action("Buy", "Product", new { id = Model.Id })" class="btn btn-danger btn-sm">Mua</a>
            }
            else if (User.IsInRole("Admin") || User.IsInRole("Employer"))
            {
                <button class="btn btn-secondary btn-sm" disabled>Mua</button>
            }
            else
            {
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-secondary btn-sm">
                    <i class="bi bi-cart-fill me-2"></i> Mua
                </a>
            }
        </div>

        <!-- Nút So sánh (dùng JS để kèm variantId) -->
        <button type="button"
                class="btn btn-outline-primary btn-sm mt-2 btn-compare"
                data-product-id="@Model.Id">
            So sánh
        </button>
    </div>
</div>

<!-- JS: chọn dung lượng + cập nhật giá + gửi Compare với variantId -->
<script>
    (function () {
        if (window.__bindVariantPriceCard) return;
        window.__bindVariantPriceCard = true;

        document.addEventListener('click', function (e) {
            // ----- Click chọn dung lượng -----
            var btnCap = e.target.closest('.variant-capacity-btn');
            if (btnCap) {
                var productId = btnCap.getAttribute('data-product-id');
                var price = Number(btnCap.getAttribute('data-price')) || 0;
                var variantId = btnCap.getAttribute('data-variant-id') || '';

                // Bỏ active các nút cùng product
                document.querySelectorAll('.variant-capacity-btn[data-product-id="' + productId + '"]')
                    .forEach(function (b) { b.classList.remove('active'); });

                btnCap.classList.add('active');

                var card = btnCap.closest('.product-card');
                if (card) {
                    // cập nhật giá
                    var priceSpan = card.querySelector('.variant-price');
                    if (priceSpan) {
                        priceSpan.textContent = price.toLocaleString('vi-VN') + ' VNĐ';
                    }
                    // lưu variantId đang chọn
                    var hidden = card.querySelector('.selected-variant-id');
                    if (hidden) {
                        hidden.value = variantId;
                    }
                }
                return;
            }

            // ----- Click nút So sánh -----
            var btnCompare = e.target.closest('.btn-compare');
            if (btnCompare) {
                var productId2 = btnCompare.getAttribute('data-product-id');
                var card2 = btnCompare.closest('.product-card');
                var hidden2 = card2 ? card2.querySelector('.selected-variant-id') : null;
                var variantId2 = hidden2 ? hidden2.value : '';

                var url = '@Url.Action("Add", "Compare")' + '?productId=' + productId2;
                if (variantId2) {
                    url += '&variantId=' + encodeURIComponent(variantId2);
                }

                window.location.href = url;
            }
        });
    })();
</script>
