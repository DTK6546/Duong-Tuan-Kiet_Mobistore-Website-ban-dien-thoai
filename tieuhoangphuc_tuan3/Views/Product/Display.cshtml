@{
    var faqs = ViewBag.Faqs as List<WebBanDienThoai.Models.ProductFaq> ?? new();
    var qas = ViewBag.QAs as List<WebBanDienThoai.Models.ProductQuestion> ?? new();
}

<div class="container mt-4">
    <div class="mt-5">
        <h4 class="mb-3">Hỏi & Đạp / FAQ</h4>

        @if (faqs.Any())
        {
            <div class="mb-4">
                <h5 class="mb-2">Câu hỏi thường gặp</h5>

                <div class="accordion" id="faqAccordion">
                    @for (int i = 0; i < faqs.Count; i++)
                    {
                        var f = faqs[i];
                        var cid = $"faq_{f.Id}";
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="h_@cid">
                                <button class="accordion-button @(i == 0 ? "" : "collapsed")" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#c_@cid"
                                        aria-expanded="@(i == 0 ? "true" : "false")" aria-controls="c_@cid">
                                    @f.Question
                                </button>
                            </h2>
                            <div id="c_@cid" class="accordion-collapse collapse @(i == 0 ? "show" : "")" aria-labelledby="h_@cid">
                                <div class="accordion-body">
                                    @Html.Raw(f.Answer.Replace("\n", "<br/>"))
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="border rounded-3 p-3" style="background:#fff;">
            <h5 class="mb-3">Hỏi đáp về sản phẩm</h5>

            @{
                bool isStaff = User.IsInRole("Admin") || User.IsInRole("Employer");
            }

            @if (User.Identity.IsAuthenticated && !isStaff)
            {
                <form asp-action="AskQuestion" asp-controller="Product" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <div class="input-group">
                        <input name="question" class="form-control" maxlength="800"
                               placeholder="Hỏi về cấu hình, bảo hành, tương thích, phụ kiện trong hộp..." />
                        <button class="btn btn-primary" type="submit">Gửi câu hỏi</button>
                    </div>
                    <div class="small text-muted mt-1">* Tối đa 800 ký tự. Không nhập thông tin nhạy cảm.</div>
                </form>
            }
            else if (!User.Identity.IsAuthenticated)
            {
                <div class="alert alert-warning mb-3">
                    Bạn cần <a href="/Identity/Account/Login">đăng nhập</a> để đặt câu hỏi.
                </div>
            }
            else if (isStaff)
            {
                <div class="alert alert-info mb-3">
                    Tài khoản nhân viên không đặt câu hỏi như khách hàng. Bạn có thể phản hồi và duyệt/ẩn câu hỏi bên dưới.
                </div>
            }

            @if (qas == null || !qas.Any())
            {
                <div class="text-muted">Chưa có câu hỏi nào.</div>
            }
            else
            {
                @foreach (var q in qas)
                {
                    var qName = q.User?.FullName ?? q.User?.UserName ?? "Người dùng";
                    var isApproved = q.IsApproved;

                    <div class="border-top pt-3 mt-3">
                        <div class="d-flex justify-content-between flex-wrap gap-2">
                            <div>
                                <span class="fw-semibold">@qName</span>
                                <span class="text-muted small ms-2">@q.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>

                                @if (isStaff)
                                {
                                    if (isApproved)
                                    {
                                        <span class="badge bg-success-subtle text-success border ms-2">Đã duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning border ms-2">Chờ duyệt</span>
                                    }
                                }
                            </div>

                            @if (isStaff)
                            {
                                <div class="d-flex gap-2">
                                    @if (isApproved)
                                    {
                                        <form asp-action="HideQuestion" asp-controller="Product" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="questionId" value="@q.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">Ẩn</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="ApproveQuestion" asp-controller="Product" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="questionId" value="@q.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-success">Duyệt</button>
                                        </form>
                                    }

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <form asp-action="DeleteQuestion" asp-controller="Product" method="post" class="d-inline"
                                              onsubmit="return confirm('Xóa câu hỏi này và toàn bộ phản hồi?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="questionId" value="@q.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                        </form>
                                    }
                                </div>
                            }
                        </div>

                        <div class="mt-1">@q.Question</div>

                        @if (q.Replies != null && q.Replies.Any())
                        {
                            <div class="ms-3 mt-2">
                                @foreach (var rep in q.Replies.OrderBy(r => r.CreatedAt))
                                {
                                    var repName = rep.User?.FullName ?? rep.User?.UserName ?? "Admin/Staff";
                                    var editId = $"editReply_{rep.Id}";

                                    <div class="reply-box border rounded-3 p-2 mt-2" style="background:#fafafa;">
                                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="fw-semibold">@repName</span>
                                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Trả lời</span>
                                                @if (rep.UpdatedAt != null)
                                                {
                                                    <span class="badge bg-secondary-subtle text-secondary border">Đã sửa</span>
                                                }
                                            </div>

                                            <div class="d-flex align-items-center gap-2">
                                                <span class="text-muted small">@rep.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>

                                                @if (isStaff)
                                                {
                                                    <button class="btn btn-sm btn-outline-secondary"
                                                            type="button" data-bs-toggle="collapse" data-bs-target="#@editId">
                                                        Sửa
                                                    </button>

                                                    <form asp-action="DeleteQuestionReply" asp-controller="Product" method="post" class="d-inline"
                                                          onsubmit="return confirm('Xóa phản hồi này?');">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="replyId" value="@rep.Id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                                    </form>
                                                }
                                            </div>
                                        </div>

                                        <div class="mt-1 word-break-all">@rep.Content</div>

                                        @if (isStaff)
                                        {
                                            <div class="collapse mt-2" id="@editId">
                                                <form asp-action="EditQuestionReply" asp-controller="Product" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="replyId" value="@rep.Id" />
                                                    <textarea name="content" class="form-control" rows="2" required>@rep.Content</textarea>
                                                    <div class="mt-2 d-flex gap-2">
                                                        <button class="btn btn-sm btn-primary" type="submit">Lưu</button>
                                                        <button class="btn btn-sm btn-outline-secondary" type="button"
                                                                data-bs-toggle="collapse" data-bs-target="#@editId">
                                                            Hủy
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }

                        @if (isStaff)
                        {
                            <form asp-action="ReplyQuestion" asp-controller="Product" method="post" class="mt-2 ms-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="questionId" value="@q.Id" />
                                <div class="input-group input-group-sm">
                                    <textarea name="content" class="form-control" rows="2" required
                                              placeholder="Phản hồi câu hỏi này..."></textarea>
                                    <button class="btn btn-outline-secondary" type="submit">Trả lời</button>
                                </div>
                                <div class="small text-muted mt-1">
                                    * Trả lời sẽ tự động duyệt câu hỏi (nếu đang chờ duyệt).
                                </div>
                            </form>
                        }
                    </div>
                }
            }
        </div>
    </div>

    <div class="mt-5">
        <h4 class="mb-3">Đánh giá sản phẩm</h4>

        <div class="mb-3">
            <span class="fw-bold fs-5">@avg.ToString("0.0")</span>
            @for (int i = 1; i <= 5; i++)
            {
                if (i <= fullStars)
                {
                    <i class="bi bi-star-fill text-warning"></i>
                }
                else if (i == fullStars + 1 && hasHalf)
                {
                    <i class="bi bi-star-half text-warning"></i>
                }
                else
                {
                    <i class="bi bi-star text-warning"></i>
                }
            }
            <span class="ms-2 text-muted">(@((int)(ViewBag.TotalRatings ?? 0)) đánh giá)</span>
        </div>

        <form asp-action="Display" asp-route-id="@Model.Id" method="get" class="d-flex flex-wrap gap-2 align-items-center mb-3">
            <input type="hidden" name="variantId" value="@(ViewBag.SelectedVariant?.Id)" />

            <select name="star" class="form-select" style="width:150px">
                <option value="">Tất cả sao</option>
                @for (int s = 5; s >= 1; s--)
                {
                    <option value="@s" selected="@(filterStar.HasValue && filterStar.Value == s)">
                        @s sao
                    </option>
                }
            </select>

            <label class="form-check m-0">
                <input class="form-check-input" type="checkbox" name="hasImages" value="true" checked="@(filterHasImages)" />
                <span class="form-check-label">Có ảnh</span>
            </label>

            <label class="form-check m-0">
                <input class="form-check-input" type="checkbox" name="verifiedOnly" value="true" checked="@(filterVerifiedOnly)" />
                <span class="form-check-label">Đã mua</span>
            </label>

            <select name="sort" class="form-select" style="width:180px">
                <option value="new" selected="@(filterSort == "new")">Mới nhất</option>
                <option value="helpful" selected="@(filterSort == "helpful")">Hữu ích nhất</option>
                <option value="high" selected="@(filterSort == "high")">Điểm cao → thấp</option>
                <option value="low" selected="@(filterSort == "low")">Điểm thấp → cao</option>
            </select>

            <button class="btn btn-outline-primary" type="submit">Lọc</button>
        </form>

        @if (User.Identity.IsAuthenticated)
        {
            var myRating = ViewBag.MyRating as WebBanDienThoai.Models.ProductRating;

            if (!canReview)
            {
                <div class="alert alert-warning">
                    Bạn cần mua và nhận hàng thành công mới được đánh giá sản phẩm này.
                </div>
            }
            else
            {
                if (myRating != null)
                {
                    <div class="alert alert-info mb-2">Bạn đã đánh giá. Có thể sửa lại đánh giá!</div>
                }

                <form asp-action="SubmitRating" method="post" enctype="multipart/form-data" class="mb-4">
                    <input type="hidden" name="productId" value="@Model.Id" />

                    <div class="mb-2">
                        <label class="form-label fw-bold text-secondary">Chọn số sao đánh giá:</label>
                        <div class="text-start">
                            <div id="star-group" class="d-flex gap-1" style="font-size: 2rem; direction: ltr;">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var myRating = ViewBag.MyRating as WebBanDienThoai.Models.ProductRating;
                                    bool isChecked = myRating != null && myRating.Stars == i;

                                    <input type="radio" name="stars" id="star-@i" value="@i"
                                           class="star-radio-input" style="position: absolute; opacity: 0; width: 0; height: 0;"
                                    @(isChecked ? "checked" : "") required />

                                    <label for="star-@i" class="star-label-item" data-value="@i" style="cursor: pointer; color: #ddd; transition: color 0.15s;">
                                        <i class="bi bi-star-fill"></i>
                                    </label>
                                }
                            </div>
                        </div>
                    </div>

                    <style>
                                    /* Style mồi khi hover và khi được chọn */
                                    .star-label-item:hover,
                                    .star-label-item.hovered,
                                    .star-label-item.selected {
                                        color: #ffb300 !important;
                                    }
                    </style>

                    <div class="mb-2">
                        <label class="form-label">Nhận xét:</label>
                        <textarea name="comment" class="form-control" rows="2">@myRating?.Comment</textarea>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Ảnh đánh giá (tối đa 5 ảnh):</label>
                        <input type="file" name="images" multiple accept="image/*" class="form-control" />
                        <div class="small text-muted">* jpg/png/webp, mỗi ảnh ≤ 2MB</div>
                    </div>

                    <button type="submit" class="btn btn-primary">Gửi đánh giá</button>
                </form>
            }
        }
        else
        {
            <div class="alert alert-warning">
                Bạn cần <a href="/Identity/Account/Login">đăng nhập</a> để đánh giá sản phẩm này.
            </div>
        }

        <div class="row bg-white p-4 rounded-3 shadow-sm mb-4 border align-items-center">
            <div class="col-md-4 text-center border-end">
                <h1 class="display-3 fw-bold text-primary mb-0">@avg.ToString("0.0")</h1>
                <div class="text-warning fs-4 mb-2">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi @(i <= Math.Round(avg) ? "bi-star-fill" : "bi-star")"></i>
                    }
                </div>
                <p class="text-muted">@((int)(ViewBag.TotalRatings ?? 0)) đánh giá & @Model.SoldCount lượt bán</p>
            </div>
            <div class="col-md-8 ps-md-5">
                @{
                    int sLevel = 5;
                    int total = (int)(ViewBag.TotalRatings ?? 0);
                }
                @foreach (var count in starDistribution)
                {
                    <div class="d-flex align-items-center mb-1">
                        <span style="width: 50px;" class="small fw-bold">@sLevel sao</span>
                        <div class="progress flex-grow-1 mx-2" style="height: 8px;">
                            <div class="progress-bar bg-warning" style="width: @(total > 0 ? (count * 100 / total) : 0)%"></div>
                        </div>
                        <span class="text-muted small" style="width: 30px;">@count</span>
                    </div>
                    sLevel--;
                }
            </div>
        </div>

        <div>
            @if (!ratings.Any(r => r.IsApproved || (User.Identity.IsAuthenticated && r.UserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)))
            {
                <div class="text-muted">Chưa có đánh giá nào theo bộ lọc hiện tại.</div>
            }
            else
            {
                @* =========================================================================
            // 🌟 KHỐI CẬP NHẬT CHÍ MẠNG: THAY THẾ TOÀN BỘ VÒNG LẶP FOREACH RATINGS CỦA BẠN
            // ========================================================================= *@
                @foreach (var r in ratings)
                {
                    // Đồng bộ lấy CurrentUserId bốc từ ViewBag truyền từ Controller sang để check chính chủ
                    var currentUserId = ViewBag.CurrentUserId as string;

                    if (r.IsApproved || (User.Identity.IsAuthenticated && r.UserId == currentUserId))
                    {
                        var displayName = r.User?.FullName ?? r.User?.UserName ?? "Người dùng";
                        var firstChar = !string.IsNullOrWhiteSpace(displayName) ? displayName.Trim()[0].ToString().ToUpper() : "U";
                        var isEdited = r.UpdatedAt.HasValue;

                        <div class="rating-item border-bottom pb-3 mb-3" style="@(!r.IsApproved ? "background-color: #fff3cd; padding: 10px; border-radius: 8px;" : "")">
                            <div class="d-flex align-items-start gap-2">
                                <div class="rating-avatar">@firstChar</div>

                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center flex-wrap gap-2">
                                        <span class="fw-bold text-dark fs-6">@displayName</span>

                                        @* 🚀 HIỂN THỊ BADGE TÍCH XANH CHUẨN XÁC KHI ĐÃ ĐƯỢC XÁC MINH MUA HÀNG *@
                                        @if (r.IsVerifiedPurchase)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success border-opacity-50 px-2.5 py-1.5 small d-inline-flex align-items-center gap-1 shadow-sm" style="font-size: 11px; font-weight: 600; border-radius: 20px;">
                                                <i class="bi bi-patch-check-fill text-success" style="font-size: 13px;"></i> ✓ Đã mua hàng tại MobiStore
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-muted border border-secondary border-opacity-25 px-2.5 py-1.5 small d-inline-flex align-items-center gap-1" style="font-size: 11px; font-weight: 500; border-radius: 20px;">
                                                <i class="bi bi-person-fill text-secondary"></i> Khách vãng lai
                                            </span>
                                        }

                                        @if (!r.IsApproved)
                                        {
                                            <span class="badge bg-warning text-dark border border-warning px-2 py-1 small" style="font-size: 11px; border-radius: 4px;">
                                                <i class="bi bi-hourglass-split me-1"></i> Đang chờ duyệt nội dung
                                            </span>
                                        }

                                        <span class="ms-1">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi @(i <= r.Stars ? "bi-star-fill text-warning" : "bi-star text-warning")"></i>
                                            }
                                        </span>

                                        <span class="text-muted small">
                                            @r.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                            @if (isEdited)
                                            {
                                                <span class="ms-1">(đã sửa)</span>
                                            }
                                        </span>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(r.Comment))
                                    {
                                        <div class="mt-1 word-break-all">@r.Comment</div>
                                    }
                                    else
                                    {
                                        <div class="mt-1 text-muted fst-italic small">Không có nhận xét.</div>
                                    }

                                    @if (r.Images != null && r.Images.Any())
                                    {
                                        <div class="d-flex gap-2 flex-wrap mt-2">
                                            @foreach (var img in r.Images)
                                            {
                                                <a href="@img.Url" target="_blank">
                                                    <img src="@img.Url" style="width:80px;height:80px;object-fit:cover;border-radius:8px;border:1px solid #eee" />
                                                </a>
                                            }
                                        </div>
                                    }

                                    <div class="d-flex gap-2 mt-2">
                                        <button type="button" class="btn btn-sm btn-outline-success" onclick="voteRating(@r.Id,true)">
                                            👍 <span id="like-@r.Id">@r.LikeCount</span>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="voteRating(@r.Id,false)">
                                            👎 <span id="dislike-@r.Id">@r.DislikeCount</span>
                                        </button>

                                        @if (User.Identity.IsAuthenticated)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="reportRating(@r.Id)">
                                                Báo cáo
                                            </button>
                                        }
                                    </div>

                                    @if (r.Replies != null && r.Replies.Any())
                                    {
                                        <div class="ms-3 mt-2">
                                            @foreach (var reply in r.Replies)
                                            {
                                                var replyName = reply.User?.FullName ?? reply.User?.UserName ?? "Admin/Staff";
                                                <div class="reply-box">
                                                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                                        <div class="d-flex align-items-center gap-2">
                                                            <span class="fw-semibold">@replyName</span>
                                                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Phản hồi</span>
                                                        </div>
                                                        <span class="text-muted small">@reply.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                                    </div>
                                                    <div class="mt-1 word-break-all">@reply.Content</div>
                                                </div>
                                            }
                                        </div>
                                    }

                                    @if (User.IsInRole("Admin") || User.IsInRole("Employer"))
                                    {
                                        <form asp-action="ReplyRating" method="post" class="mt-2 ms-3">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productRatingId" value="@r.Id" />
                                            <div class="input-group input-group-sm">
                                                <textarea name="content" class="form-control" rows="2" placeholder="Phản hồi đánh giá này..." required></textarea>
                                                <button class="btn btn-outline-secondary" type="submit">Phản hồi</button>
                                            </div>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            }
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {

    function showPopup(message, time = 1600) {
    const popup = document.getElementById('custom-popup-success');
    const msg = document.getElementById('custom-popup-message');
    if (!popup || !msg) return;
    msg.innerHTML = message;
    popup.style.display = 'flex';
    setTimeout(() => { popup.style.display = 'none'; }, time);
    }

    function updateCartCount() {
    fetch('/ShoppingCart/GetCartCount')
    .then(res => res.json())
    .then(data => {
    const el = document.getElementById('cartCount');
    if (el) el.innerText = data.count;
    });
    }

    function parseVndFromText(text) {
    if (!text) return 0;
    const digits = String(text).replace(/[^\d]/g, '');
    return digits ? Number(digits) : 0;
    }

    function formatVnd(n) {
    return Number(n || 0).toLocaleString('vi-VN') + ' VNĐ';
    }

    const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value;

    // =========================================================================
    // 📉 ✨ SCRIPT 1: AJAX ĐĂNG KÝ MỐC ALERT KHẤU TRỪ THEO DÕI GIÁ GIẢM
    // =========================================================================
    window.registerPriceAlert = function(productId) {
    const price = document.getElementById("targetPriceInput").value;
    if(!price || price <= 0) { alert("Vui lòng nhập giá mong muốn hợp lệ!"); return; }

    // Sửa đường dẫn bọc đúng chuẩn sang PriceAlert/RegisterAlert
    fetch('/PriceAlert/RegisterAlert', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: `productId=${productId}&targetPrice=${price}`
    })
    .then(res => res.json())
    .then(data => {
    alert(data.message);
    if(data.success) document.getElementById("targetPriceInput").value = '';
    });
    }

    // =========================================================================
    // 📊 ✨ SCRIPT 2: FETCH DATA VÀ RENDER BIỂU ĐỒ LỊCH SỬ GIÁ SẢN PHẨM
    // =========================================================================
    fetch('/Product/GetPriceHistory?productId=' + @Model.Id)
    .then(res => res.json())
    .then(data => {
    const ctx = document.getElementById('priceHistoryChart').getContext('2d');
    new Chart(ctx, {
    type: 'line',
    data: {
    labels: data.dates,
    datasets: [{
    label: 'Giá thực tế (đ)',
    data: data.prices,
    borderColor: '#0ea5e9',
    backgroundColor: 'rgba(14, 165, 233, 0.1)',
    borderWidth: 2,
    tension: 0.3,
    fill: true
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: {
    y: {
    ticks: { callback: function(value) { return value.toLocaleString('vi-VN') + ' đ'; } }
    }
    }
    }
    });
    });

    // Copy coupon
    document.querySelectorAll('.copy-coupon-btn').forEach(btn => {
    btn.addEventListener('click', async function () {
    const code = this.getAttribute('data-code');
    try {
    await navigator.clipboard.writeText(code);
    showPopup(`Đã copy mã: <b>${code}</b>`);
    } catch {
    alert('Không copy được, bạn copy thủ công: ' + code);
    }
    });
    });

    // Gallery thumbs sync
    const carousels = document.querySelectorAll('[id^="productGallery_"]');
    carousels.forEach(function (carouselEl) {
    const thumbs = carouselEl.parentElement.querySelectorAll('.tgdd-thumb');
    carouselEl.addEventListener('slide.bs.carousel', function (e) {
    const index = e.to;
    thumbs.forEach(function (t, i) { t.classList.toggle('active', i === index); });
    });
    thumbs.forEach(function (thumb) {
    thumb.addEventListener('click', function () {
    thumbs.forEach(t => t.classList.remove('active'));
    this.classList.add('active');
    });
    });
    });

    // Installment calculator
    function updateInstallment() {
    const priceEl = document.getElementById('displayPrice');
    const monthsEl = document.getElementById('installmentMonths');
    const downEl = document.getElementById('installmentDown');

    const price = parseVndFromText(priceEl?.textContent || "");
    const months = Number(monthsEl?.value || 6);

    let down = parseVndFromText(downEl?.value || "0");
    if (down < 0) down = 0;
    if (down > price) down = price;

    const remain = price - down;
    const perMonth = months > 0 ? Math.round(remain / months) : 0;

    document.getElementById('installmentPriceText').textContent = formatVnd(price);
    document.getElementById('installmentPerMonth').textContent = formatVnd(perMonth);
    }
    document.getElementById('installmentMonths')?.addEventListener('change', updateInstallment);
    document.getElementById('installmentDown')?.addEventListener('input', updateInstallment);

    // Variants logic
    const variants = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(variantDtos));
    const hasVariants = Array.isArray(variants) && variants.length > 0;
    window.hasProductVariants = hasVariants;

    const addToCartBtn = document.getElementById('addToCartButton');
    const buyNowBtn = document.getElementById('buyNowButton');

    let selectedCapacity = null;
    let selectedColor = null;

    const qtyInput = document.getElementById('quantity');
    const cartQtyHidden = document.getElementById('cartQuantity');
    const buyNowQtyHidden = document.getElementById('buyNowQuantity');

    function syncQtyToHidden() {
    const v = qtyInput?.value || "1";
    if (cartQtyHidden) cartQtyHidden.value = v;
    if (buyNowQtyHidden) buyNowQtyHidden.value = v;
    }
    qtyInput?.addEventListener('input', syncQtyToHidden);
    syncQtyToHidden();

    const priceEl = document.getElementById('displayPrice');
    const specStorageEl = document.getElementById('specStorage');
    const specStorageAvailEl = document.getElementById('specStorageAvailable');

    const basePriceText = priceEl ? priceEl.textContent : '—';
    const baseStorageText = specStorageEl ? specStorageEl.textContent : '';
    const baseStorageAvailText = specStorageAvailEl ? specStorageAvailEl.textContent : '';

    function restoreBaseUI() {
    if (priceEl) priceEl.textContent = basePriceText || '—';
    if (specStorageEl) specStorageEl.textContent = baseStorageText || '';
    if (specStorageAvailEl) specStorageAvailEl.textContent = baseStorageAvailText || '';
    updateInstallment();
    }

    function setHiddenVariantId(variantId) {
    document.getElementById('SelectedVariantId')?.setAttribute('value', variantId || "");
    const w = document.getElementById('WishlistVariantId'); if (w) w.value = variantId || "";
    const b = document.getElementById('BuyNowVariantId'); if (b) b.value = variantId || "";
    }

    function setPrice(priceNumber) {
    if (!priceEl) return;
    priceEl.textContent = Number(priceNumber || 0).toLocaleString('vi-VN') + ' VNĐ';
    }

    function setSpecs(storage, storageAvailable) {
    if (specStorageEl) specStorageEl.textContent = storage || '';
    if (specStorageAvailEl) specStorageAvailEl.textContent = storageAvailable || '';
    }

    /*  */

    function setSku(sku) {
    const el = document.getElementById('variantSku');
    if (el) el.textContent = (sku && String(sku).trim()) ? sku : '—';
    }

    function setVariantImage(imageUrl) {
    if (!imageUrl) return;
    const firstSlideImg = document.querySelector('[id^="productGallery_"] .carousel-item:first-child img');
    if (firstSlideImg) firstSlideImg.src = imageUrl;
    const firstThumb = document.querySelector('.tgdd-thumb-list .tgdd-thumb:first-child');
    if (firstThumb) firstThumb.src = imageUrl;
    const mainImage = document.getElementById('mainImage');
    if (mainImage && !firstSlideImg) mainImage.src = imageUrl;
    }

    function setActiveButtons(capacity, color) {
    document.querySelectorAll('.variant-capacity-btn').forEach(btn => {
    btn.classList.toggle('active', btn.getAttribute('data-capacity') === capacity);
    });
    document.querySelectorAll('.variant-color-btn').forEach(btn => {
    btn.classList.toggle('active', btn.getAttribute('data-color') === color);
    });
    }

    function setStockUIState(state, stock = 0) {
    const badge = document.getElementById('stockBadge');
    const text = document.getElementById('stockText');

    if (state === 'unselected') {
    if (badge) { badge.className = "badge bg-secondary"; badge.textContent = "Chưa chọn phiên bản"; }
    if (text) text.textContent = "Vui lòng chọn Dung lượng và Màu sắc";
    if (addToCartBtn) addToCartBtn.disabled = true;
    if (buyNowBtn) buyNowBtn.disabled = true;
    if (qtyInput) { qtyInput.min = 1; qtyInput.max = "1"; qtyInput.value = 1; syncQtyToHidden(); }
    return;
    }

    if (state === 'notfound') {
    if (badge) { badge.className = "badge bg-warning text-dark"; badge.textContent = "Không có phiên bản"; }
    if (text) text.textContent = "Tổ hợp dung lượng + màu này không tồn tại";
    if (addToCartBtn) addToCartBtn.disabled = true;
    if (buyNowBtn) buyNowBtn.disabled = true;
    if (qtyInput) { qtyInput.min = 1; qtyInput.max = "1"; qtyInput.value = 1; syncQtyToHidden(); }
    return;
    }

    const qty = parseInt(stock || 0);
    const inStock = qty > 0;

    if (badge) {
    badge.className = inStock ? "badge bg-success" : "badge bg-danger";
    badge.textContent = inStock ? "Còn hàng" : "Hết hàng";
    }
    if (text) text.textContent = inStock ? `Còn ${qty} sản phẩm` : "Tạm hết hàng";

    if (addToCartBtn) addToCartBtn.disabled = !inStock;
    if (buyNowBtn) buyNowBtn.disabled = !inStock;

    if (qtyInput) {
    qtyInput.min = 1;
    qtyInput.value = 1;
    qtyInput.max = inStock ? String(qty) : "1";
    syncQtyToHidden();
    }
    }

    function capacityHasStock(capacity, colorFilter) {
    return variants.some(v => v.capacity === capacity && (!colorFilter || v.color === colorFilter) && (v.stock || 0) > 0);
    }

    function colorHasStock(color, capacityFilter) {
    return variants.some(v => v.color === color && (!capacityFilter || v.capacity === capacityFilter) && (v.stock || 0) > 0);
    }

    function updateOptionAvailability() {
    document.querySelectorAll('.variant-capacity-btn').forEach(btn => {
    const cap = btn.getAttribute('data-capacity');
    btn.disabled = !capacityHasStock(cap, selectedColor);
    });
    document.querySelectorAll('.variant-color-btn').forEach(btn => {
    const c = btn.getAttribute('data-color');
    btn.disabled = !colorHasStock(c, selectedCapacity);
    });
    }

    function applyVariantExact(variant) {
    setHiddenVariantId(variant.id);
    setSku(variant.sku);
    setVariantImage(variant.imageUrl);
    setPrice(variant.discountedPrice);
    setSpecs(variant.storage || variant.capacity || '', variant.storageAvailable || '');
    setStockUIState('selected', parseInt(variant.stock || 0));
    updateInstallment();
    syncQtyToHidden();
    }

    function resolveSelection() {
    setActiveButtons(selectedCapacity, selectedColor);
    updateOptionAvailability();

    if (!selectedCapacity || !selectedColor) {
    setHiddenVariantId("");
    setSku("");
    setStockUIState('unselected');
    restoreBaseUI();
    return;
    }

    const exact = variants.find(v => v.capacity === selectedCapacity && v.color === selectedColor);
    if (!exact) {
    setHiddenVariantId("");
    setSku("");
    setStockUIState('notfound');
    restoreBaseUI();
    return;
    }

    applyVariantExact(exact);
    }

    if (hasVariants) {
    selectedCapacity = null;
    selectedColor = null;

    setHiddenVariantId("");
    setSku("");
    setStockUIState('unselected');
    restoreBaseUI();
    updateOptionAvailability();

    const urlVarId = new URLSearchParams(window.location.search).get('variantId');
    if (urlVarId) {
    const pre = variants.find(v => String(v.id) === String(urlVarId));
    if (pre) {
    selectedCapacity = pre.capacity || null;
    selectedColor = pre.color || null;
    resolveSelection();
    }
    }

    document.querySelectorAll('.variant-capacity-btn').forEach(btn => {
    btn.addEventListener('click', function () {
    if (this.disabled) return;
    const cap = this.getAttribute('data-capacity');
    selectedCapacity = (selectedCapacity === cap) ? null : cap;
    resolveSelection();
    });
    });

    document.querySelectorAll('.variant-color-btn').forEach(btn => {
    btn.addEventListener('click', function () {
    if (this.disabled) return;
    const c = this.getAttribute('data-color');
    selectedColor = (selectedColor === c) ? null : c;
    resolveSelection();
    });
    });
    } else {
    setSku('');
    updateInstallment();
    syncQtyToHidden();
    }

    const provSel = document.getElementById('shipProvince');
    const distSel = document.getElementById('shipDistrict');
    const feeEl = document.getElementById('shipFee');
    const etaEl = document.getElementById('shipEta');

    function money(v) { return Number(v || 0).toLocaleString('vi-VN') + ' đ'; }
    function formatDate(d) {
    const dd = String(d.getDate()).padStart(2, '0');
    const mm = String(d.getMonth() + 1).padStart(2, '0');
    return `${dd}/${mm}/${d.getFullYear()}`;
    }
    function etaText(minDays, maxDays) {
    minDays = Number(minDays || 0); maxDays = Number(maxDays || 0);
    if (!minDays && !maxDays) return '—';
    const now = new Date();
    const d1 = new Date(now); d1.setDate(now.getDate() + minDays);
    const d2 = new Date(now); d2.setDate(now.getDate() + (maxDays || minDays));
    return (minDays === maxDays) ? formatDate(d1) : `${formatDate(d1)} - ${formatDate(d2)}`;
    }

    async function loadProvinces() {
    const res = await fetch('/Shipping/Provinces');
    const data = await res.json();
    if (provSel) {
    provSel.innerHTML = `<option value="">-- Chọn Tỉnh/TP --</option>`;
    data.forEach(p => {
    const opt = document.createElement('option');
    // SỬA CHỖ NÀY: Quét cả 2 kiểu chữ thường và chữ hoa để chấp hết mọi loại cấu hình JSON
    opt.value = p.code || p.Code;
    opt.textContent = p.name || p.Name;
    provSel.appendChild(opt);
    });
    }
    }

    async function loadDistricts(provinceCode) {
    if (!distSel) return;
    distSel.disabled = true;
    distSel.innerHTML = `<option value="">-- Toàn tỉnh --</option>`;
    if (!provinceCode) return;
    const res = await fetch('/Shipping/Districts?provinceCode=' + encodeURIComponent(provinceCode));
    const data = await res.json();
    data.forEach(d => {
    const opt = document.createElement('option');
    // SỬA CHỖ NÀY LUÔN: Đồng bộ bẫy lỗi mapping cho Quận/Huyện
    opt.value = d.code || d.Code;
    opt.textContent = d.name || d.Name;
    distSel.appendChild(opt);
    });
    distSel.disabled = false;
    }

    async function quote(provinceCode, districtCode) {
    if (!feeEl || !etaEl) return;
    if (!provinceCode) { feeEl.textContent = '—'; etaEl.textContent = '—'; return; }
    const res = await fetch(`/Shipping/Quote?provinceCode=${encodeURIComponent(provinceCode)}&districtCode=${encodeURIComponent(districtCode || '')}`);
    const data = await res.json();
    feeEl.textContent = money(data.fee);
    etaEl.textContent = etaText(data.minDays, data.maxDays);
    }

    // Khởi chạy ngầm và lắng nghe sự kiện thay đổi trên UI
    if (provSel && distSel) {
    const savedProvince = localStorage.getItem('ship_province') || '';
    const savedDistrict = localStorage.getItem('ship_district') || '';

    loadProvinces().then(async () => {
    if (savedProvince) {
    provSel.value = savedProvince;
    await loadDistricts(provSel.value);
    if (savedDistrict) distSel.value = savedDistrict;
    await quote(provSel.value, distSel.value);
    }
    });

    provSel.addEventListener('change', async function() {
    localStorage.setItem('ship_province', this.value);
    localStorage.setItem('ship_district', '');
    await loadDistricts(this.value);
    await quote(this.value, '');
    });

    distSel.addEventListener('change', async function() {
    localStorage.setItem('ship_district', this.value);
    await quote(provSel.value, this.value);
    });
    }

    // ===== Vote / Report =====
    window.voteRating = async function(id, isLike) {
    const res = await fetch('/Product/VoteRating', {
    method: 'POST',
    headers: {
    'Content-Type': 'application/x-www-form-urlencoded',
    ...(token ? { 'RequestVerificationToken': token } : {})
    },
    body: `ratingId=${id}&isLike=${isLike}`
    });

    if (!res.ok) { alert('Không vote được'); return; }
    const data = await res.json();
    document.getElementById(`like-${id}`).innerText = data.like;
    document.getElementById(`dislike-${id}`).innerText = data.dislike;
    }

    window.reportRating = async function(id) {
    const reason = prompt("Lý do báo cáo (tối đa 200 ký tự)?");
    if (!reason) return;

    const res = await fetch('/Product/ReportRating', {
    method: 'POST',
    headers: {
    'Content-Type': 'application/x-www-form-urlencoded',
    ...(token ? { 'RequestVerificationToken': token } : {})
    },
    body: `ratingId=${id}&reason=${encodeURIComponent(reason)}`
    });

    if (!res.ok) { alert('Không gửi báo cáo được'); return; }
    const data = await res.json();
    alert(data.ok ? "Đã gửi báo cáo" : (data.message || "Không gửi được"));
    }

    });

    // === 🚀 KHỐI XỬ LÝ CLICK SÁNG ĐÈN NGÔI SAO ĐÁNH GIÁ ===
    const starLabels = document.querySelectorAll('.star-label-item');
    const starInputs = document.querySelectorAll('.star-radio-input');

    function highlightStars(value) {
    starLabels.forEach(label => {
    const val = parseInt(label.getAttribute('data-value'));
    if (val <= value) {
    label.classList.add('selected');
    } else {
    label.classList.remove('selected');
    }
    });
    }

    // Kiểm tra xem nếu đã có đánh giá cũ thì làm sáng sẵn số sao tương ứng
    const checkedInput = document.querySelector('.star-radio-input:checked');
    if (checkedInput) {
    highlightStars(parseInt(checkedInput.value));
    }

    starLabels.forEach(label => {
    // Khi click chọn sao
    label.addEventListener('click', function () {
    const value = parseInt(this.getAttribute('data-value'));
    highlightStars(value);
    });

    // Khi di chuột vào (Hover)
    label.addEventListener('mouseenter', function () {
    const value = parseInt(this.getAttribute('data-value'));
    starLabels.forEach(l => {
    const v = parseInt(l.getAttribute('data-value'));
    l.classList.toggle('hovered', v <= value);
    });
    });
    });

    // Khi rà chuột ra ngoài thì trả về trạng thái sao đã chọn ban đầu
    document.getElementById('star-group').addEventListener('mouseleave', function () {
    starLabels.forEach(l => l.classList.remove('hovered'));
    const currentChecked = document.querySelector('.star-radio-input:checked');
    if (currentChecked) {
    highlightStars(parseInt(currentChecked.value));
    } else {
    starLabels.forEach(l => l.classList.remove('selected'));
    }
    });
</script>