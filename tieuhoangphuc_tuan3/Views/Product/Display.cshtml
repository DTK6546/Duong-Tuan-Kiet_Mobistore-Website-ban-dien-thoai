@using System.Text.Json
@model WebBanDienThoai.Models.ProductWithSoldCount
@using WebBanDienThoai.Models
@using System.Collections.Generic
@using System.Linq
@using System.Globalization

@{
    var vi = CultureInfo.GetCultureInfo("vi-VN");

    ViewData["Title"] = "Chi Tiết Sản Phẩm";

    var ratings = ViewBag.Ratings as List<WebBanDienThoai.Models.ProductRating> ?? new List<WebBanDienThoai.Models.ProductRating>();
    double avg = (double)(ViewBag.AvgStars ?? 0.0);
    var starDistribution = ViewBag.StarCounts as List<int> ?? new List<int> { 0, 0, 0, 0, 0 };

    int fullStars = (int)Math.Floor(avg);
    bool hasHalf = avg - fullStars >= 0.5;

    // 🔹 Biến thể (màu / dung lượng)
    var variants = ViewBag.Variants as List<ProductVariant> ?? new List<ProductVariant>();
    bool hasVariants = variants.Any();

    var variantDtos = variants.Select(v => new
    {
        id = v.Id,
        color = v.Color,
        capacity = v.Capacity,
        discountedPrice = v.DiscountedPrice,
        stock = v.Stock,
        storage = v.Storage,
        storageAvailable = v.StorageAvailable,
        sku = v.Sku,
        imageUrl = v.ImageUrl
    }).ToList();

    var defaultVariantPrice = hasVariants
        ? variants.First().DiscountedPrice
        : Model.DiscountedPrice;

    // 🔹 Gallery: gom ảnh chính + ảnh phụ
    var galleryId = $"productGallery_{Model.Id}";
    var media = new List<string>();

    if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        media.Add(Model.ImageUrl);
    }

    if (Model.Images != null)
    {
        foreach (var img in Model.Images)
        {
            if (!string.IsNullOrEmpty(img.Url))
            {
                media.Add(img.Url);
            }
        }
    }

    var promoCoupons = ViewBag.PromoCoupons as List<Coupon> ?? new List<Coupon>();

    // Review paging
    int ratingPage = ViewBag.RatingPage ?? 1;
    int ratingTotalPages = ViewBag.RatingTotalPages ?? 1;

    int? filterStar = ViewBag.FilterStar as int?;
    bool filterHasImages = ViewBag.FilterHasImages == true;
    bool filterVerifiedOnly = ViewBag.FilterVerifiedOnly == true;
    string filterSort = ViewBag.FilterSort as string ?? "new";

    bool canReview = ViewBag.CanReview == true;
}

<script>
    window.hasProductVariants = @hasVariants.ToString().ToLower();
</script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    .btn-cart {
        background-color: #4CAF50;
        color: white;
        border-color: #4CAF50;
    }

        .btn-cart:hover {
            background-color: #45a049;
            border-color: #45a049;
        }

    .btn-heart {
        background-color: #f44336;
        color: white;
        border-color: #f44336;
    }

        .btn-heart:hover {
            background-color: #e53935;
            border-color: #e53935;
        }

    .img-thumbnail {
        cursor: pointer;
    }

    .product-description-box {
        background: #fafbfc;
        border-radius: 8px;
        box-shadow: 0 2px 8px #0001;
        font-size: 1.1rem;
        line-height: 1.7;
        word-break: break-word;
    }

    .word-break-all {
        word-break: break-word;
    }

    .rating-select .star-label i {
        color: #ddd;
        transition: color 0.2s;
    }

    .rating-select .star-label.selected i {
        color: #ffb300 !important;
    }

    .custom-popup {
        position: fixed;
        z-index: 9999;
        left: 0;
        right: 0;
        top: 0;
        bottom: 0;
        background: rgba(0,0,0,0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
    }

    .custom-popup-content {
        background: #fff;
        padding: 32px 48px;
        border-radius: 14px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.16);
        display: flex;
        align-items: center;
        flex-direction: column;
        animation: popscale .2s;
        min-width: 300px;
    }

    @@keyframes popscale {
        0% {
            transform: scale(0.7);
        }

        100% {
            transform: scale(1);
        }
    }

    .custom-popup-icon {
        font-size: 48px;
        color: #27c93f;
        margin-bottom: 12px;
    }

    #custom-popup-message {
        font-size: 1.15rem;
        font-weight: 500;
        color: #222;
    }

    .tgdd-gallery {
        background: #fff;
    }

    .tgdd-thumb-list {
        gap: 6px;
        overflow-x: auto;
    }

    .tgdd-thumb {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid #ddd;
        cursor: pointer;
        transition: all 0.15s;
        background: #fff;
        margin-right: 4px;
        margin-bottom: 4px;
    }

        .tgdd-thumb.active {
            border: 2px solid #0d6efd;
            box-shadow: 0 0 0 2px rgba(13,110,253,.25);
        }

        .tgdd-thumb:hover {
            transform: translateY(-1px);
        }

    .variant-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        border-radius: 999px;
        border: 1px solid #ddd;
        background: #fff;
        padding: 6px 14px;
        font-size: 0.9rem;
        min-width: 72px;
        cursor: pointer;
        margin-right: 6px;
        margin-bottom: 6px;
        transition: all 0.15s ease-in-out;
        outline: none;
        color: #333;
        white-space: nowrap;
    }

        .variant-pill:hover {
            border-color: #2f80ed;
            color: #2f80ed;
            background: rgba(47, 128, 237, 0.03);
        }

        .variant-pill.active {
            border-color: #2f80ed;
            color: #2f80ed;
            background: rgba(47, 128, 237, 0.08);
            box-shadow: 0 0 0 1px rgba(47, 128, 237, 0.25);
            font-weight: 600;
        }

    .color-dot {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        border: 1px solid rgba(0,0,0,0.1);
        flex-shrink: 0;
    }

    .variant-color-btn.variant-pill {
        padding-inline: 14px;
    }

    .variant-pill:disabled {
        opacity: .45;
        cursor: not-allowed;
        border-color: #ddd !important;
        color: #999 !important;
        background: #f6f7f8 !important;
    }

        .variant-pill:disabled .color-dot {
            filter: grayscale(1);
            opacity: .6;
        }

    .rating-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: #e9ecef;
        color: #495057;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        flex: 0 0 38px;
    }

    .reply-box {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 10px;
        padding: 10px 12px;
        margin-top: 8px;
    }
</style>

<div class="container mt-5">

    <!-- Anti-forgery token for AJAX -->
    <form id="antiForgeryForm">
        @Html.AntiForgeryToken()
    </form>

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small bg-light rounded px-3 py-2 mb-3">
            <li class="breadcrumb-item">
                <a href="/" class="text-primary text-decoration-none">
                    <i class="bi bi-house"></i> Trang chủ
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="/Product" class="text-info text-decoration-none">Sản phẩm</a>
            </li>
            <li class="breadcrumb-item active text-secondary" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Hình ảnh sản phẩm chính + gallery -->
        <div class="col-md-6 mb-4">
            @if (media.Count > 0)
            {
                <div class="tgdd-gallery border rounded-3 p-2">
                    <div id="@galleryId" class="carousel slide" data-bs-ride="false">
                        <div class="carousel-inner">
                            @for (int i = 0; i < media.Count; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "")">
                                    <img src="@media[i]"
                                         class="d-block w-100 img-fluid rounded shadow-sm product-image"
                                         style="max-height:420px;object-fit:contain"
                                         alt="@Model.Name"
                                         @(i == 0 ? "id=\"mainImage\"" : "") />
                                </div>
                            }
                        </div>

                        <button class="carousel-control-prev" type="button"
                                data-bs-target="#@galleryId" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                        </button>
                        <button class="carousel-control-next" type="button"
                                data-bs-target="#@galleryId" data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                        </button>
                    </div>

                    <div class="tgdd-thumb-list d-flex flex-wrap mt-2">
                        @for (int i = 0; i < media.Count; i++)
                        {
                            <img src="@media[i]"
                                 class="tgdd-thumb @(i == 0 ? "active" : "")"
                                 data-bs-target="#@galleryId"
                                 data-bs-slide-to="@i"
                                 alt="thumb-@i" />
                        }
                    </div>
                </div>
            }
            else
            {
                <img src="@Model.ImageUrl" alt="@Model.Name"
                     class="img-fluid rounded shadow-sm product-image" id="mainImage">
            }
        </div>

        <!-- Thông tin sản phẩm -->
        <div class="col-md-6">
            <h2 class="mb-2 text-uppercase text-dark">@Model.Name</h2>
            @{
                var selectedVariantSku = ViewBag.SelectedVariant as ProductVariant;
            }
            <div class="mb-2 small text-muted">
                SKU: <b id="variantSku">@(!string.IsNullOrWhiteSpace(selectedVariantSku?.Sku) ? selectedVariantSku.Sku : "—")</b>
            </div>

            <!-- Rating + đã bán -->
            <div class="d-flex align-items-center mb-3 gap-3" style="font-size: 1.1rem;">
                <span class="fw-bold me-1" style="color: #ffb300;">@avg.ToString("0.0")</span>
                <i class="bi bi-star-fill text-warning"></i>
                <span class="text-muted ms-3">|</span>
                <span class="text-muted ms-3">@((int)(ViewBag.TotalRatings ?? 0)) đánh giá</span>
                <span class="text-muted ms-3">|</span>
                <span class="text-muted ms-3">Đã bán: @Model.SoldCount</span>
            </div>

            <div style="height: 12px;"></div>

            <!-- GIÁ + cập nhật theo biến thể -->
            <div class="mb-3">
                @if (hasVariants)
                {
                    if (Model.DiscountPercent > 0)
                    {
                        <span class="h5 text-muted text-decoration-line-through">
                            @Model.Price.ToString("N0", vi) VNĐ
                        </span>
                    }
                    <span class="h4 text-danger fw-bold ms-2" id="displayPrice">
                        @defaultVariantPrice.ToString("N0", vi) VNĐ
                    </span>
                }
                else
                {
                    @if (Model.DiscountPercent > 0)
                    {
                        <span class="h4 text-danger fw-bold">
                            <del>@Model.Price.ToString("N0", vi) VNĐ</del>
                        </span>
                        <span class="h4 text-danger fw-bold ms-2" id="displayPrice">
                            @Model.DiscountedPrice.ToString("N0", vi) VNĐ
                        </span>
                    }
                    else
                    {
                        <span class="h4 text-danger fw-bold" id="displayPrice">
                            @Model.Price.ToString("N0", vi) VNĐ
                        </span>
                    }
                }
            </div>

            @functions {
                public string GetColorHex(string color)
                {
                    if (string.IsNullOrWhiteSpace(color)) return "#cccccc";
                    color = color.ToLower();

                    if (color.Contains("đen")) return "#000000";
                    if (color.Contains("trắng")) return "#f8f8f8";
                    if (color.Contains("xanh lá")) return "#2ecc71";
                    if (color.Contains("xanh")) return "#3498db";
                    if (color.Contains("đỏ")) return "#e74c3c";
                    if (color.Contains("vàng") || color.Contains("gold")) return "#f1c40f";
                    if (color.Contains("tím")) return "#9b59b6";
                    if (color.Contains("titan")) return "#bdc3c7";
                    if (color.Contains("xám") || color.Contains("ghi") || color.Contains("gray")) return "#7f8c8d";

                    return "#cccccc";
                }
            }

            <!-- CHỌN PHIÊN BẢN -->
            @if (hasVariants)
            {
                <div class="mb-2">
                    <label class="form-label fw-semibold me-2">Dung lượng:</label>
                    @foreach (var cap in variants.Select(v => v.Capacity).Distinct())
                    {
                        <button type="button"
                                class="variant-pill variant-capacity-btn"
                                data-capacity="@cap">
                            @cap
                        </button>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold me-2">Màu sắc:</label>
                    @foreach (var color in variants.Select(v => v.Color).Distinct())
                    {
                        <button type="button"
                                class="variant-pill variant-color-btn"
                                data-color="@color">
                            <span class="color-dot" style="background-color:@GetColorHex(color)"></span>
                            <span>@color</span>
                        </button>
                    }
                </div>
            }

            <!-- Tồn kho -->
            <div class="mb-2">
                <span class="fw-semibold">Tình trạng: </span>
                <span id="stockBadge" class="badge"></span>
                <span id="stockText" class="ms-2 small text-muted"></span>
            </div>

            <!-- Giao hàng -->
            <div class="border rounded-3 p-3 mb-3" style="background:#fcfcfd;">
                <div class="fw-semibold mb-2">
                    <i class="bi bi-truck me-1"></i> Giao đến
                </div>

                <div class="row g-2">
                    <div class="col-md-6">
                        <select class="form-select" id="shipProvince">
                            <option value="">-- Chọn Tỉnh/TP --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <select class="form-select" id="shipDistrict" disabled>
                            <option value="">-- Toàn tỉnh --</option>
                        </select>
                    </div>
                </div>

                <div class="mt-2 small">
                    <div>Phí ship: <b id="shipFee">—</b></div>
                    <div>Giao dự kiến: <b id="shipEta">—</b></div>
                </div>
            </div>

            <!-- PROMO -->
            <div class="border rounded-3 p-3 mb-3" style="background:#fff7ed;">
                <div class="fw-semibold mb-2">
                    <i class="bi bi-gift me-1"></i> Khuyến mãi / Ưu đãi
                </div>

                <ul class="mb-2 small">
                    <li>Mã giảm giá / quà tặng kèm (tuỳ đợt).</li>
                    <li>Ưu đãi ngân hàng / hoàn tiền (nếu áp dụng).</li>
                    <li class="text-muted">* Điều kiện áp dụng theo thời gian, số lượt, và biến thể.</li>
                </ul>

                @if (promoCoupons.Any())
                {
                    <div class="list-group">
                        @foreach (var c in promoCoupons)
                        {
                            var remain = c.Quantity - c.CurrentUsage;
                            <div class="list-group-item d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-semibold">
                                        <span class="badge bg-danger me-2">@c.Code</span>
                                        @if (c.DiscountPercent.HasValue && c.DiscountPercent.Value > 0)
                                        {
                                            <span>Giảm @c.DiscountPercent% </span>
                                        }
                                        else if (c.DiscountAmount.HasValue && c.DiscountAmount.Value > 0)
                                        {
                                            <span>Giảm @c.DiscountAmount.Value.ToString("N0", vi) VNĐ</span>
                                        }
                                    </div>

                                    <div class="small text-muted">
                                        Đơn tối thiểu: @c.MinOrderValue.ToString("N0", vi) VNĐ •
                                        Còn: @(remain > 0 ? remain.ToString() : "0") lượt •
                                        @c.StartDate.ToString("dd/MM") - @c.EndDate.ToString("dd/MM")
                                    </div>
                                </div>

                                <button type="button"
                                        class="btn btn-sm btn-outline-dark copy-coupon-btn"
                                        data-code="@c.Code">
                                    Copy
                                </button>
                            </div>
                        }
                    </div>

                    <div class="small text-muted mt-2">
                        * Bạn áp mã tại trang giỏ hàng/checkout.
                    </div>
                }
                else
                {
                    <div class="small text-muted">
                        Hiện chưa có mã hiển thị ở trang sản phẩm.
                    </div>
                }
            </div>

            <!-- Trả góp -->
            <div class="border rounded-3 p-3 mb-3" style="background:#f8fafc;">
                <div class="fw-semibold mb-2">
                    <i class="bi bi-credit-card-2-front me-1"></i> Trả góp (ước tính)
                </div>

                <div class="row g-2 align-items-end">
                    <div class="col-6">
                        <label class="form-label small mb-1">Kỳ hạn</label>
                        <select id="installmentMonths" class="form-select form-select-sm">
                            <option value="3">3 tháng</option>
                            <option value="6" selected>6 tháng</option>
                            <option value="12">12 tháng</option>
                        </select>
                    </div>

                    <div class="col-6">
                        <label class="form-label small mb-1">Trả trước (VNĐ)</label>
                        <input id="installmentDown" class="form-control form-control-sm" value="0" />
                    </div>
                </div>

                <div class="mt-2 small">
                    <div>Giá đang chọn: <b id="installmentPriceText">—</b></div>
                    <div>Mỗi tháng (ước tính): <b id="installmentPerMonth">—</b></div>
                    <div class="text-muted">* Bảng tính tham khảo, thực tế tuỳ ngân hàng/cổng trả góp.</div>
                </div>
            </div>

            <!-- Số lượng -->
            <div class="mb-4">
                <label for="quantity" class="form-label">Số lượng:</label>
                <input type="number" class="form-control" id="quantity" value="1" min="1" style="width: 120px;">
            </div>

            <!-- Nút mua / yêu thích / so sánh -->
            <div class="d-flex flex-wrap gap-2">
                @if (User.Identity.IsAuthenticated && !User.IsInRole("Admin") && !User.IsInRole("Employer"))
                {
                    <form id="addToCartForm" asp-controller="ShoppingCart" asp-action="AddToCart" method="post">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <input type="hidden" name="quantity" id="cartQuantity" value="1" />
                        <input type="hidden" name="variantId" id="SelectedVariantId" />

                        <button class="btn btn-cart px-4 py-2 shadow" type="submit" id="addToCartButton">
                            <i class="bi bi-cart-fill me-2"></i> Thêm vào giỏ hàng
                        </button>
                    </form>

                    <form id="buyNowForm" asp-controller="ShoppingCart" asp-action="BuyNow" method="post">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <input type="hidden" name="quantity" id="buyNowQuantity" value="1" />
                        <input type="hidden" name="variantId" id="BuyNowVariantId" />
                        <button class="btn btn-danger px-4 py-2 shadow" type="submit" id="buyNowButton">
                            <i class="bi bi-lightning-charge-fill me-2"></i> Mua ngay
                        </button>
                    </form>
                }
                else if (User.IsInRole("Admin") || User.IsInRole("Employer"))
                {
                    <button class="btn btn-secondary px-4 py-2 shadow" disabled>
                        <i class="bi bi-cart-fill me-2"></i> Thêm vào giỏ hàng
                    </button>
                    <button class="btn btn-secondary px-4 py-2 shadow" disabled>
                        <i class="bi bi-lightning-charge-fill me-2"></i> Mua ngay
                    </button>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-secondary px-4 py-2 shadow">
                        <i class="bi bi-cart-fill me-2"></i> Thêm vào giỏ hàng
                    </a>
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-danger px-4 py-2 shadow">
                        <i class="bi bi-lightning-charge-fill me-2"></i> Mua ngay
                    </a>
                }

                @if (User.Identity.IsAuthenticated)
                {
                    <form id="addToWishlistForm" asp-controller="Wishlist" asp-action="AddToWishlist" method="post">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <input type="hidden" name="variantId" id="WishlistVariantId" />

                        <button type="submit" class="btn btn-heart px-4 py-2 shadow" id="addToWishlistButton">
                            <i class="bi bi-heart me-2"></i> Yêu thích
                        </button>
                    </form>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-heart px-4 py-2 shadow">
                        <i class="bi bi-heart me-2"></i> Yêu thích
                    </a>
                }

                <a href="javascript:void(0)" id="btnCompare" class="btn btn-outline-primary px-4 py-2 shadow">
                    So sánh
                </a>
            </div>

            <div class="mt-4">
                <h5 class="mb-3">Thông tin sản phẩm:</h5>
                <ul class="list-unstyled">
                    <li><strong>Danh mục:</strong> @Model.Category?.Name</li>
                    @if (Model.SubCategory != null)
                    {
                        <li><strong>Hãng:</strong> @Model.SubCategory?.Name</li>
                    }
                    <li><strong>Mã sản phẩm:</strong> @Model.Id</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- MÔ TẢ -->
    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="product-description-box p-4">
                    <h5 class="mb-3">Mô tả sản phẩm</h5>
                    @Html.Raw(Model.Description)
                </div>
            </div>
        </div>
    }

    <!-- CAM KẾT -->
    @if (!string.IsNullOrWhiteSpace(Model.ServiceCommitment))
    {
        <div class="mt-4">
            <h5 class="mb-3 fw-semibold">Cam kết dịch vụ</h5>
            <div class="row g-3">
                @foreach (var line in Model.ServiceCommitment.Split('\n'))
                {
                    if (!string.IsNullOrWhiteSpace(line))
                    {
                        <div class="col-md-6 d-flex align-items-start">
                            <div class="me-2">
                                <i class="bi bi-patch-check-fill" style="color:#3b82f6; font-size:20px;"></i>
                            </div>
                            <div class="text-dark" style="line-height:1.4;">
                                @line.Trim()
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }

    <!-- THÔNG SỐ KỸ THUẬT -->
    @if (Model.Specs != null)
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="product-description-box p-4">
                    <h5 class="mb-3">Thông số kỹ thuật</h5>

                    <div class="accordion" id="specsAccordion">
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingCfg">
                                <button class="accordion-button" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#collapseCfg"
                                        aria-expanded="true" aria-controls="collapseCfg">
                                    Cấu hình & Bộ nhớ
                                </button>
                            </h2>
                            <div id="collapseCfg" class="accordion-collapse collapse show" aria-labelledby="headingCfg">
                                <div class="accordion-body p-0">
                                    <table class="table table-sm mb-0">
                                        <tr><th style="width:230px">Hệ điều hành</th><td>@Model.Specs.Os</td></tr>
                                        <tr><th>Chip xử lý (CPU)</th><td>@Model.Specs.Cpu</td></tr>
                                        <tr><th>Tốc độ CPU</th><td>@Model.Specs.CpuSpeed</td></tr>
                                        <tr><th>Chip đồ họa (GPU)</th><td>@Model.Specs.Gpu</td></tr>
                                        <tr><th>RAM</th><td>@Model.Specs.Ram</td></tr>
                                        <tr>
                                            <th>Dung lượng lưu trữ</th>
                                            <td id="specStorage">
                                                @(hasVariants && variants.Any() ? variants.First().Storage : Model.Specs.Storage)
                                            </td>
                                        </tr>
                                        <tr>
                                            <th>Dung lượng còn lại (khả dụng)</th>
                                            <td id="specStorageAvailable">
                                                @(hasVariants && variants.Any()
                                                                                            ? (variants.First().StorageAvailable ?? Model.Specs.StorageAvailable)
                                                                                            : Model.Specs.StorageAvailable)
                                        </td>
                                    </tr>
                                    <tr><th>Danh bạ</th><td>@Model.Specs.ContactLimit</td></tr>
                                </table>
                            </div>
                        </div>
                    </div>

                        <!-- (các accordion item khác giữ nguyên giống file bạn) -->
                        <!-- Camera & Màn hình -->
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingCam">
                                <button class="accordion-button collapsed" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#collapseCam"
                                        aria-expanded="false" aria-controls="collapseCam">
                                    Camera & Màn hình
                                </button>
                            </h2>
                            <div id="collapseCam" class="accordion-collapse collapse" aria-labelledby="headingCam">
                                <div class="accordion-body p-0">
                                    <table class="table table-sm mb-0">
                                        <tr><th style="width:230px">Độ phân giải camera sau</th><td>@Model.Specs.RearCameraResolution</td></tr>
                                        <tr><th>Độ phân giải camera trước</th><td>@Model.Specs.FrontCameraResolution</td></tr>
                                        <tr><th>Quay video (sau)</th><td>@Model.Specs.RearVideoModes</td></tr>
                                        <tr><th>Quay video (trước)</th><td>@Model.Specs.FrontVideoModes</td></tr>
                                        <tr><th>Tính năng camera sau</th><td>@Model.Specs.RearCameraFeatures</td></tr>
                                        <tr><th>Tính năng camera trước</th><td>@Model.Specs.FrontCameraFeatures</td></tr>
                                        <tr><th>Công nghệ màn hình</th><td>@Model.Specs.ScreenTech</td></tr>
                                        <tr><th>Độ phân giải màn hình</th><td>@Model.Specs.ScreenResolution</td></tr>
                                        <tr><th>Kích thước & tần số quét</th><td>@Model.Specs.ScreenSize</td></tr>
                                        <tr><th>Độ sáng tối đa</th><td>@Model.Specs.ScreenBrightness</td></tr>
                                        <tr><th>Mặt kính cảm ứng</th><td>@Model.Specs.ScreenGlass</td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Pin & Sạc -->
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingPin">
                                <button class="accordion-button collapsed" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#collapsePin"
                                        aria-expanded="false" aria-controls="collapsePin">
                                    Pin & Sạc
                                </button>
                            </h2>
                            <div id="collapsePin" class="accordion-collapse collapse" aria-labelledby="headingPin">
                                <div class="accordion-body p-0">
                                    <table class="table table-sm mb-0">
                                        <tr><th style="width:230px">Thời lượng pin</th><td>@Model.Specs.BatteryUsageTime</td></tr>
                                        <tr><th>Loại pin</th><td>@Model.Specs.BatteryType</td></tr>
                                        <tr><th>Công suất sạc tối đa</th><td>@Model.Specs.MaxChargePower</td></tr>
                                        <tr><th>Công nghệ pin</th><td>@Model.Specs.BatteryTech</td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Tiện ích -->
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingTienIch">
                                <button class="accordion-button collapsed" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#collapseTienIch"
                                        aria-expanded="false" aria-controls="collapseTienIch">
                                    Tiện ích
                                </button>
                            </h2>
                            <div id="collapseTienIch" class="accordion-collapse collapse" aria-labelledby="headingTienIch">
                                <div class="accordion-body p-0">
                                    <table class="table table-sm mb-0">
                                        <tr><th style="width:230px">Bảo mật</th><td>@Model.Specs.Security</td></tr>
                                        <tr><th>Kháng nước bụi</th><td>@Model.Specs.WaterDustResist</td></tr>
                                        <tr><th>Tính năng đặc biệt</th><td>@Model.Specs.SpecialFeatures</td></tr>
                                        <tr><th>Ghi âm</th><td>@Model.Specs.Recorder</td></tr>
                                        <tr><th>Định dạng phim</th><td>@Model.Specs.VideoFormats</td></tr>
                                        <tr><th>Định dạng nhạc</th><td>@Model.Specs.AudioFormats</td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Kết nối -->
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingKetNoi">
                                <button class="accordion-button collapsed" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#collapseKetNoi"
                                        aria-expanded="false" aria-controls="collapseKetNoi">
                                    Kết nối
                                </button>
                            </h2>
                            <div id="collapseKetNoi" class="accordion-collapse collapse" aria-labelledby="headingKetNoi">
                                <div class="accordion-body p-0">
                                    <table class="table table-sm mb-0">
                                        <tr><th style="width:230px">Mạng di động</th><td>@Model.Specs.MobileNetwork</td></tr>
                                        <tr><th>SIM</th><td>@Model.Specs.Sim</td></tr>
                                        <tr><th>WiFi</th><td>@Model.Specs.Wifi</td></tr>
                                        <tr><th>GPS</th><td>@Model.Specs.Gps</td></tr>
                                        <tr><th>Bluetooth</th><td>@Model.Specs.Bluetooth</td></tr>
                                        <tr><th>Cổng sạc</th><td>@Model.Specs.ChargingPort</td></tr>
                                        <tr><th>Jack tai nghe</th><td>@Model.Specs.HeadphoneJack</td></tr>
                                        <tr><th>Kết nối khác</th><td>@Model.Specs.OtherConnections</td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Thiết kế -->
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingDesign">
                                <button class="accordion-button collapsed" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#collapseDesign"
                                        aria-expanded="false" aria-controls="collapseDesign">
                                    Thiết kế & Chất liệu
                                </button>
                            </h2>
                            <div id="collapseDesign" class="accordion-collapse collapse" aria-labelledby="headingDesign">
                                <div class="accordion-body p-0">
                                    <table class="table table-sm mb-0">
                                        <tr><th style="width:230px">Thiết kế</th><td>@Model.Specs.DesignStyle</td></tr>
                                        <tr><th>Chất liệu</th><td>@Model.Specs.Material</td></tr>
                                        <tr><th>Kích thước</th><td>@Model.Specs.Dimensions</td></tr>
                                        <tr><th>Khối lượng</th><td>@Model.Specs.Weight</td></tr>
                                        <tr><th>Thời điểm ra mắt</th><td>@Model.Specs.ReleaseTime</td></tr>
                                        <tr><th>Hãng</th><td>@Model.Specs.BrandInfo</td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                    </div><!-- /accordion -->
                </div>
            </div>
        </div>
        }

    @{
        var faqs = ViewBag.Faqs as List<WebBanDienThoai.Models.ProductFaq> ?? new();
        var qas = ViewBag.QAs as List<WebBanDienThoai.Models.ProductQuestion> ?? new();
    }

    <!-- =========================
         FAQ + Q&A
         ========================= -->
    <div class="mt-5">
        <h4 class="mb-3">Hỏi & Đáp / FAQ</h4>

        <!-- FAQ -->
        @if (faqs.Any())
        {
            <div class="mb-4">
                <h5 class="mb-2">Câu hỏi thường gặp</h5>

                <div class="accordion" id="faqAccordion">
                    @for (int i = 0; i < faqs.Count; i++)
                    {
                        var f = faqs[i];
                        var cid = $"faq_{f.Id}";
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="h_@cid">
                                <button class="accordion-button @(i == 0 ? "" : "collapsed")" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#c_@cid"
                                        aria-expanded="@(i == 0 ? "true" : "false")" aria-controls="c_@cid">
                                    @f.Question
                                </button>
                            </h2>
                            <div id="c_@cid" class="accordion-collapse collapse @(i == 0 ? "show" : "")" aria-labelledby="h_@cid">
                                <div class="accordion-body">
                                    @Html.Raw(f.Answer.Replace("\n", "<br/>"))
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Q&A -->
        <div class="border rounded-3 p-3" style="background:#fff;">
            <h5 class="mb-3">Hỏi đáp về sản phẩm</h5>

            @{
                bool isStaff = User.IsInRole("Admin") || User.IsInRole("Employer");
            }

            @* Khách (không phải staff) mới được hỏi *@
            @if (User.Identity.IsAuthenticated && !isStaff)
            {
                <form asp-action="AskQuestion" asp-controller="Product" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <div class="input-group">
                        <input name="question" class="form-control" maxlength="800"
                               placeholder="Hỏi về cấu hình, bảo hành, tương thích, phụ kiện trong hộp..." />
                        <button class="btn btn-primary" type="submit">Gửi câu hỏi</button>
                    </div>
                    <div class="small text-muted mt-1">* Tối đa 800 ký tự. Không nhập thông tin nhạy cảm.</div>
                </form>
            }
            else if (!User.Identity.IsAuthenticated)
            {
                <div class="alert alert-warning mb-3">
                    Bạn cần <a href="/Identity/Account/Login">đăng nhập</a> để đặt câu hỏi.
                </div>
            }
            else if (isStaff)
            {
                <div class="alert alert-info mb-3">
                    Tài khoản nhân viên không đặt câu hỏi như khách hàng. Bạn có thể phản hồi và duyệt/ẩn câu hỏi bên dưới.
                </div>
            }

            @if (qas == null || !qas.Any())
            {
                <div class="text-muted">Chưa có câu hỏi nào.</div>
            }
            else
            {
                @foreach (var q in qas)
                {
                    var qName = q.User?.FullName ?? q.User?.UserName ?? "Người dùng";
                    var isApproved = q.IsApproved;

                    <div class="border-top pt-3 mt-3">
                        <div class="d-flex justify-content-between flex-wrap gap-2">
                            <div>
                                <span class="fw-semibold">@qName</span>
                                <span class="text-muted small ms-2">@q.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>

                                @if (isStaff)
                                {
                                    if (isApproved)
                                    {
                                        <span class="badge bg-success-subtle text-success border ms-2">Đã duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning border ms-2">Chờ duyệt</span>
                                    }
                                }
                            </div>

                            @* Staff tools: Duyệt/Ẩn + Xóa *@
                            @if (isStaff)
                            {
                                <div class="d-flex gap-2">
                                    @if (isApproved)
                                    {
                                        <form asp-action="HideQuestion" asp-controller="Product" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="questionId" value="@q.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">Ẩn</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="ApproveQuestion" asp-controller="Product" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="questionId" value="@q.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-success">Duyệt</button>
                                        </form>
                                    }

                                    @* (Tuỳ chọn) nếu bạn đã thêm action DeleteQuestion trong controller *@
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <form asp-action="DeleteQuestion" asp-controller="Product" method="post" class="d-inline"
                                              onsubmit="return confirm('Xóa câu hỏi này và toàn bộ phản hồi?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="questionId" value="@q.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                        </form>
                                    }
                                </div>
                            }
                        </div>

                        <div class="mt-1">@q.Question</div>

                        @* Replies *@
                        @if (q.Replies != null && q.Replies.Any())
                        {
                            <div class="ms-3 mt-2">
                                @foreach (var rep in q.Replies.OrderBy(r => r.CreatedAt))
                                {
                                    var repName = rep.User?.FullName ?? rep.User?.UserName ?? "Admin/Staff";
                                    var editId = $"editReply_{rep.Id}";

                                    <div class="reply-box border rounded-3 p-2 mt-2" style="background:#fafafa;">
                                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="fw-semibold">@repName</span>
                                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Trả lời</span>
                                                @if (rep.UpdatedAt != null)
                                                {
                                                    <span class="badge bg-secondary-subtle text-secondary border">Đã sửa</span>
                                                }
                                            </div>

                                            <div class="d-flex align-items-center gap-2">
                                                <span class="text-muted small">@rep.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>

                                                @if (isStaff)
                                                {
                                                    <button class="btn btn-sm btn-outline-secondary"
                                                            type="button" data-bs-toggle="collapse" data-bs-target="#@editId">
                                                        Sửa
                                                    </button>

                                                    <form asp-action="DeleteQuestionReply" asp-controller="Product" method="post" class="d-inline"
                                                          onsubmit="return confirm('Xóa phản hồi này?');">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="replyId" value="@rep.Id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                                    </form>
                                                }
                                            </div>
                                        </div>

                                        <div class="mt-1 word-break-all">@rep.Content</div>

                                        @if (isStaff)
                                        {
                                            <div class="collapse mt-2" id="@editId">
                                                <form asp-action="EditQuestionReply" asp-controller="Product" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="replyId" value="@rep.Id" />
                                                    <textarea name="content" class="form-control" rows="2" required>@rep.Content</textarea>
                                                    <div class="mt-2 d-flex gap-2">
                                                        <button class="btn btn-sm btn-primary" type="submit">Lưu</button>
                                                        <button class="btn btn-sm btn-outline-secondary" type="button"
                                                                data-bs-toggle="collapse" data-bs-target="#@editId">
                                                            Hủy
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }

                        @* Staff reply form *@
                        @if (isStaff)
                        {
                            <form asp-action="ReplyQuestion" asp-controller="Product" method="post" class="mt-2 ms-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="questionId" value="@q.Id" />
                                <div class="input-group input-group-sm">
                                    <textarea name="content" class="form-control" rows="2" required
                                  placeholder="Phản hồi câu hỏi này..."></textarea>
                                    <button class="btn btn-outline-secondary" type="submit">Trả lời</button>
                                </div>
                                <div class="small text-muted mt-1">
                                    * Trả lời sẽ tự động duyệt câu hỏi (nếu đang chờ duyệt).
                                </div>
                            </form>
                        }
                    </div>
                }
            }
        </div>

    <!-- =========================
         REVIEW SECTION (UPDATED)
         ========================= -->
    <div class="mt-5">
        <h4 class="mb-3">Đánh giá sản phẩm</h4>

        <div class="mb-3">
            <span class="fw-bold fs-5">@avg.ToString("0.0")</span>
            @for (int i = 1; i <= 5; i++)
            {
                if (i <= fullStars)
                {
                    <i class="bi bi-star-fill text-warning"></i>
                }
                else if (i == fullStars + 1 && hasHalf)
                {

                    <i class="bi bi-star-half text-warning"></i>
                }
                else
                {

                    <i class="bi bi-star text-warning"></i>
                }
            }
            <span class="ms-2 text-muted">(@((int)(ViewBag.TotalRatings ?? 0)) đánh giá)</span>
        </div>

        <!-- Filter / Sort -->
        <form asp-action="Display" asp-route-id="@Model.Id" method="get" class="d-flex flex-wrap gap-2 align-items-center mb-3">
            <input type="hidden" name="variantId" value="@(ViewBag.SelectedVariant?.Id)" />

            <select name="star" class="form-select" style="width:150px">
                <option value="">Tất cả sao</option>
                @for (int s = 5; s >= 1; s--)
                {
                    <option value="@s" selected="@(filterStar.HasValue && filterStar.Value == s)">
                        @s sao
                    </option>
                }
            </select>

            <label class="form-check m-0">
                <input class="form-check-input" type="checkbox" name="hasImages" value="true" checked="@(filterHasImages)" />
                <span class="form-check-label">Có ảnh</span>
            </label>

            <label class="form-check m-0">
                <input class="form-check-input" type="checkbox" name="verifiedOnly" value="true" checked="@(filterVerifiedOnly)" />
                <span class="form-check-label">Đã mua</span>
            </label>

            <select name="sort" class="form-select" style="width:180px">
                <option value="new" selected="@(filterSort == "new")">Mới nhất</option>
                <option value="helpful" selected="@(filterSort == "helpful")">Hữu ích nhất</option>
                <option value="high" selected="@(filterSort == "high")">Điểm cao → thấp</option>
                <option value="low" selected="@(filterSort == "low")">Điểm thấp → cao</option>
            </select>

            <button class="btn btn-outline-primary" type="submit">Lọc</button>
        </form>

        <!-- Form đánh giá (chỉ khi đã mua) -->
        @if (User.Identity.IsAuthenticated)
        {
            var myRating = ViewBag.MyRating as WebBanDienThoai.Models.ProductRating;

            if (!canReview)
            {
                <div class="alert alert-warning">
                    Bạn cần mua và nhận hàng thành công mới được đánh giá sản phẩm này.
                </div>
            }
            else
            {
                if (myRating != null)
                {
                    <div class="alert alert-info mb-2">Bạn đã đánh giá. Có thể sửa lại đánh giá!</div>
                }

                <form asp-action="SubmitRating" method="post" enctype="multipart/form-data" class="mb-4">
                    <input type="hidden" name="productId" value="@Model.Id" />

                    <div class="mb-2">
                        <label class="form-label">Số sao:</label>
                        <div class="text-start">
                            <div id="star-group" class="rating-select d-flex flex-row-reverse" style="font-size:2rem; width:fit-content;">
                                @for (int i = 5; i >= 1; i--)
                                {
                                    <input type="radio" name="stars" id="star-@i" value="@i"
                                           style="display:none;"
                                           @(myRating != null && myRating.Stars == i ? "checked" : "") required />
                                    <label for="star-@i" class="star-label" style="cursor:pointer; margin:0 2px;">
                                        <i class="bi bi-star-fill"></i>
                                    </label>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Nhận xét:</label>
                        <textarea name="comment" class="form-control" rows="2">@myRating?.Comment</textarea>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Ảnh đánh giá (tối đa 5 ảnh):</label>
                        <input type="file" name="images" multiple accept="image/*" class="form-control" />
                        <div class="small text-muted">* jpg/png/webp, mỗi ảnh ≤ 2MB</div>
                    </div>

                    <button type="submit" class="btn btn-primary">Gửi đánh giá</button>
                </form>
            }
        }
        else
        {
            <div class="alert alert-warning">
                Bạn cần <a href="/Identity/Account/Login">đăng nhập</a> để đánh giá sản phẩm này.
            </div>
        }

        <!-- Stats box -->
        <div class="row bg-white p-4 rounded-3 shadow-sm mb-4 border align-items-center">
            <div class="col-md-4 text-center border-end">
                <h1 class="display-3 fw-bold text-primary mb-0">@avg.ToString("0.0")</h1>
                <div class="text-warning fs-4 mb-2">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi @(i <= Math.Round(avg) ? "bi-star-fill" : "bi-star")"></i>
                    }
                </div>
                <p class="text-muted">@((int)(ViewBag.TotalRatings ?? 0)) đánh giá & @Model.SoldCount lượt bán</p>
            </div>
            <div class="col-md-8 ps-md-5">
                @{
                    int sLevel = 5;
                    int total = (int)(ViewBag.TotalRatings ?? 0);
                }
                @foreach (var count in starDistribution)
                {
                    <div class="d-flex align-items-center mb-1">
                        <span style="width: 50px;" class="small fw-bold">@sLevel sao</span>
                        <div class="progress flex-grow-1 mx-2" style="height: 8px;">
                            <div class="progress-bar bg-warning" style="width: @(total > 0 ? (count * 100 / total) : 0)%"></div>
                        </div>
                        <span class="text-muted small" style="width: 30px;">@count</span>
                    </div>
                    sLevel--;
                }
            </div>
        </div>

        <!-- Danh sách đánh giá -->
        <div>
            @if (!ratings.Any(r => r.IsApproved || (User.Identity.IsAuthenticated && r.UserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)))
            {
                <div class="text-muted">Chưa có đánh giá nào theo bộ lọc hiện tại.</div>
            }
            else
            {
                @foreach (var r in ratings)
                {
                    // ✨ CHỨC NĂNG 8: CHỈ HIỂN THỊ NẾU ĐÃ DUYỆT HOẶC CHÍNH CHỦ TỰ XEM BÀI VIẾT CỦA MÌNH
                    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                    if (r.IsApproved || (User.Identity.IsAuthenticated && r.UserId == currentUserId))
                    {
                        var displayName = r.User?.FullName ?? r.User?.UserName ?? "Người dùng";
                        var firstChar = !string.IsNullOrWhiteSpace(displayName) ? displayName.Trim()[0].ToString().ToUpper() : "U";
                        var isEdited = r.UpdatedAt.HasValue;

                        <div class="rating-item border-bottom pb-3 mb-3" style="@(!r.IsApproved ? "background-color: #fff3cd; padding: 10px; border-radius: 8px;" : "")">
                            <div class="d-flex align-items-start gap-2">
                                <div class="rating-avatar">@firstChar</div>

                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center flex-wrap gap-2">
                                        <span class="fw-bold text-dark">@displayName</span>

                                        @if (r.IsVerifiedPurchase)
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1 small" style="font-size: 11px; border-radius: 4px;">
                                                <i class="bi bi-patch-check-fill me-1"></i> Đã mua tại MobiStore
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-secondary border px-2 py-1 small" style="font-size: 11px; border-radius: 4px;">
                                                <i class="bi bi-info-circle me-1"></i> Khách vãng lai
                                            </span>
                                        }

                                        @if (!r.IsApproved)
                                        {
                                            <span class="badge bg-warning text-dark border border-warning px-2 py-1 small" style="font-size: 11px; border-radius: 4px;">
                                                <i class="bi bi-hourglass-split me-1"></i> Đang chờ duyệt nội dung
                                            </span>
                                        }

                                        <span class="ms-1">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi @(i <= r.Stars ? "bi-star-fill text-warning" : "bi-star text-warning")"></i>
                                            }
                                        </span>

                                        <span class="text-muted small">
                                            @r.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                            @if (isEdited)
                                            {
                                                <span class="ms-1">(đã sửa)</span>
                                            }
                                        </span>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(r.Comment))
                                    {
                                        <div class="mt-1 word-break-all">@r.Comment</div>
                                    }
                                    else
                                    {
                                        <div class="mt-1 text-muted fst-italic small">Không có nhận xét.</div>
                                    }

                                    @if (r.Images != null && r.Images.Any())
                                    {
                                        <div class="d-flex gap-2 flex-wrap mt-2">
                                            @foreach (var img in r.Images)
                                            {
                                                <a href="@img.Url" target="_blank">
                                                    <img src="@img.Url" style="width:80px;height:80px;object-fit:cover;border-radius:8px;border:1px solid #eee" />
                                                </a>
                                            }
                                        </div>
                                    }

                                    <div class="d-flex gap-2 mt-2">
                                        <button type="button" class="btn btn-sm btn-outline-success" onclick="voteRating(@r.Id,true)">
                                            👍 <span id="like-@r.Id">@r.LikeCount</span>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="voteRating(@r.Id,false)">
                                            👎 <span id="dislike-@r.Id">@r.DislikeCount</span>
                                        </button>

                                        @if (User.Identity.IsAuthenticated)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="reportRating(@r.Id)">
                                                Báo cáo
                                            </button>
                                        }
                                    </div>

                                    @if (r.Replies != null && r.Replies.Any())
                                    {
                                        <div class="ms-3 mt-2">
                                            @foreach (var reply in r.Replies)
                                            {
                                                var replyName = reply.User?.FullName ?? reply.User?.UserName ?? "Admin/Staff";
                                                <div class="reply-box">
                                                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                                        <div class="d-flex align-items-center gap-2">
                                                            <span class="fw-semibold">@replyName</span>
                                                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Phản hồi</span>
                                                        </div>
                                                        <span class="text-muted small">@reply.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                                    </div>
                                                    <div class="mt-1 word-break-all">@reply.Content</div>
                                                </div>
                                            }
                                        </div>
                                    }

                                    @if (User.IsInRole("Admin") || User.IsInRole("Employer"))
                                    {
                                        <form asp-action="ReplyRating" method="post" class="mt-2 ms-3">
                                            <input type="hidden" name="productRatingId" value="@r.Id" />
                                            <div class="input-group input-group-sm">
                                                <textarea name="content" class="form-control" rows="2"
                                                          placeholder="Phản hồi đánh giá này..." required></textarea>
                                                <button class="btn btn-outline-secondary" type="submit">Phản hồi</button>
                                            </div>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            }
        </div>

        <!-- Paging -->
        @if (ratingTotalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination">
                    @for (int p = 1; p <= ratingTotalPages; p++)
                    {
                        <li class="page-item @(p == ratingPage ? "active" : "")">
                            <a class="page-link"
                               asp-action="Display" asp-route-id="@Model.Id"
                               asp-route-page="@p"
                               asp-route-star="@filterStar"
                               asp-route-hasImages="@filterHasImages"
                               asp-route-verifiedOnly="@filterVerifiedOnly"
                               asp-route-sort="@filterSort">
                                @p
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>

    @* Viewed + Related *@
    @{
        var viewedProducts = ViewBag.ViewedProducts as List<WebBanDienThoai.Models.ProductWithSoldCount>;
        var relatedProducts = ViewBag.RelatedProducts as List<WebBanDienThoai.Models.ProductWithSoldCount>;
    }

    @if (viewedProducts != null && viewedProducts.Any())
    {
        <div class="mt-5">
            <h4 class="mb-3">Sản phẩm đã xem</h4>
            <div class="row g-3">
                @foreach (var p in viewedProducts)
                {
                    <div class="col-6 col-md-3">
                        @await Html.PartialAsync("_ProductCard", p)
                    </div>
                }
            </div>
        </div>
    }

    @if (relatedProducts != null && relatedProducts.Any())
    {
        <div class="mt-5">
            <h4 class="mb-3">Sản phẩm liên quan</h4>
            <div class="row g-3">
                @foreach (var p in relatedProducts)
                {
                    <div class="col-6 col-md-3">
                        @await Html.PartialAsync("_ProductCard", p)
                    </div>
                }
            </div>
        </div>
    }

    <!-- Popup -->
    <div id="custom-popup-success" class="custom-popup" style="display:none;">
        <div class="custom-popup-content">
            <div class="custom-popup-icon">
                <i class="bi bi-check2-circle"></i>
            </div>
            <span id="custom-popup-message"></span>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {

      function showPopup(message, time = 1600) {
        const popup = document.getElementById('custom-popup-success');
        const msg = document.getElementById('custom-popup-message');
        if (!popup || !msg) return;
        msg.innerHTML = message;
        popup.style.display = 'flex';
        setTimeout(() => { popup.style.display = 'none'; }, time);
      }

      function updateCartCount() {
        fetch('/ShoppingCart/GetCartCount')
          .then(res => res.json())
          .then(data => {
            const el = document.getElementById('cartCount');
            if (el) el.innerText = data.count;
          });
      }

      function parseVndFromText(text) {
        if (!text) return 0;
        const digits = String(text).replace(/[^\d]/g, '');
        return digits ? Number(digits) : 0;
      }
      function formatVnd(n) {
        return Number(n || 0).toLocaleString('vi-VN') + ' VNĐ';
      }

      // Anti-forgery token for ajax
      const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value;

      // Copy coupon
      document.querySelectorAll('.copy-coupon-btn').forEach(btn => {
        btn.addEventListener('click', async function () {
          const code = this.getAttribute('data-code');
          try {
            await navigator.clipboard.writeText(code);
            showPopup(`Đã copy mã: <b>${code}</b>`);
          } catch {
            alert('Không copy được, bạn copy thủ công: ' + code);
          }
        });
      });

      // Gallery thumbs sync
      const carousels = document.querySelectorAll('[id^="productGallery_"]');
      carousels.forEach(function (carouselEl) {
        const thumbs = carouselEl.parentElement.querySelectorAll('.tgdd-thumb');
        carouselEl.addEventListener('slide.bs.carousel', function (e) {
          const index = e.to;
          thumbs.forEach(function (t, i) { t.classList.toggle('active', i === index); });
        });
        thumbs.forEach(function (thumb) {
          thumb.addEventListener('click', function () {
            thumbs.forEach(t => t.classList.remove('active'));
            this.classList.add('active');
          });
        });
      });

      // Installment calculator
      function updateInstallment() {
        const priceEl = document.getElementById('displayPrice');
        const monthsEl = document.getElementById('installmentMonths');
        const downEl = document.getElementById('installmentDown');

        const price = parseVndFromText(priceEl?.textContent || "");
        const months = Number(monthsEl?.value || 6);

        let down = parseVndFromText(downEl?.value || "0");
        if (down < 0) down = 0;
        if (down > price) down = price;

        const remain = price - down;
        const perMonth = months > 0 ? Math.round(remain / months) : 0;

        document.getElementById('installmentPriceText').textContent = formatVnd(price);
        document.getElementById('installmentPerMonth').textContent = formatVnd(perMonth);
      }
      document.getElementById('installmentMonths')?.addEventListener('change', updateInstallment);
      document.getElementById('installmentDown')?.addEventListener('input', updateInstallment);

      // Variants logic (giữ của bạn)
      const variants = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(variantDtos));
      const hasVariants = Array.isArray(variants) && variants.length > 0;
      window.hasProductVariants = hasVariants;

      const addToCartBtn = document.getElementById('addToCartButton');
      const buyNowBtn = document.getElementById('buyNowButton');

      let selectedCapacity = null;
      let selectedColor = null;

      const qtyInput = document.getElementById('quantity');
      const cartQtyHidden = document.getElementById('cartQuantity');
      const buyNowQtyHidden = document.getElementById('buyNowQuantity');

      function syncQtyToHidden() {
        const v = qtyInput?.value || "1";
        if (cartQtyHidden) cartQtyHidden.value = v;
        if (buyNowQtyHidden) buyNowQtyHidden.value = v;
      }
      qtyInput?.addEventListener('input', syncQtyToHidden);
      syncQtyToHidden();

      const priceEl = document.getElementById('displayPrice');
      const specStorageEl = document.getElementById('specStorage');
      const specStorageAvailEl = document.getElementById('specStorageAvailable');

      const basePriceText = priceEl ? priceEl.textContent : '—';
      const baseStorageText = specStorageEl ? specStorageEl.textContent : '';
      const baseStorageAvailText = specStorageAvailEl ? specStorageAvailEl.textContent : '';

      function restoreBaseUI() {
        if (priceEl) priceEl.textContent = basePriceText || '—';
        if (specStorageEl) specStorageEl.textContent = baseStorageText || '';
        if (specStorageAvailEl) specStorageAvailEl.textContent = baseStorageAvailText || '';
        updateInstallment();
      }

      function setHiddenVariantId(variantId) {
        document.getElementById('SelectedVariantId')?.setAttribute('value', variantId || "");
        const w = document.getElementById('WishlistVariantId'); if (w) w.value = variantId || "";
        const b = document.getElementById('BuyNowVariantId'); if (b) b.value = variantId || "";
      }

      function setPrice(priceNumber) {
        if (!priceEl) return;
        priceEl.textContent = Number(priceNumber || 0).toLocaleString('vi-VN') + ' VNĐ';
      }

      function setSpecs(storage, storageAvailable) {
        if (specStorageEl) specStorageEl.textContent = storage || '';
        if (specStorageAvailEl) specStorageAvailEl.textContent = storageAvailable || '';
      }

      function setSku(sku) {
        const el = document.getElementById('variantSku');
        if (el) el.textContent = (sku && String(sku).trim()) ? sku : '—';
      }

      function setVariantImage(imageUrl) {
        if (!imageUrl) return;
        const firstSlideImg = document.querySelector('[id^="productGallery_"] .carousel-item:first-child img');
        if (firstSlideImg) firstSlideImg.src = imageUrl;
        const firstThumb = document.querySelector('.tgdd-thumb-list .tgdd-thumb:first-child');
        if (firstThumb) firstThumb.src = imageUrl;
        const mainImage = document.getElementById('mainImage');
        if (mainImage && !firstSlideImg) mainImage.src = imageUrl;
      }

      function setActiveButtons(capacity, color) {
        document.querySelectorAll('.variant-capacity-btn').forEach(btn => {
          btn.classList.toggle('active', btn.getAttribute('data-capacity') === capacity);
        });
        document.querySelectorAll('.variant-color-btn').forEach(btn => {
          btn.classList.toggle('active', btn.getAttribute('data-color') === color);
        });
      }

      function setStockUIState(state, stock = 0) {
        const badge = document.getElementById('stockBadge');
        const text = document.getElementById('stockText');

        if (state === 'unselected') {
          if (badge) { badge.className = "badge bg-secondary"; badge.textContent = "Chưa chọn phiên bản"; }
          if (text) text.textContent = "Vui lòng chọn Dung lượng và Màu sắc";
          if (addToCartBtn) addToCartBtn.disabled = true;
          if (buyNowBtn) buyNowBtn.disabled = true;
          if (qtyInput) { qtyInput.min = 1; qtyInput.max = "1"; qtyInput.value = 1; syncQtyToHidden(); }
          return;
        }

        if (state === 'notfound') {
          if (badge) { badge.className = "badge bg-warning text-dark"; badge.textContent = "Không có phiên bản"; }
          if (text) text.textContent = "Tổ hợp dung lượng + màu này không tồn tại";
          if (addToCartBtn) addToCartBtn.disabled = true;
          if (buyNowBtn) buyNowBtn.disabled = true;
          if (qtyInput) { qtyInput.min = 1; qtyInput.max = "1"; qtyInput.value = 1; syncQtyToHidden(); }
          return;
        }

        const qty = parseInt(stock || 0);
        const inStock = qty > 0;

        if (badge) {
          badge.className = inStock ? "badge bg-success" : "badge bg-danger";
          badge.textContent = inStock ? "Còn hàng" : "Hết hàng";
        }
        if (text) text.textContent = inStock ? `Còn ${qty} sản phẩm` : "Tạm hết hàng";

        if (addToCartBtn) addToCartBtn.disabled = !inStock;
        if (buyNowBtn) buyNowBtn.disabled = !inStock;

        if (qtyInput) {
          qtyInput.min = 1;
          qtyInput.value = 1;
          qtyInput.max = inStock ? String(qty) : "1";
          syncQtyToHidden();
        }
      }

      function capacityHasStock(capacity, colorFilter) {
        return variants.some(v => v.capacity === capacity && (!colorFilter || v.color === colorFilter) && (v.stock || 0) > 0);
      }
      function colorHasStock(color, capacityFilter) {
        return variants.some(v => v.color === color && (!capacityFilter || v.capacity === capacityFilter) && (v.stock || 0) > 0);
      }
      function updateOptionAvailability() {
        document.querySelectorAll('.variant-capacity-btn').forEach(btn => {
          const cap = btn.getAttribute('data-capacity');
          btn.disabled = !capacityHasStock(cap, selectedColor);
        });
        document.querySelectorAll('.variant-color-btn').forEach(btn => {
          const c = btn.getAttribute('data-color');
          btn.disabled = !colorHasStock(c, selectedCapacity);
        });
      }

      function applyVariantExact(variant) {
        setHiddenVariantId(variant.id);
        setSku(variant.sku);
        setVariantImage(variant.imageUrl);
        setPrice(variant.discountedPrice);
        setSpecs(variant.storage || variant.capacity || '', variant.storageAvailable || '');
        setStockUIState('selected', parseInt(variant.stock || 0));
        updateInstallment();
        syncQtyToHidden();
      }

      function resolveSelection() {
        setActiveButtons(selectedCapacity, selectedColor);
        updateOptionAvailability();

        if (!selectedCapacity || !selectedColor) {
          setHiddenVariantId("");
          setSku("");
          setStockUIState('unselected');
          restoreBaseUI();
          return;
        }

        const exact = variants.find(v => v.capacity === selectedCapacity && v.color === selectedColor);
        if (!exact) {
          setHiddenVariantId("");
          setSku("");
          setStockUIState('notfound');
          restoreBaseUI();
          return;
        }

        applyVariantExact(exact);
      }

      if (hasVariants) {
        selectedCapacity = null;
        selectedColor = null;

        setHiddenVariantId("");
        setSku("");
        setStockUIState('unselected');
        restoreBaseUI();
        updateOptionAvailability();

        const urlVarId = new URLSearchParams(window.location.search).get('variantId');
        if (urlVarId) {
          const pre = variants.find(v => String(v.id) === String(urlVarId));
          if (pre) {
            selectedCapacity = pre.capacity || null;
            selectedColor = pre.color || null;
            resolveSelection();
          }
        }

        document.querySelectorAll('.variant-capacity-btn').forEach(btn => {
          btn.addEventListener('click', function () {
            if (this.disabled) return;
            const cap = this.getAttribute('data-capacity');
            selectedCapacity = (selectedCapacity === cap) ? null : cap;
            resolveSelection();
          });
        });

        document.querySelectorAll('.variant-color-btn').forEach(btn => {
          btn.addEventListener('click', function () {
            if (this.disabled) return;
            const c = this.getAttribute('data-color');
            selectedColor = (selectedColor === c) ? null : c;
            resolveSelection();
          });
        });
      } else {
        setSku('');
        updateInstallment();
        syncQtyToHidden();
      }

      // Shipping
      const provSel = document.getElementById('shipProvince');
      const distSel = document.getElementById('shipDistrict');
      const feeEl = document.getElementById('shipFee');
      const etaEl = document.getElementById('shipEta');

      function money(v) { return Number(v || 0).toLocaleString('vi-VN') + ' đ'; }
      function formatDate(d) {
        const dd = String(d.getDate()).padStart(2, '0');
        const mm = String(d.getMonth() + 1).padStart(2, '0');
        const yy = d.getFullYear();
        return `${dd}/${mm}/${yy}`;
      }
      function etaText(minDays, maxDays) {
        minDays = Number(minDays || 0);
        maxDays = Number(maxDays || 0);
        if (!minDays && !maxDays) return '—';
        const now = new Date();
        const d1 = new Date(now); d1.setDate(now.getDate() + (minDays || 0));
        const d2 = new Date(now); d2.setDate(now.getDate() + (maxDays || minDays || 0));
        return (minDays === maxDays) ? formatDate(d1) : `${formatDate(d1)} - ${formatDate(d2)}`;
      }

      async function loadProvinces() {
        const res = await fetch('/Shipping/Provinces');
        const data = await res.json();
        provSel.innerHTML = `<option value="">-- Chọn Tỉnh/TP --</option>`;
        data.forEach(p => {
          const opt = document.createElement('option');
          opt.value = p.code;
          opt.textContent = `${p.name} (${p.code})`;
          provSel.appendChild(opt);
        });
      }

      async function loadDistricts(provinceCode) {
        distSel.disabled = true;
        distSel.innerHTML = `<option value="">-- Toàn tỉnh --</option>`;
        if (!provinceCode) return;

        const res = await fetch('/Shipping/Districts?provinceCode=' + encodeURIComponent(provinceCode));
        const data = await res.json();

        data.forEach(d => {
          const opt = document.createElement('option');
          opt.value = d.code;
          opt.textContent = `${d.name} (${d.code})`;
          distSel.appendChild(opt);
        });

        distSel.disabled = false;
      }

      async function quote(provinceCode, districtCode) {
        if (!provinceCode) {
          feeEl.textContent = '—';
          etaEl.textContent = '—';
          return;
        }

        const url = '/Shipping/Quote?provinceCode=' + encodeURIComponent(provinceCode)
          + '&districtCode=' + encodeURIComponent(districtCode || '');
        const res = await fetch(url);
        const data = await res.json();

        feeEl.textContent = money(data.fee);
        etaEl.textContent = etaText(data.minDays, data.maxDays);
      }

      if (provSel && distSel && feeEl && etaEl) {
        const savedProvince = localStorage.getItem('ship_province') || '';
        const savedDistrict = localStorage.getItem('ship_district') || '';

        loadProvinces().then(async () => {
          provSel.value = savedProvince;
          await loadDistricts(provSel.value);
          distSel.value = savedDistrict;
          await quote(provSel.value, distSel.value);
        });

        provSel.addEventListener('change', async () => {
          localStorage.setItem('ship_province', provSel.value);
          localStorage.setItem('ship_district', '');
          await loadDistricts(provSel.value);
          distSel.value = '';
          await quote(provSel.value, '');
        });

        distSel.addEventListener('change', async () => {
          localStorage.setItem('ship_district', distSel.value);
          await quote(provSel.value, distSel.value);
        });
      }

      // Rating stars hover/select
      (function initRatingStars() {
        const stars = document.querySelectorAll('.rating-select input[type="radio"]');
        const starLabels = document.querySelectorAll('.rating-select .star-label');
        if (!stars.length || !starLabels.length) return;

        function updateStars(value) {
          starLabels.forEach((lbl, idx) => {
            if ((starLabels.length - idx) <= value) lbl.classList.add('selected');
            else lbl.classList.remove('selected');
          });
        }

        const checked = document.querySelector('.rating-select input[type="radio"]:checked');
        if (checked) updateStars(Number(checked.value));

        stars.forEach((star, idx) => {
          star.addEventListener('change', function () { updateStars(Number(star.value)); });
          starLabels[idx].addEventListener('mouseenter', function () {
            updateStars(starLabels.length - idx);
          });
          starLabels[idx].addEventListener('mouseleave', function () {
            const checked2 = document.querySelector('.rating-select input[type="radio"]:checked');
            updateStars(checked2 ? Number(checked2.value) : 0);
          });
        });
      })();

      // AJAX AddToCart
      document.getElementById('addToCartForm')?.addEventListener('submit', function (e) {
        e.preventDefault();

        if (window.hasProductVariants) {
          const variantId = document.getElementById('SelectedVariantId')?.value;
          if (!variantId) { alert('Vui lòng chọn dung lượng và màu sắc trước khi thêm vào giỏ.'); return; }
          const v = variants.find(x => String(x.id) === String(variantId));
          if (v && parseInt(v.stock || 0) <= 0) { alert('Phiên bản này đã hết hàng.'); return; }
        }

        syncQtyToHidden();

        const form = this;
        const formData = new FormData(form);

        fetch(form.action, {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          body: formData
        })
        .then(res => {
          if (res.ok) { showPopup('Sản phẩm đã được thêm vào giỏ hàng!'); updateCartCount(); }
          else { showPopup('Có lỗi khi thêm vào giỏ hàng!', 2000); }
        })
        .catch(() => showPopup('Lỗi mạng!', 2000));
      });

      // AJAX Wishlist
      document.getElementById('addToWishlistForm')?.addEventListener('submit', function (e) {
        e.preventDefault();

        if (window.hasProductVariants) {
          const variantId = document.getElementById('WishlistVariantId')?.value;
          if (!variantId) { alert('Vui lòng chọn dung lượng và màu sắc trước khi thêm yêu thích.'); return; }
        }

        const form = this;
        const formData = new FormData(form);

        fetch(form.action, {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          body: formData
        })
        .then(res => {
          if (res.ok) showPopup('Đã thêm vào danh sách yêu thích!');
          else showPopup('Có lỗi khi thêm vào yêu thích!', 2000);
        })
        .catch(() => showPopup('Lỗi mạng!', 2000));
      });

      // BuyNow validation
      document.getElementById('buyNowForm')?.addEventListener('submit', function (e) {
        if (window.hasProductVariants) {
          const variantId = document.getElementById('BuyNowVariantId')?.value;
          if (!variantId) { e.preventDefault(); alert('Vui lòng chọn dung lượng và màu sắc trước khi mua ngay.'); return; }
          const v = variants.find(x => String(x.id) === String(variantId));
          if (v && parseInt(v.stock || 0) <= 0) { e.preventDefault(); alert('Phiên bản này đã hết hàng.'); return; }
        }
        syncQtyToHidden();
      });

      // Compare
      const btnCompare = document.getElementById('btnCompare');
      if (btnCompare) {
        btnCompare.addEventListener('click', function () {
          const baseUrl = '@Url.Action("Add", "Compare")';
          const productId = '@Model.Id';
          let url = baseUrl + '?productId=' + productId;

          if (window.hasProductVariants) {
            const variantId = document.getElementById('SelectedVariantId')?.value;
            if (!variantId) { alert('Vui lòng chọn dung lượng và màu sắc trước khi so sánh.'); return; }
            url += '&variantId=' + encodeURIComponent(variantId);
          }

          window.location.href = url;
        });
      }

      // ===== Vote / Report =====
      window.voteRating = async function(id, isLike) {
        const res = await fetch('/Product/VoteRating', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            ...(token ? { 'RequestVerificationToken': token } : {})
          },
          body: `ratingId=${id}&isLike=${isLike}`
        });

        if (!res.ok) { alert('Không vote được'); return; }
        const data = await res.json();
        document.getElementById(`like-${id}`).innerText = data.like;
        document.getElementById(`dislike-${id}`).innerText = data.dislike;
      }

      window.reportRating = async function(id) {
        const reason = prompt("Lý do báo cáo (tối đa 200 ký tự)?");
        if (!reason) return;

        const res = await fetch('/Product/ReportRating', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            ...(token ? { 'RequestVerificationToken': token } : {})
          },
          body: `ratingId=${id}&reason=${encodeURIComponent(reason)}`
        });

        if (!res.ok) { alert('Không gửi báo cáo được'); return; }
        const data = await res.json();
        alert(data.ok ? "Đã gửi báo cáo" : (data.message || "Không gửi được"));
      }

    });
</script>
