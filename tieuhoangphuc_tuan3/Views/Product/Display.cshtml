@using System.Text.Json
@model WebBanDienThoai.Models.ProductWithSoldCount
@using WebBanDienThoai.Models
@using System.Collections.Generic
@using System.Linq

@{
    ViewData["Title"] = "Chi Tiết Sản Phẩm";

    var ratings = ViewBag.Ratings as List<WebBanDienThoai.Models.ProductRating> ?? new List<WebBanDienThoai.Models.ProductRating>();
    double avg = ratings.Count > 0 ? ratings.Average(r => r.Stars) : 0;
    int fullStars = (int)Math.Floor(avg);
    bool hasHalf = avg - fullStars >= 0.5;

    // 🔹 Biến thể (màu / dung lượng)
    var variants = ViewBag.Variants as List<ProductVariant> ?? new List<ProductVariant>();
    bool hasVariants = variants.Any();
    var variantDtos = variants.Select(v => new
    {
        id = v.Id,
        color = v.Color,
        capacity = v.Capacity,             // map sang Storage
        discountedPrice = v.DiscountedPrice,
        stock = v.Stock,
        storage = v.Storage,               // 👈 THÊM
        storageAvailable = v.StorageAvailable // 👈 THÊM
    }).ToList();


    var defaultVariantPrice = hasVariants
    ? variants.First().DiscountedPrice
    : Model.DiscountedPrice;

    // 🔹 Gallery: gom ảnh chính + ảnh phụ
    var galleryId = $"productGallery_{Model.Id}";
    var media = new List<string>();

    if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        media.Add(Model.ImageUrl);
    }

    if (Model.Images != null)
    {
        foreach (var img in Model.Images)
        {
            if (!string.IsNullOrEmpty(img.Url))
            {
                media.Add(img.Url);
            }
        }
    }
}

}

<script>
    // Cho JS phía dưới biết là sản phẩm này có biến thể hay không
    window.hasProductVariants = @hasVariants.ToString().ToLower();
</script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    .btn-cart {
        background-color: #4CAF50;
        color: white;
        border-color: #4CAF50;
    }

        .btn-cart:hover {
            background-color: #45a049;
            border-color: #45a049;
        }

    .btn-heart {
        background-color: #f44336;
        color: white;
        border-color: #f44336;
    }

        .btn-heart:hover {
            background-color: #e53935;
            border-color: #e53935;
        }

    .img-thumbnail {
        cursor: pointer;
    }

    .product-description-box {
        background: #fafbfc;
        border-radius: 8px;
        box-shadow: 0 2px 8px #0001;
        font-size: 1.1rem;
        line-height: 1.7;
        word-break: break-word;
    }

    .word-break-all {
        word-break: break-word;
    }

    .rating-select .star-label i {
        color: #ddd;
        transition: color 0.2s;
    }

    .rating-select .star-label.selected i {
        color: #ffb300 !important;
    }

    .custom-popup {
        position: fixed;
        z-index: 9999;
        left: 0;
        right: 0;
        top: 0;
        bottom: 0;
        background: rgba(0,0,0,0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
    }

    .custom-popup-content {
        background: #fff;
        padding: 32px 48px;
        border-radius: 14px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.16);
        display: flex;
        align-items: center;
        flex-direction: column;
        animation: popscale .2s;
        min-width: 300px;
    }

    keyframes popscale {
        0%

    {
        transform: scale(0.7);
    }

    100% {
        transform: scale(1);
    }

    }

    .custom-popup-icon {
        font-size: 48px;
        color: #27c93f;
        margin-bottom: 12px;
    }

    #custom-popup-message {
        font-size: 1.15rem;
        font-weight: 500;
        color: #222;
    }

    /* Gallery kiểu TGDD */
    .tgdd-gallery {
        background: #fff;
    }

    .tgdd-thumb-list {
        gap: 6px;
        overflow-x: auto;
    }

    .tgdd-thumb {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid #ddd;
        cursor: pointer;
        transition: all 0.15s;
        background: #fff;
        margin-right: 4px;
        margin-bottom: 4px;
    }

        .tgdd-thumb.active {
            border: 2px solid #0d6efd;
            box-shadow: 0 0 0 2px rgba(13, 110, 253, .25);
        }

        .tgdd-thumb:hover {
            transform: translateY(-1px);
        }

    /* ===== NÚT DUNG LƯỢNG / MÀU KIỂU TGDD ===== */

    .variant-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        border-radius: 999px;
        border: 1px solid #ddd;
        background: #fff;
        padding: 6px 14px;
        font-size: 0.9rem;
        min-width: 72px;
        cursor: pointer;
        margin-right: 6px;
        margin-bottom: 6px;
        transition: all 0.15s ease-in-out;
        outline: none;
        color: #333;
        white-space: nowrap;
    }

        .variant-pill:hover {
            border-color: #2f80ed;
            color: #2f80ed;
            background: rgba(47, 128, 237, 0.03);
        }

        .variant-pill.active {
            border-color: #2f80ed;
            color: #2f80ed;
            background: rgba(47, 128, 237, 0.08);
            box-shadow: 0 0 0 1px rgba(47, 128, 237, 0.25);
            font-weight: 600;
        }

    /* chấm tròn màu bên trái chữ */
    .color-dot {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        border: 1px solid rgba(0,0,0,0.1);
        flex-shrink: 0;
    }

    .variant-color-btn.variant-pill {
        padding-inline: 14px;
    }


</style>

<div class="container mt-5">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small bg-light rounded px-3 py-2 mb-3">
            <li class="breadcrumb-item">
                <a href="/" class="text-primary text-decoration-none">
                    <i class="bi bi-house"></i> Trang chủ
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="/Product" class="text-info text-decoration-none">Sản phẩm</a>
            </li>
            <li class="breadcrumb-item active text-secondary" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Hình ảnh sản phẩm chính + gallery -->
        <div class="col-md-6 mb-4">
            @if (media.Count > 0)
            {
                <div class="tgdd-gallery border rounded-3 p-2">
                    <div id="@galleryId" class="carousel slide" data-bs-ride="false">
                        <div class="carousel-inner">
                            @for (int i = 0; i < media.Count; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "")">
                                    <img src="@media[i]"
                                         class="d-block w-100 img-fluid rounded shadow-sm product-image"
                                         style="max-height:420px;object-fit:contain"
                                         alt="@Model.Name"
                                         @(i == 0 ? "id=\"mainImage\"" : "") />
                                </div>
                            }
                        </div>

                        <button class="carousel-control-prev" type="button"
                                data-bs-target="#@galleryId" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                        </button>
                        <button class="carousel-control-next" type="button"
                                data-bs-target="#@galleryId" data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                        </button>
                    </div>

                    <div class="tgdd-thumb-list d-flex flex-wrap mt-2">
                        @for (int i = 0; i < media.Count; i++)
                        {
                            <img src="@media[i]"
                                 class="tgdd-thumb @(i == 0 ? "active" : "")"
                                 data-bs-target="#@galleryId"
                                 data-bs-slide-to="@i"
                                 alt="thumb-@i" />
                        }
                    </div>
                </div>
            }
            else
            {
                <img src="@Model.ImageUrl" alt="@Model.Name"
                     class="img-fluid rounded shadow-sm product-image" id="mainImage">
            }
        </div>

        <!-- Thông tin sản phẩm -->
        <div class="col-md-6">
            <h2 class="mb-2 text-uppercase text-dark">@Model.Name</h2>

            <!-- Rating + đã bán -->
            <div class="d-flex align-items-center mb-3 gap-3" style="font-size: 1.1rem;">
                <span class="fw-bold me-1" style="color: #ffb300;">@avg.ToString("0.0")</span>
                <i class="bi bi-star-fill text-warning"></i>
                <span class="text-muted ms-3">|</span>
                <span class="text-muted ms-3">@ratings.Count đánh giá</span>
                <span class="text-muted ms-3">|</span>
                <span class="text-muted ms-3">Đã bán: @Model.SoldCount</span>
            </div>

            <div style="height: 32px;"></div>

            <!-- GIÁ + cập nhật theo biến thể -->
            <div class="mb-3">
                @if (hasVariants)
                {
                    if (Model.DiscountPercent > 0)
                    {
                        <span class="h5 text-muted text-decoration-line-through">
                            @Model.Price.ToString("N0") VNĐ
                        </span>
                    }
                    <span class="h4 text-danger fw-bold ms-2" id="displayPrice">
                        @defaultVariantPrice.ToString("N0") VNĐ
                    </span>
                }
                else
                {
                    @if (Model.DiscountPercent > 0)
                    {
                        <span class="h4 text-danger fw-bold">
                            <del>@Model.Price.ToString("N0") VNĐ</del>
                        </span>
                        <span class="h4 text-danger fw-bold ms-2" id="displayPrice">
                            @Model.DiscountedPrice.ToString("N0") VNĐ
                        </span>
                    }
                    else
                    {
                        <span class="h4 text-danger fw-bold" id="displayPrice">
                            @Model.Price.ToString("N0") VNĐ
                        </span>
                    }
                }
            </div>

            <!-- CHỌN PHIÊN BẢN: dung lượng & màu -->
            @functions {
                public string GetColorHex(string color)
                {
                    if (string.IsNullOrWhiteSpace(color)) return "#cccccc";
                    color = color.ToLower();

                    if (color.Contains("đen")) return "#000000";
                    if (color.Contains("trắng")) return "#f8f8f8";
                    if (color.Contains("xanh lá")) return "#2ecc71";
                    if (color.Contains("xanh")) return "#3498db";
                    if (color.Contains("đỏ")) return "#e74c3c";
                    if (color.Contains("vàng") || color.Contains("gold")) return "#f1c40f";
                    if (color.Contains("tím")) return "#9b59b6";
                    if (color.Contains("titan")) return "#bdc3c7";
                    if (color.Contains("xám") || color.Contains("ghi") || color.Contains("gray")) return "#7f8c8d";

                    return "#cccccc";
                }
            }

            @if (hasVariants)
            {
                // chọn mặc định theo biến thể đầu tiên
                var firstVariant = variants.FirstOrDefault();

                <!-- Dung lượng -->
                <div class="mb-2">
                    <label class="form-label fw-semibold me-2">Dung lượng:</label>
                    @foreach (var cap in variants.Select(v => v.Capacity).Distinct())
                    {
                        <button type="button"
                                class="variant-pill variant-capacity-btn @(firstVariant != null && cap == firstVariant.Capacity ? "active" : "")"
                                data-capacity="@cap">
                            @cap
                        </button>
                    }
                </div>

                <!-- Màu sắc -->
                <div class="mb-3">
                    <label class="form-label fw-semibold me-2">Màu sắc:</label>
                    @foreach (var color in variants.Select(v => v.Color).Distinct())
                    {
                        <button type="button"
                                class="variant-pill variant-color-btn @(firstVariant != null && color == firstVariant.Color ? "active" : "")"
                                data-color="@color">
                            <span class="color-dot" style="background-color:@GetColorHex(color)"></span>
                            <span>@color</span>
                        </button>
                    }
                </div>
            }

            <!-- Số lượng -->
            <div class="mb-4">
                <label for="quantity" class="form-label">Số lượng:</label>
                <input type="number" class="form-control" id="quantity" value="1" min="1" style="width: 80px;">
            </div>

            <!-- Nút mua / yêu thích -->
            <div class="d-flex gap-3">
                @if (User.Identity.IsAuthenticated && !User.IsInRole("Admin") && !User.IsInRole("Employer"))
                {
                    <form id="addToCartForm" asp-controller="ShoppingCart" asp-action="AddToCart" method="post">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <input type="hidden" name="quantity" id="cartQuantity" value="1" />
                        <!-- 🔹 VariantId -->
                        <input type="hidden" name="variantId" id="SelectedVariantId" />

                        <button class="btn btn-cart px-4 py-2 shadow" type="submit" id="addToCartButton">
                            <i class="bi bi-cart-fill me-2"></i> Thêm vào giỏ hàng
                        </button>
                    </form>
                }
                else if (User.IsInRole("Admin") || User.IsInRole("Employer"))
                {
                    <button class="btn btn-secondary px-4 py-2 shadow" disabled>
                        <i class="bi bi-cart-fill me-2"></i> Thêm vào giỏ hàng
                    </button>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-secondary px-4 py-2 shadow">
                        <i class="bi bi-cart-fill me-2"></i> Thêm vào giỏ hàng
                    </a>
                }

                <!-- Nút Yêu thích -->
                @if (User.Identity.IsAuthenticated)
                {
                    <form id="addToWishlistForm" asp-controller="Wishlist" asp-action="AddToWishlist" method="post">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <input type="hidden" name="variantId" id="WishlistVariantId" />   <!-- THÊM DÒNG NÀY -->

                        <button type="submit" class="btn btn-heart px-4 py-2 shadow" id="addToWishlistButton">
                            <i class="bi bi-heart me-2"></i> Yêu thích
                        </button>
                    </form>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-heart px-4 py-2 shadow">
                        <i class="bi bi-heart me-2"></i> Yêu thích
                    </a>
                }

                <a href="javascript:void(0)"
                   id="btnCompare"
                   class="btn btn-outline-primary px-4 py-2 shadow">
                    So sánh
                </a>
            </div>

            <!-- Thông tin cơ bản -->
            <div class="mt-4">
                <h5 class="mb-3">Thông tin sản phẩm:</h5>
                <ul class="list-unstyled">
                    <li><strong>Danh mục:</strong> @Model.Category?.Name</li>
                    @if (Model.SubCategory != null)
                    {
                        <li><strong>Hãng:</strong> @Model.SubCategory?.Name</li>
                    }
                    <li><strong>Mã sản phẩm:</strong> @Model.Id</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- MÔ TẢ SẢN PHẨM -->
    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="product-description-box p-4">
                    <h5 class="mb-3">Mô tả sản phẩm</h5>
                    @Html.Raw(Model.Description)
                </div>
            </div>
        </div>
    }

    <!-- CAM KẾT DỊCH VỤ -->
    @if (!string.IsNullOrWhiteSpace(Model.ServiceCommitment))
    {
        <div class="mt-4">
            <h5 class="mb-3 fw-semibold">Cam kết dịch vụ</h5>

            <div class="row g-3">
                @foreach (var line in Model.ServiceCommitment.Split('\n'))
                {
                    if (!string.IsNullOrWhiteSpace(line))
                    {
                        <div class="col-md-6 d-flex align-items-start">
                            <div class="me-2">
                                <i class="bi bi-patch-check-fill"
                                   style="color:#3b82f6; font-size:20px;"></i>
                            </div>

                            <div class="text-dark" style="line-height:1.4;">
                                @line.Trim()
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }

    <!-- THÔNG SỐ KỸ THUẬT (Accordion) -->
    @if (Model.Specs != null)
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="product-description-box p-4">
                    <h5 class="mb-3">Thông số kỹ thuật</h5>

                    <div class="accordion" id="specsAccordion">
                        <!-- (GIỮ NGUYÊN 6 accordion như bạn đã có) -->
                        <!-- 1) Cấu hình & Bộ nhớ -->
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingCfg">
                                <button class="accordion-button" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#collapseCfg"
                                        aria-expanded="true" aria-controls="collapseCfg">
                                    Cấu hình & Bộ nhớ
                                </button>
                            </h2>
                            <div id="collapseCfg" class="accordion-collapse collapse show"
                                 aria-labelledby="headingCfg" data-bs-parent="#specsAccordion">
                                <div class="accordion-body p-0">
                                    <table class="table table-sm mb-0">
                                        <tr><th style="width:230px">Hệ điều hành</th><td>@Model.Specs.Os</td></tr>
                                        <tr><th>Chip xử lý (CPU)</th><td>@Model.Specs.Cpu</td></tr>
                                        <tr><th>Tốc độ CPU</th><td>@Model.Specs.CpuSpeed</td></tr>
                                        <tr><th>Chip đồ họa (GPU)</th><td>@Model.Specs.Gpu</td></tr>
                                        <tr><th>RAM</th><td>@Model.Specs.Ram</td></tr>
                                        <tr>
                                            <th>Dung lượng lưu trữ</th>
                                            <td id="specStorage">
                                                @(
                                                                                            hasVariants && variants.Any()
                                                                                            ? variants.First().Storage          // 👈 lấy từ biến thể đầu tiên
                                                                                            : Model.Specs.Storage               // fallback: Specs
                                                                                            )
                                            </td>
                                        </tr>

                                        <tr>
                                            <th>Dung lượng còn lại (khả dụng)</th>
                                            <td id="specStorageAvailable">
                                                @(
                                                                                            hasVariants && variants.Any()
                                                                                            ? (variants.First().StorageAvailable ?? Model.Specs.StorageAvailable)
                                                                                            : Model.Specs.StorageAvailable
                                                                                            )
                                        </td>
                                    </tr>

                                        <tr><th>Danh bạ</th><td>@Model.Specs.ContactLimit</td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- 2) Camera & Màn hình -->
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingCam">
                                <button class="accordion-button collapsed" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#collapseCam"
                                        aria-expanded="false" aria-controls="collapseCam">
                                    Camera & Màn hình
                                </button>
                            </h2>
                            <div id="collapseCam" class="accordion-collapse collapse"
                                 aria-labelledby="headingCam" data-bs-parent="#specsAccordion">
                                <div class="accordion-body p-0">
                                    <table class="table table-sm mb-0">
                                        <tr><th style="width:230px">Độ phân giải camera sau</th><td>@Model.Specs.RearCameraResolution</td></tr>
                                        <tr><th>Độ phân giải camera trước</th><td>@Model.Specs.FrontCameraResolution</td></tr>
                                        <tr><th>Quay video (sau)</th><td>@Model.Specs.RearVideoModes</td></tr>
                                        <tr><th>Quay video (trước)</th><td>@Model.Specs.FrontVideoModes</td></tr>
                                        <tr><th>Tính năng camera sau</th><td>@Model.Specs.RearCameraFeatures</td></tr>
                                        <tr><th>Tính năng camera trước</th><td>@Model.Specs.FrontCameraFeatures</td></tr>
                                        <tr><th>Công nghệ màn hình</th><td>@Model.Specs.ScreenTech</td></tr>
                                        <tr><th>Độ phân giải màn hình</th><td>@Model.Specs.ScreenResolution</td></tr>
                                        <tr><th>Kích thước & tần số quét</th><td>@Model.Specs.ScreenSize</td></tr>
                                        <tr><th>Độ sáng tối đa</th><td>@Model.Specs.ScreenBrightness</td></tr>
                                        <tr><th>Mặt kính cảm ứng</th><td>@Model.Specs.ScreenGlass</td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- 3) Pin & Sạc -->
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingPin">
                                <button class="accordion-button collapsed" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#collapsePin"
                                        aria-expanded="false" aria-controls="collapsePin">
                                    Pin & Sạc
                                </button>
                            </h2>
                            <div id="collapsePin" class="accordion-collapse collapse"
                                 aria-labelledby="headingPin" data-bs-parent="#specsAccordion">
                                <div class="accordion-body p-0">
                                    <table class="table table-sm mb-0">
                                        <tr><th style="width:230px">Thời lượng pin</th><td>@Model.Specs.BatteryUsageTime</td></tr>
                                        <tr><th>Loại pin</th><td>@Model.Specs.BatteryType</td></tr>
                                        <tr><th>Công suất sạc tối đa</th><td>@Model.Specs.MaxChargePower</td></tr>
                                        <tr><th>Công nghệ pin</th><td>@Model.Specs.BatteryTech</td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- 4) Tiện ích -->
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingTienIch">
                                <button class="accordion-button collapsed" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#collapseTienIch"
                                        aria-expanded="false" aria-controls="collapseTienIch">
                                    Tiện ích
                                </button>
                            </h2>
                            <div id="collapseTienIch" class="accordion-collapse collapse"
                                 aria-labelledby="headingTienIch" data-bs-parent="#specsAccordion">
                                <div class="accordion-body p-0">
                                    <table class="table table-sm mb-0">
                                        <tr><th style="width:230px">Bảo mật</th><td>@Model.Specs.Security</td></tr>
                                        <tr><th>Kháng nước bụi</th><td>@Model.Specs.WaterDustResist</td></tr>
                                        <tr><th>Tính năng đặc biệt</th><td>@Model.Specs.SpecialFeatures</td></tr>
                                        <tr><th>Ghi âm</th><td>@Model.Specs.Recorder</td></tr>
                                        <tr><th>Định dạng phim</th><td>@Model.Specs.VideoFormats</td></tr>
                                        <tr><th>Định dạng nhạc</th><td>@Model.Specs.AudioFormats</td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>

