        height: 18px;
        border-radius: 50%;
        border: 1px solid rgba(0,0,0,0.1);
        flex-shrink: 0;
    }

    .variant-color-btn.variant-pill {
        padding-inline: 14px;
    }

    .variant-pill:disabled {
        opacity: .45;
        cursor: not-allowed;
        border-color: #ddd !important;
        color: #999 !important;
        background: #f6f7f8 !important;
    }

        .variant-pill:disabled .color-dot {
            filter: grayscale(1);
            opacity: .6;
        }

    .rating-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: #e9ecef;
        color: #495057;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        flex: 0 0 38px;
    }

    .reply-box {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 10px;
        padding: 10px 12px;
        margin-top: 8px;
    }

    #recommendationTab .nav-link {
        color: #4b5563;
        border-radius: 6px;
        transition: all 0.2s;
    }

        #recommendationTab .nav-link.active {
            background-color: #0ea5e9;
            color: white !important;
            box-shadow: 0 4px 6px rgba(14, 165, 233, 0.2);
        }

        #recommendationTab .nav-link:hover:not(.active) {
            background-color: #e5e7eb;
            color: #000;
        }

    .border-dashed {
        border-style: dashed !important;
    }
</style>

<div class="container mt-5">

    <form id="antiForgeryForm">
        @Html.AntiForgeryToken()
    </form>

    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small bg-light rounded px-3 py-2 mb-3">
            <li class="breadcrumb-item">
                <a href="/" class="text-primary text-decoration-none">
                    <i class="bi bi-house"></i> Trang chủ
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="/Product" class="text-info text-decoration-none">Sản phẩm</a>
            </li>
            <li class="breadcrumb-item active text-secondary" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-6 mb-4">
            @if (media.Count > 0)
            {
                <div class="tgdd-gallery border rounded-3 p-2">
                    <div id="@galleryId" class="carousel slide" data-bs-ride="false">
                        <div class="carousel-inner">
                            @for (int i = 0; i < media.Count; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "")">
                                    <img src="@media[i]"
                                         class="d-block w-100 img-fluid rounded shadow-sm product-image"
                                         style="max-height:420px;object-fit:contain"
                                         alt="@Model.Name"
                                    @(i == 0 ? "id=\"mainImage\"" : "") />
                                </div>
                            }
                        </div>

                        <button class="carousel-control-prev" type="button"
                                data-bs-target="#@galleryId" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                        </button>
                        <button class="carousel-control-next" type="button"
                                data-bs-target="#@galleryId" data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                        </button>
                    </div>

                    <div class="tgdd-thumb-list d-flex flex-wrap mt-2">
                        @for (int i = 0; i < media.Count; i++)
                        {
                            <img src="@media[i]"
                                 class="tgdd-thumb @(i == 0 ? "active" : "")"
                                 data-bs-target="#@galleryId"
                                 data-bs-slide-to="@i"
                                 alt="thumb-@i" />
                        }
                    </div>
                </div>
            }
            else
            {
                <img src="@Model.ImageUrl" alt="@Model.Name"
                     class="img-fluid rounded shadow-sm product-image" id="mainImage">
            }
        </div>

        <div class="col-md-6">
            <h2 class="mb-2 text-uppercase text-dark">@Model.Name</h2>
            @{
                var selectedVariantSku = ViewBag.SelectedVariant as ProductVariant;
            }
            <div class="mb-2 small text-muted">
                SKU: <b id="variantSku">@(!string.IsNullOrWhiteSpace(selectedVariantSku?.Sku) ? selectedVariantSku.Sku : "—")</b>
            </div>

            <div class="d-flex align-items-center mb-3 gap-3" style="font-size: 1.1rem;">
                <span class="fw-bold me-1" style="color: #ffb300;">@avg.ToString("0.0")</span>
                <i class="bi bi-star-fill text-warning"></i>
                <span class="text-muted ms-3">|</span>
                <span class="text-muted ms-3">@((int)(ViewBag.TotalRatings ?? 0)) đánh giá</span>
                <span class="text-muted ms-3">|</span>
                <span class="text-muted ms-3">Đã bán: @Model.SoldCount</span>
            </div>

            <div style="height: 12px;"></div>

            <div class="mb-3">
                @if (hasVariants)
                {
                    if (Model.DiscountPercent > 0)
                    {
                        <span class="h5 text-muted text-decoration-line-through">
                            @Model.Price.ToString("N0", vi) VNĐ
                        </span>
                    }
                    <span class="h4 text-danger fw-bold ms-2" id="displayPrice">
                        @defaultVariantPrice.ToString("N0", vi) VNĐ
                    </span>
                }
                else
                {
                    @if (Model.DiscountPercent > 0)
                    {
                        <span class="h4 text-danger fw-bold">
                            <del>@Model.Price.ToString("N0", vi) VNĐ</del>
                        </span>
                        <span class="h4 text-danger fw-bold ms-2" id="displayPrice">
                            @Model.DiscountedPrice.ToString("N0", vi) VNĐ
                        </span>
                    }
                    else
                    {
                        <span class="h4 text-danger fw-bold" id="displayPrice">
                            @Model.Price.ToString("N0", vi) VNĐ
                        </span>
                    }
                }
            </div>

@functions {
    public string GetColorHex(string color)
    {
        if (string.IsNullOrWhiteSpace(color)) return "#cccccc";
        color = color.ToLower();

        if (color.Contains("đen")) return "#000000";
        if (color.Contains("trắng")) return "#f8f8f8";
        if (color.Contains("xanh lá")) return "#2ecc71";
        if (color.Contains("xanh")) return "#3498db";
        if (color.Contains("đỏ")) return "#e74c3c";
        if (color.Contains("vàng") || color.Contains("gold")) return "#f1c40f";
        if (color.Contains("tím")) return "#9b59b6";
        if (color.Contains("titan")) return "#bdc3c7";
        if (color.Contains("xám") || color.Contains("ghi") || color.Contains("gray")) return "#7f8c8d";

        return "#cccccc";
    }
}

@if (hasVariants)
{
    <div class="mb-2">
        <label class="form-label fw-semibold me-2">Dung lượng:</label>
        @foreach (var cap in variants.Select(v => v.Capacity).Distinct())
        {
            <button type="button"
                    class="variant-pill variant-capacity-btn"
                    data-capacity="@cap">
                @cap
            </button>
        }
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold me-2">Màu sắc:</label>
        @foreach (var color in variants.Select(v => v.Color).Distinct())
        {
            <button type="button"
                    class="variant-pill variant-color-btn"
                    data-color="@color">
                <span class="color-dot" style="background-color:@GetColorHex(color)"></span>
                <span>@color</span>
            </button>
        }
    </div>
}

<div class="mb-2">
    <span class="fw-semibold">Tình trạng: </span>
    <span id="stockBadge" class="badge"></span>
    <span id="stockText" class="ms-2 small text-muted"></span>
</div>

<div class="border rounded-3 p-3 mb-3" style="background:#fcfcfd;">
    <div class="fw-semibold mb-2">
        <i class="bi bi-truck me-1"></i> Giao đến
    </div>

    <div class="row g-2">
        <div class="col-md-6">
            <select class="form-select" id="shipProvince">
                <option value="">-- Chọn Tỉnh/TP --</option>
            </select>
        </div>
        <div class="col-md-6">
            <select class="form-select" id="shipDistrict" disabled>
                <option value="">-- Toàn tỉnh --</option>
            </select>
        </div>
    </div>

    <div class="mt-2 small">
        <div>Phí ship: <b id="shipFee">—</b></div>
        <div>Giao dự kiến: <b id="shipEta">—</b></div>
    </div>
</div>

<div class="border rounded-3 p-3 mb-3" style="background:#fff7ed;">
    <div class="fw-semibold mb-2">
        <i class="bi bi-gift me-1"></i> Khuyến mãi / Ưu đãi
    </div>

    <ul class="mb-2 small">
        <li>Mã giảm giá / quà tặng kèm (tuỳ đợt).</li>
        <li>Ưu đãi ngân hàng / hoàn tiền (nếu áp dụng).</li>
        <li class="text-muted">* Điều kiện áp dụng theo thời gian, số lượt, và biến thể.</li>
    </ul>

    @if (promoCoupons.Any())
    {
        <div class="list-group">
            @foreach (var c in promoCoupons)
            {
                var remain = c.Quantity - c.CurrentUsage;
                <div class="list-group-item d-flex justify-content-between align-items-start">
                    <div>
                        <div class="fw-semibold">
                            <span class="badge bg-danger me-2">@c.Code</span>
                            @if (c.DiscountPercent.HasValue && c.DiscountPercent.Value > 0)
                            {
                                <span>Giảm @c.DiscountPercent% </span>
                            }
                            else if (c.DiscountAmount.HasValue && c.DiscountAmount.Value > 0)
                            {
                                <span>Giảm @c.DiscountAmount.Value.ToString("N0", vi) VNĐ</span>
                            }
                        </div>

                        <div class="small text-muted">
                            Đơn tối thiểu: @c.MinOrderValue.ToString("N0", vi) VNĐ •
                            Còn: @(remain > 0 ? remain.ToString() : "0") lượt •
                            @c.StartDate.ToString("dd/MM") - @c.EndDate.ToString("dd/MM")
                        </div>
                    </div>

                    <button type="button"
                            class="btn btn-sm btn-outline-dark copy-coupon-btn"
                            data-code="@c.Code">
                        Copy
                    </button>
                </div>
            }
        </div>

        <div class="small text-muted mt-2">
            * Bạn áp mã tại trang giỏ hàng/checkout.
        </div>
    }
    else
    {
        <div class="small text-muted">
            Hiện chưa có mã hiển thị ở trang sản phẩm.
        </div>
    }
</div>

