<!-- ⭐ Đồng bộ thumbnail với carousel gallery -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var carousels = document.querySelectorAll('[id^="productGallery_"]');

        carousels.forEach(function (carouselEl) {
            // tìm thumbnail trong cùng gallery
            var thumbs = carouselEl.parentElement.querySelectorAll('.tgdd-thumb');

            // khi dùng nút prev/next
            carouselEl.addEventListener('slide.bs.carousel', function (e) {
                var index = e.to;
                thumbs.forEach(function (t, i) {
                    t.classList.toggle('active', i === index);
                });
            });

            // khi click vào thumbnail
            thumbs.forEach(function (thumb) {
                thumb.addEventListener('click', function () {
                    thumbs.forEach(t => t.classList.remove('active'));
                    this.classList.add('active');
                });
            });
        });
    });
</script>

<!-- ⭐ Script chọn variant + cập nhật giá -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const variants = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(variantDtos));
        const hasVariants = variants && variants.length > 0;

        // cho các script khác (AddToCart, Compare) biết có biến thể hay không
        window.hasProductVariants = hasVariants;

        let selectedCapacity = null;
        let selectedColor = null;

        // 🔹 AUTO CHỌN BIẾN THỂ ĐẦU TIÊN KHI VÀO TRANG
        if (hasVariants) {
            const first = variants[0];               // biến thể đầu tiên trong DB
            selectedCapacity = first.capacity;
            selectedColor = first.color;

            // Đánh dấu nút dung lượng
            document.querySelectorAll('.variant-capacity-btn').forEach(btn => {
                if (btn.getAttribute('data-capacity') === first.capacity) {
                    btn.classList.add('active');
                }
            });

            // Đánh dấu nút màu sắc
            document.querySelectorAll('.variant-color-btn').forEach(btn => {
                if (btn.getAttribute('data-color') === first.color) {
                    btn.classList.add('active');
                }
            });

            // Gán sẵn VariantId hidden + giá hiển thị
            const hidden = document.getElementById('SelectedVariantId');
            if (hidden) hidden.value = first.id;

            // 👉 Gán cho Wishlist luôn
            const wishlistHidden = document.getElementById('WishlistVariantId');
            if (wishlistHidden) wishlistHidden.value = first.id;

            const priceEl = document.getElementById('displayPrice');
            if (priceEl) {
                priceEl.textContent =
                    first.discountedPrice.toLocaleString('vi-VN') + ' VNĐ';
            }
        }

        function updateSelectedVariant() {
            if (!hasVariants) return;

            const variant = variants.find(v =>
                (!selectedCapacity || v.capacity === selectedCapacity) &&
                (!selectedColor || v.color === selectedColor)
            );
            if (!variant) return;

            // Hidden VariantId để AddToCart
            const hidden = document.getElementById('SelectedVariantId');
            if (hidden) hidden.value = variant.id;

            // Hidden VariantId để Wishlist
            const wishlistHidden = document.getElementById('WishlistVariantId');
            if (wishlistHidden) wishlistHidden.value = variant.id;

            // Cập nhật GIÁ
            const priceEl = document.getElementById('displayPrice');
            if (priceEl) {
                priceEl.textContent =
                    variant.discountedPrice.toLocaleString('vi-VN') + ' VNĐ';
            }

            // 🔹 Cập nhật "Dung lượng lưu trữ"
            const storageEl = document.getElementById('specStorage');
            if (storageEl) {
                storageEl.textContent = variant.storage || variant.capacity || '';
            }

            // 🔹 Cập nhật "Dung lượng còn lại (khả dụng)"
            const storageAvailEl = document.getElementById('specStorageAvailable');
            if (storageAvailEl) {
                storageAvailEl.textContent = variant.storageAvailable || '';
            }
        }

        // click dung lượng
        document.querySelectorAll('.variant-capacity-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                selectedCapacity = this.getAttribute('data-capacity');
                document.querySelectorAll('.variant-capacity-btn')
                    .forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                updateSelectedVariant();
            });
        });

        // click màu sắc
        document.querySelectorAll('.variant-color-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                selectedColor = this.getAttribute('data-color');
                document.querySelectorAll('.variant-color-btn')
                    .forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                updateSelectedVariant();
            });
        });
    });
</script>

<!-- Rating stars -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const stars = document.querySelectorAll('.rating-select input[type="radio"]');
        const starLabels = document.querySelectorAll('.rating-select .star-label');

        function updateStars(value) {
            starLabels.forEach((lbl, idx) => {
                if ((starLabels.length - idx) <= value) {
                    lbl.classList.add('selected');
                } else {
                    lbl.classList.remove('selected');
                }
            });
        }

        let checked = document.querySelector('.rating-select input[type="radio"]:checked');
        if (checked) updateStars(Number(checked.value));

        stars.forEach((star, idx) => {
            star.addEventListener('change', function () {
                updateStars(Number(star.value));
            });
            starLabels[idx].addEventListener('mouseenter', function () {
                updateStars(starLabels.length - idx);
            });
            starLabels[idx].addEventListener('mouseleave', function () {
                let checked = document.querySelector('.rating-select input[type="radio"]:checked');
                updateStars(checked ? Number(checked.value) : 0);
            });
        });
    });
</script>

<script>
    // Cập nhật số lượng cart badge trên header
    function updateCartCount() {
        fetch('/ShoppingCart/GetCartCount')
            .then(res => res.json())
            .then(data => {
                var el = document.getElementById('cartCount');
                if (el) el.innerText = data.count;
            });
    }

    // Popup trung tâm
    function showPopup(message, time = 1600) {
        var popup = document.getElementById('custom-popup-success');
        var msg = document.getElementById('custom-popup-message');
        msg.innerHTML = message;
        popup.style.display = 'flex';
        setTimeout(function () {
            popup.style.display = 'none';
        }, time);
    }

    // Thêm vào giỏ hàng AJAX
    document.getElementById('addToCartForm')?.addEventListener('submit', function (e) {
        e.preventDefault();

        // Nếu sản phẩm có nhiều biến thể -> bắt buộc chọn
        if (window.hasProductVariants) {
            const variantId = document.getElementById('SelectedVariantId')?.value;
            if (!variantId) {
                alert('Vui lòng chọn dung lượng và màu sắc trước khi thêm vào giỏ.');
                return;
            }
        }

        var form = this;
        var formData = new FormData(form);
        fetch(form.action, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: formData
        })
            .then(res => {
                if (res.ok) {
                    showPopup('Sản phẩm đã được thêm vào giỏ hàng!');
                    updateCartCount();
                } else {
                    showPopup('Có lỗi khi thêm vào giỏ hàng!', 2000);
                }
            })
            .catch(err => showPopup('Lỗi mạng!', 2000));
    });

    // Yêu thích AJAX
    document.getElementById('addToWishlistForm')?.addEventListener('submit', function (e) {
        e.preventDefault();
        var form = this;
        var formData = new FormData(form);
        fetch(form.action, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: formData
        })
            .then(res => {
                if (res.ok) {
                    showPopup('Đã thêm vào danh sách yêu thích!');
                } else {
                    showPopup('Có lỗi khi thêm vào yêu thích!', 2000);
                }
            })
            .catch(err => showPopup('Lỗi mạng!', 2000));
    });
</script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const btnCompare = document.getElementById('btnCompare');
        if (!btnCompare) return;

        btnCompare.addEventListener('click', function () {
            // base url: /Compare/Add
            var baseUrl = '@Url.Action("Add", "Compare")';
            var productId = '@Model.Id';
            var url = baseUrl + '?productId=' + productId;

            // Nếu có biến thể thì bắt buộc lấy variantId
            if (window.hasProductVariants) {
                var variantId = document.getElementById('SelectedVariantId')?.value;
                if (!variantId) {
                    alert('Vui lòng chọn dung lượng và màu sắc trước khi so sánh.');
                    return;
                }
                url += '&variantId=' + encodeURIComponent(variantId);
            }

            // Điều hướng sang /Compare/Add
            window.location.href = url;
        });
    });
</script>
