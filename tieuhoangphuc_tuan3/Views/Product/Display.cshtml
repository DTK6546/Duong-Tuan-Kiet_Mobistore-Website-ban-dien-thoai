    }

    .tgdd-gallery {
        background: #fff;
    }

    .tgdd-thumb-list {
        gap: 6px;
        overflow-x: auto;
    }

    .tgdd-thumb {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid #ddd;
        cursor: pointer;
        transition: all 0.15s;
        background: #fff;
        margin-right: 4px;
        margin-bottom: 4px;
    }

        .tgdd-thumb.active {
            border: 2px solid #0d6efd;
            box-shadow: 0 0 0 2px rgba(13,110,253,.25);
        }

        .tgdd-thumb:hover {
            transform: translateY(-1px);
        }

    .variant-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        border-radius: 999px;
        border: 1px solid #ddd;
        background: #fff;
        padding: 6px 14px;
        font-size: 0.9rem;
        min-width: 72px;
        cursor: pointer;
        margin-right: 6px;
        margin-bottom: 6px;
        transition: all 0.15s ease-in-out;
        outline: none;
        color: #333;
        white-space: nowrap;
    }

        .variant-pill:hover {
            border-color: #2f80ed;
            color: #2f80ed;
            background: rgba(47, 128, 237, 0.03);
        }

        .variant-pill.active {
            border-color: #2f80ed;
            color: #2f80ed;
            background: rgba(47, 128, 237, 0.08);
            box-shadow: 0 0 0 1px rgba(47, 128, 237, 0.25);
