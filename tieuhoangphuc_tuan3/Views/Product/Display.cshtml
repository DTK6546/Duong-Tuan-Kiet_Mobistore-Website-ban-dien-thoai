@using System.Text.Json
@model WebBanDienThoai.Models.ProductWithSoldCount
@using WebBanDienThoai.Models
@using System.Collections.Generic
@using System.Linq
@using System.Globalization

@{
    var vi = CultureInfo.GetCultureInfo("vi-VN");

    ViewData["Title"] = "Chi Tiết Sản Phẩm";

    var ratings = ViewBag.Ratings as List<WebBanDienThoai.Models.ProductRating> ?? new List<WebBanDienThoai.Models.ProductRating>();
    double avg = (double)(ViewBag.AvgStars ?? 0.0);
    var starDistribution = ViewBag.StarCounts as List<int> ?? new List<int> { 0, 0, 0, 0, 0 };

    int fullStars = (int)Math.Floor(avg);
    bool hasHalf = avg - fullStars >= 0.5;

    // 🔹 Biến thể (màu / dung lượng)
    var variants = ViewBag.Variants as List<ProductVariant> ?? new List<ProductVariant>();
    bool hasVariants = variants.Any();

    var variantDtos = variants.Select(v => new
    {
        id = v.Id,
        color = v.Color,
        capacity = v.Capacity,
        discountedPrice = v.DiscountedPrice,
        stock = v.Stock,
        storage = v.Storage,
        storageAvailable = v.StorageAvailable,
        sku = v.Sku,
        imageUrl = v.ImageUrl
    }).ToList();

    var defaultVariantPrice = hasVariants
        ? variants.First().DiscountedPrice
        : Model.DiscountedPrice;

    // 🔹 Gallery: gom ảnh chính + ảnh phụ
    var galleryId = $"productGallery_{Model.Id}";
    var media = new List<string>();

    if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        media.Add(Model.ImageUrl);
    }

    if (Model.Images != null)
    {
        foreach (var img in Model.Images)
        {
            if (!string.IsNullOrEmpty(img.Url))
            {
                media.Add(img.Url);
            }
        }
    }

    var promoCoupons = ViewBag.PromoCoupons as List<Coupon> ?? new List<Coupon>();

    // Review paging
    int ratingPage = ViewBag.RatingPage ?? 1;
    int ratingTotalPages = ViewBag.RatingTotalPages ?? 1;

    int? filterStar = ViewBag.FilterStar as int?;
    bool filterHasImages = ViewBag.FilterHasImages == true;
    bool filterVerifiedOnly = ViewBag.FilterVerifiedOnly == true;
    string filterSort = ViewBag.FilterSort as string ?? "new";

    bool canReview = ViewBag.CanReview == true;
}

<script>
    window.hasProductVariants = @hasVariants.ToString().ToLower();
</script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    .btn-cart {
