        display: flex;
        align-items: center;
        flex-direction: column;
        animation: popscale .2s;
        min-width: 300px;
    }

    @@keyframes popscale {
        0% {
            transform: scale(0.7);
        }

        100% {
            transform: scale(1);
        }
    }

    .custom-popup-icon {
        font-size: 48px;
        color: #27c93f;
        margin-bottom: 12px;
    }

    #custom-popup-message {
        font-size: 1.15rem;
        font-weight: 500;
