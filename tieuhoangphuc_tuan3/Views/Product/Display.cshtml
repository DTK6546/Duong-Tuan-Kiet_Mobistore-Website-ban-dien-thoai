    }

    .custom-popup {
        position: fixed;
        z-index: 9999;
        left: 0;
        right: 0;
        top: 0;
        bottom: 0;
        background: rgba(0,0,0,0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
    }

    .custom-popup-content {
        background: #fff;
        padding: 32px 48px;
        border-radius: 14px;
