@model IEnumerable<WebBanDienThoai.Models.Wishlist>
@{
    ViewData["Title"] = "Danh sách yêu thích được chia sẻ";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <span class="badge bg-info text-dark mb-2 px-3 py-2 rounded-pill fw-bold text-uppercase">MobiStore Wishlist Sharing</span>
        <h2 class="fw-bold">🎁 Danh sách sản phẩm yêu thích của @ViewData["OwnerName"]</h2>
        <p class="text-muted">Khám phá các siêu phẩm công nghệ được lựa chọn và lưu trữ bởi bạn bè của bạn.</p>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 shadow-sm bg-white rounded-3">
            <i class="bi bi-heartbreak text-secondary" style="font-size: 60px;"></i>
            <h4 class="mt-3 text-muted">Danh sách này hiện tại không có sản phẩm nào.</h4>
            <a href="/" class="btn btn-primary mt-3 rounded-pill px-4">Quay lại Trang Chủ</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var item in Model)
            {
                if (item.Product != null)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden position-relative" style="transition: 0.3s;">
                            <img src="@item.Product.ImageUrl" class="card-img-top p-3" alt="@item.Product.Name" style="height: 200px; object-fit: contain;">

                            <div class="card-body d-flex flex-column justify-content-between">
                                <div>
                                    <h6 class="card-title fw-bold text-dark text-truncate-2">@item.Product.Name</h6>
                                    <p class="card-text text-danger fw-bold mb-2">@item.Product.Price.ToString("#,##0") VNĐ</p>
                                </div>

                                <a href="/Product/Details/@item.Product.Id" class="btn btn-outline-primary btn-sm w-100 rounded-pill mt-2fw-bold">
                                    <i class="bi bi-eye"></i> Xem Chi Tiết
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>