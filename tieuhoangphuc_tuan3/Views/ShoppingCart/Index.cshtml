@using WebBanDienThoai.Models
@model WebBanDienThoai.Models.ShoppingCart
@using System.Globalization

@if (TempData["PaymentError"] != null)
{
    <div class="alert alert-danger" id="paymentError">
        @TempData["PaymentError"]
    </div>

    <script>
        setTimeout(function () {
            var errorMessage = document.getElementById("paymentError");
            if (errorMessage) {
                errorMessage.style.display = "none";
            }
        }, 3000);
    </script>
}

@{
    ViewData["Title"] = "Giỏ hàng của bạn";

    decimal subtotal = Model.Items.Sum(i =>
    {
        var warrantyPerItem = i.Warranties?.Sum(w => w.Price) ?? 0;
        return (i.Price + warrantyPerItem) * i.Quantity;
    });

    decimal discount = Model.DiscountAmount;
    if (discount < 0) { discount = 0; }

    decimal priceAfterDiscount = subtotal - discount;
    if (priceAfterDiscount < 0) { priceAfterDiscount = 0; }

    decimal vatRate = 0.10m;
    decimal vatAmount = Math.Round(priceAfterDiscount * vatRate, 0);

    decimal shippingFee = 0;
    decimal finalTotal = priceAfterDiscount + vatAmount + shippingFee;

    var vi = CultureInfo.GetCultureInfo("vi-VN");
}

@{
    var stores = ViewBag.Stores as List<Store>;
}

<div class="container mt-5">
    <h2 class="text-center mb-4">🛒 Giỏ hàng của bạn</h2>

    @if (Model.Items.Count == 0)
    {
        <p class="text-center text-muted">Giỏ hàng của bạn đang trống! 🛍️</p>
    }
    else
    {
        <div class="row">
            <!-- CỘT TRÁI -->
            <div class="col-md-8">
                <table class="table table-bordered align-middle text-center">
                    <thead class="table-dark">
                        <tr>
                            <th>Hình ảnh</th>
                            <th style="width: 40%">Tên sản phẩm</th>
                            <th>Giá</th>
                            <th>Số lượng</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            var warrantyPerItem = item.Warranties?.Sum(w => w.Price) ?? 0;

                            <tr>
                                <td class="align-middle">
                                    <img src="@item.ImageUrl" alt="@item.Name" class="cart-image img-fluid" style="width: 80px; height: 80px; object-fit: contain;">
                                </td>
                                <td class="align-middle text-start">
                                    <strong>@item.Name</strong>
                                    <p class="text-muted m-0">Mã SP: @item.ProductId</p>

                                    @{
                                        var allWarrantyOptions = ViewBag.WarrantyOptions as List<WarrantyOption>;
                                        var optionsForProduct = allWarrantyOptions?
                                        .Where(w => w.ProductId == item.ProductId && w.IsActive)
                                        .ToList();

                                        var selectedIds = item.Warranties?
                                        .Select(w => w.WarrantyOptionId)
                                        .ToHashSet()
                                        ?? new HashSet<int>();
                                    }

                                    @if (optionsForProduct != null && optionsForProduct.Any())
                                    {
                                        <div class="mt-2 p-2 border rounded bg-white">
                                            <form asp-action="UpdateWarranties"
                                                  asp-controller="ShoppingCart"
                                                  method="post">
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <input type="hidden" name="variantId" value="@(item.VariantId?.ToString() ?? "")" />

                                                <div class="small fw-semibold mb-1">Gói bảo hành thêm:</div>

                                                @foreach (var w in optionsForProduct)
                                                {
                                                    var checkId = $"w_{item.ProductId}_{w.Id}";
                                                    var isChecked = selectedIds.Contains(w.Id);
                                                    <div class="form-check small">
                                                        <input class="form-check-input"
                                                               type="checkbox"
                                                               name="warrantyOptionIds"
                                                               value="@w.Id"
                                                               id="@checkId"
                                                               @(isChecked ? "checked" : "")
                                                               onchange="this.form.submit()" />
                                                        <label class="form-check-label" for="@checkId">
                                                            @w.Name (@w.Price.ToString("N0", vi) VNĐ)
                                                        </label>
                                                    </div>
                                                }

                                                @if (item.Warranties != null && item.Warranties.Any())
                                                {
                                                    <div class="small text-success mt-1">
                                                        Đã chọn:
                                                        @string.Join(", ", item.Warranties.Select(w => w.Name))
                                                        (tổng +@warrantyPerItem.ToString("N0", vi) VNĐ / sản phẩm)
                                                    </div>
                                                }
                                            </form>
                                        </div>
                                    }
                                </td>
                                <td class="align-middle">
                                    @item.Price.ToString("N0", vi) VNĐ
                                    @if (warrantyPerItem > 0)
                                    {
                                        <div class="small text-muted">
                                            + @warrantyPerItem.ToString("N0", vi) VNĐ (bảo hành)
                                        </div>
                                    }
                                </td>
                                <td class="align-middle">
                                    <div class="input-group input-group-sm">
                                        <button class="btn btn-outline-secondary btn-sm quantity-btn" type="button">-</button>

                                        <input type="text"
                                               class="form-control text-center quantity-input"
                                               value="@item.Quantity"
                                               data-unit-price="@item.Price"
                                               data-warranty-price="@warrantyPerItem"
                                               data-max-qty="@item.AvailableStock"
                                               style="max-width: 50px;">

                                        <button class="btn btn-outline-secondary btn-sm quantity-btn" type="button">+</button>
                                    </div>

                                    @{
                                        var remaining = item.AvailableStock - item.Quantity;
                                    }

                                    @if (item.AvailableStock <= 0)
                                    {
                                        <div class="text-danger small mt-1">Hết hàng.</div>
                                    }
                                    else if (remaining <= 0)
                                    {
                                        <div class="text-danger small mt-1">Bạn đã chọn tối đa (@item.AvailableStock).</div>
                                    }
                                    else if (remaining <= 3)
                                    {
                                        <div class="text-warning small mt-1">Chỉ còn @remaining sản phẩm.</div>
                                    }
                                    else
                                    {
                                        <div class="text-muted small mt-1">Còn @item.AvailableStock sản phẩm.</div>
                                    }
                                </td>

                                <td class="align-middle">
                                    <a asp-action="RemoveFromCart"
                                       asp-route-productId="@item.ProductId"
                                       asp-route-variantId="@item.VariantId"
                                       class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <!-- GỢI Ý SẢN PHẨM -->
                <div class="mt-5">
                    <h4 class="fw-semibold mb-3">
                        <i class="bi bi-star-half text-warning"></i> Có thể bạn cũng thích
                    </h4>
                    <div class="row flex-nowrap overflow-auto pb-2" style="gap:24px;">
                        @foreach (var p in ViewBag.SuggestedProducts as List<Product>)
                        {
                            <div class="col-auto" style="min-width: 210px;">
                                <div class="card border-0 shadow-sm h-100">
                                    <a href="@Url.Action("Display", "Product", new { id = p.Id })">
                                        <img src="@p.ImageUrl" class="card-img-top" style="height:120px;object-fit:contain">
                                    </a>
                                    <div class="card-body p-2 text-center">
                                        <div class="fw-semibold small mb-1" style="min-height:38px;">@p.Name</div>
                                        <div class="text-danger fw-bold mb-2">@p.Price.ToString("N0", vi) đ</div>
                                        <a href="@Url.Action("Display", "Product", new { id = p.Id })"
                                           class="btn btn-sm btn-outline-danger rounded-pill">
                                            Xem chi tiết
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                        <div class="col-auto d-flex align-items-center">
                            <a href="/Product" class="btn btn-warning rounded-pill ms-2">Xem tất cả &gt;</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CỘT PHẢI -->
            <div class="col-md-4">
                @{
                    var currentUser = ViewBag.CurrentUser as ApplicationUser;
                }

                <div class="card shadow-sm p-3">
                    <!-- THÔNG TIN NGƯỜI MUA -->
                    <h6 class="border-bottom pb-2 mb-2">Thông tin người mua</h6>

                    @if (currentUser != null)
                    {
                        <p class="mb-1 small">
                            <strong>Trạng thái:</strong>
                            <span class="text-success">Đã đăng nhập (@currentUser.UserName)</span>
                        </p>
                        <p class="mb-1 small"><strong>Họ tên:</strong> @currentUser.FullName</p>
                        <p class="mb-2 small"><strong>SĐT:</strong> @currentUser.PhoneNumber</p>
                        <p class="mb-2 small"><strong>Địa chỉ:</strong> @currentUser.Address</p>
                        <a asp-area="Identity"
                           asp-page="/Account/Manage/Index"
                           class="small">
                            Chỉnh sửa thông tin giao hàng
                        </a>
                    }
                    else
                    {
                        <div class="alert alert-info small mb-2">
                            <p class="mb-1">
                                <strong>Trạng thái:</strong> Bạn chưa đăng nhập.
                            </p>
                            <p class="mb-0">
                                <a asp-area="Identity" asp-page="/Account/Login">Đăng nhập ngay</a>
                                để hệ thống tự động điền thông tin người mua và giao hàng.
                            </p>
                        </div>
                    }

                    <!-- PHƯƠNG THỨC NHẬN HÀNG -->
                    <h6 class="border-bottom pb-2 mt-3 mb-2">Phương thức nhận hàng</h6>

                    <div class="small">
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="radio"
                                   name="DeliveryMethod"
                                   value="ShipToHome"
                                   id="shipHome"
                                   checked />
                            <label class="form-check-label" for="shipHome">
                                Giao hàng tận nơi
                            </label>
                        </div>

                        <div class="form-check mt-2">
                            <input class="form-check-input"
                                   type="radio"
                                   name="DeliveryMethod"
                                   value="PickupAtStore"
                                   id="pickupStore" />
                            <label class="form-check-label" for="pickupStore">
                                Nhận tại cửa hàng
                            </label>
                        </div>

                        <!-- ✅ PANEL SHIP -->
                        <div id="shippingPanel" class="mt-3 border rounded p-2">
                            <div class="fw-semibold mb-2">
                                <i class="bi bi-truck me-1"></i> Giao đến
                            </div>

                            <div class="row g-2">
                                <div class="col-12">
                                    <select class="form-select form-select-sm" id="shipProvince">
                                        <option value="">-- Chọn Tỉnh/TP --</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <select class="form-select form-select-sm" id="shipDistrict" disabled>
                                        <option value="">-- Chọn Quận/Huyện (hoặc để Toàn tỉnh) --</option>
                                    </select>
                                </div>
                            </div>

                            <!-- ✅ thêm phương thức giao -->
                            <div class="mt-2">
                                <label class="small fw-semibold mb-1">Phương thức</label>
                                <select id="shipMethodSelect" class="form-select form-select-sm">
                                    <option value="standard" selected>Tiêu chuẩn</option>
                                    <option value="express">Nhanh</option>
                                </select>
                            </div>

                            <div class="mt-2 small">
                                <div>Phí ship: <b id="shipFee">—</b></div>
                                <div>Giao dự kiến: <b id="shipEta">—</b></div>
                            </div>

                            <small class="text-muted d-block mt-1">
                                Hệ thống sẽ nhớ lựa chọn Tỉnh/Quận cho lần sau.
                            </small>

                            <small class="text-muted d-block">
                                <span class="fw-semibold">Chính sách:</span> Miễn phí ship theo điều kiện • Cho kiểm tra hàng khi nhận (tuỳ shop) • Đổi trả theo quy định.
                            </small>
                        </div>

                        <!-- PANEL PICKUP -->
                        <div id="storePanel" class="mt-3 border rounded p-2 d-none">
                            <label for="StoreId" class="form-label mb-1">Chọn cửa hàng</label>
                            <select name="StoreId" id="StoreId" class="form-control form-control-sm">
                                <option value="">-- Chọn cửa hàng --</option>
                                @if (stores != null)
                                {
                                    foreach (var s in stores)
                                    {
                                        <option value="@s.Id">@s.Name</option>
                                    }
                                }
                            </select>
                            <small class="text-muted d-block mt-1">
                                Nhận tại cửa hàng thì phí ship = 0.
                            </small>
                        </div>
                    </div>

                    <!-- TÓM TẮT ĐƠN HÀNG -->
                    <h6 class="border-bottom pb-2 mt-3 mb-2">Tóm tắt đơn hàng</h6>

                    @if (TempData["CouponSuccess"] != null)
                    {
                        <div class="alert alert-success py-1 mb-2 small">
                            @TempData["CouponSuccess"]
                        </div>
                    }
                    @if (TempData["CouponError"] != null)
                    {
                        <div class="alert alert-danger py-1 mb-2 small">
                            @TempData["CouponError"]
                        </div>
                    }

                    <form id="ApplyCouponForm"
                          asp-action="ApplyCoupon"
                          asp-controller="ShoppingCart"
                          method="post"
                          class="mb-3">
                        <label class="form-label mb-1 small">Mã giảm giá</label>
                        <div class="input-group input-group-sm">
                            <input type="text"
                                   id="CouponCodeInput"
                                   name="couponCode"
                                   class="form-control"
                                   placeholder="Nhập mã (VD: SALE50)"
                                   value="@(Model.CouponCode ?? string.Empty)" />
                            <button type="submit" class="btn btn-outline-success">
                                Áp dụng
                            </button>
                        </div>
                        <small class="text-muted">
                            Nếu thay đổi số lượng sau khi áp mã, hãy áp lại mã để đảm bảo số tiền chính xác.
                        </small>
                    </form>

                    @if (ViewBag.AvailableCoupons != null && (ViewBag.AvailableCoupons as List<Coupon>)?.Any() == true)
                    {
                        <div class="mt-2 mb-2">
                            <strong class="small">Các mã bạn có thể dùng:</strong>
                            <div class="list-group mt-2">
                                @foreach (var c in ViewBag.AvailableCoupons as List<Coupon>)
                                {
                                    var remain = c.Quantity - c.CurrentUsage;
                                    <button type="button"
                                            class="list-group-item list-group-item-action coupon-btn py-2"
                                            data-code="@c.Code">
                                        <div class="d-flex justify-content-between">
                                            <div class="small">
                                                <strong>@c.Code</strong> -
                                                @(c.DiscountPercent > 0 ? $"{c.DiscountPercent}%" : $"{c.DiscountAmount.GetValueOrDefault().ToString("N0", vi)} VNĐ")
                                                <div class="text-muted" style="font-size: 12px;">
                                                    Đơn tối thiểu: @c.MinOrderValue.ToString("N0", vi) •
                                                    Còn: @(remain > 0 ? remain : 0) lượt •
                                                    @c.StartDate.ToString("dd/MM") - @c.EndDate.ToString("dd/MM")
                                                </div>
                                            </div>
                                            <span class="badge bg-primary align-self-start">Chọn</span>
                                        </div>
                                    </button>
                                }
                            </div>
                        </div>
                    }
                    else if (currentUser != null)
                    {
                        <div class="mt-2 mb-2 small text-muted">
                            Bạn chưa nhập mã giảm giá. Hãy vào mục
                            <a href="/News">Tin tức</a> để nhập mã khuyến mãi cho tài khoản của bạn.
                        </div>
                    }

                    <div class="d-flex justify-content-between small">
                        <span>Tạm tính</span>
                        <strong class="subtotal-amount">@subtotal.ToString("N0") VNĐ</strong>
                    </div>

                    <div class="d-flex justify-content-between small">
                        <span>Giảm giá</span>
                        <strong class="discount-amount">
                            @if (discount > 0)
                            {
                                @("-" + discount.ToString("N0") + " VNĐ")
                            }
                            else
                            {
                                @("0 VNĐ")
                            }
                        </strong>
                    </div>

                    <div class="d-flex justify-content-between small">
                        <span>Thành tiền (chưa VAT)</span>
                        <strong class="before-tax-amount">@priceAfterDiscount.ToString("N0") VNĐ</strong>
                    </div>

                    <div class="d-flex justify-content-between small">
                        <span>VAT (10%)</span>
                        <strong class="vat-amount">@vatAmount.ToString("N0") VNĐ</strong>
                    </div>

                    <div class="d-flex justify-content-between small">
                        <span>Phí vận chuyển</span>
                        <strong class="ship-fee-amount">0 VNĐ</strong>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between small mb-2">
                        <span><strong>Tổng cộng</strong></span>
                        <strong class="final-total">@finalTotal.ToString("N0") VNĐ</strong>
                    </div>

                    <!-- MoMo -->
                    <form method="POST" asp-action="CreatePaymentMomo" asp-controller="Payment" class="mt-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Amount" class="payment-amount" value="@finalTotal" />
                        <input type="hidden" name="OrderId" value="@Guid.NewGuid().ToString()" />
                        <input type="hidden" name="OrderInfo" value="Thanh toan Momo cho don hang tai WebBanDienThoai" />
                        <input type="hidden" name="FullName" value="@User.Identity.Name" />

                        <!-- ✅ ship info -->
                        <input type="hidden" name="deliveryMethod" id="momoDeliveryMethod" />
                        <input type="hidden" name="storeId" id="momoStoreId" />

                        <input type="hidden" name="provinceCode" id="momoProvince" />
                        <input type="hidden" name="districtCode" id="momoDistrict" />
                        <input type="hidden" name="shippingFee" id="momoShipFee" />
                        <input type="hidden" name="shipMethod" id="momoShipMethod" />

                        <!-- ✅ pass address/notes -->
                        <input type="hidden" name="ShippingAddress" id="momoAddress" />
                        <input type="hidden" name="Notes" id="momoNotes" />

                        <button class="btn btn-danger w-100 btn-sm" type="submit">
                            🚀 Tiến hành thanh toán Momo
                        </button>
                    </form>

                    <!-- VNPay -->
                    <form method="POST"
                          asp-action="PaymentVNPay"
                          asp-controller="Payment"
                          class="mt-2"
                          id="vnpayForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="amount" class="payment-amount" value="@finalTotal" />

                        <input type="hidden" name="deliveryMethod" id="vnpDeliveryMethod" />
                        <input type="hidden" name="storeId" id="vnpStoreId" />

                        <input type="hidden" name="provinceCode" id="vnpProvince" />
                        <input type="hidden" name="districtCode" id="vnpDistrict" />
                        <input type="hidden" name="shippingFee" id="vnpShipFee" />
                        <input type="hidden" name="shipMethod" id="vnpShipMethod" />

                        <!-- ✅ pass address/notes -->
                        <input type="hidden" name="ShippingAddress" id="vnpAddress" />
                        <input type="hidden" name="Notes" id="vnpNotes" />

                        <button class="btn btn-primary w-100 btn-sm" type="button" onclick="submitVNPay()">
                            🏦 Thanh toán bằng VNPay
                        </button>
                    </form>

                    <!-- PayPal -->
                    <a id="paypalBtn"
                       href="@Url.Action("Paypal", "Payment", new { amount = finalTotal })"
                       class="btn btn-warning w-100 btn-sm mt-2">
                        💰 Thanh toán bằng PayPal
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // discount cố định từ server
        var discountFromServer = @discount;

        const paypalBaseUrl = '@Url.Action("Paypal", "Payment")';

        // ====== GLOBAL: Shipping ======
        let currentShippingFee = 0;
        let currentProvinceCode = "";
        let currentDistrictCode = "";
        let currentShipMethod = "standard";

        const LS_PROV = "ship_province_code";
        const LS_DIST = "ship_district_code";
        const LS_METHOD = "ship_method";

        function computeSubtotal() {
            let subtotal = 0;
            document.querySelectorAll(".quantity-input").forEach(input => {
                const quantity = parseInt(input.value, 10) || 0;
                const unitPrice = parseFloat(input.getAttribute("data-unit-price")) || 0;
                const warrantyPrice = parseFloat(input.getAttribute("data-warranty-price")) || 0;
                subtotal += quantity * (unitPrice + warrantyPrice);
            });
            return subtotal;
        }

        function setShipUI(fee, etaText) {
            const feeEl = document.getElementById("shipFee");
            const etaEl = document.getElementById("shipEta");
            if (feeEl) feeEl.textContent = (fee ?? 0).toLocaleString('vi-VN') + " VNĐ";
            if (etaEl) etaEl.textContent = etaText || "—";
        }

        function saveShipSelection() {
            localStorage.setItem(LS_PROV, currentProvinceCode || "");
            localStorage.setItem(LS_DIST, currentDistrictCode || "");
            localStorage.setItem(LS_METHOD, currentShipMethod || "standard");
        }

        function loadShipSelection() {
            return {
                prov: localStorage.getItem(LS_PROV) || "",
                dist: localStorage.getItem(LS_DIST) || "",
                method: localStorage.getItem(LS_METHOD) || "standard"
            };
        }

        async function fetchJson(url) {
            const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            if (!res.ok) throw new Error("HTTP " + res.status);
            return await res.json();
        }

        async function loadProvinces(selectedCode) {
            const provSel = document.getElementById("shipProvince");
            if (!provSel) return;

            provSel.innerHTML = `<option value="">-- Chọn Tỉnh/TP --</option>`;

            const list = await fetchJson("/Shipping/Provinces");
            list.forEach(p => {
                const opt = document.createElement("option");
                opt.value = p.code;
                opt.textContent = p.name + ` (${p.code})`;
                if (selectedCode && selectedCode === p.code) opt.selected = true;
                provSel.appendChild(opt);
            });
        }

        async function loadDistricts(provinceCode, selectedDistrict) {
            const distSel = document.getElementById("shipDistrict");
            if (!distSel) return;

            distSel.innerHTML = `<option value="">-- Chọn Quận/Huyện (hoặc để Toàn tỉnh) --</option>`;
            distSel.disabled = true;

            if (!provinceCode) return;

            const list = await fetchJson(`/Shipping/Districts?provinceCode=${encodeURIComponent(provinceCode)}`);
            list.forEach(d => {
                const opt = document.createElement("option");
                opt.value = d.code;
                opt.textContent = d.name + ` (${d.code})`;
                if (selectedDistrict && selectedDistrict === d.code) opt.selected = true;
                distSel.appendChild(opt);
            });

            distSel.disabled = false;
        }

        async function quoteShipping(provinceCode, districtCode) {
            if (!provinceCode) {
                currentShippingFee = 0;
                setShipUI(null, "—");
                updateTotal();
                return;
            }

            const orderValueAfterDiscount = Math.max(0, computeSubtotal() - (discountFromServer || 0));

            const q = new URLSearchParams();
            q.set("provinceCode", provinceCode);
            if (districtCode) q.set("districtCode", districtCode);

            q.set("method", currentShipMethod || "standard");
            q.set("orderValue", orderValueAfterDiscount);

            const data = await fetchJson(`/Shipping/Quote?${q.toString()}`);

            if (data && data.ok === false) {
                currentShippingFee = 0;
                setShipUI(0, data.message || "—");
                updateTotal();
                return;
            }

            const fee = Number(data.fee || 0);
            currentShippingFee = fee;

            let etaText = "—";
            if (data.etaFrom && data.etaTo) {
                etaText = `${data.etaFrom} - ${data.etaTo}`;
            } else if (data.minDays != null && data.maxDays != null) {
                etaText = (data.minDays === 0 && data.maxDays === 0)
                    ? "—"
                    : `${data.minDays}-${data.maxDays} ngày`;
            }

            setShipUI(fee, etaText);
            updateTotal();
        }

        // ====== Toggle panels ======
        function togglePanels() {
            var method = document.querySelector("input[name='DeliveryMethod']:checked");
            var storePanel = document.getElementById("storePanel");
            var shipPanel = document.getElementById("shippingPanel");

            if (!method) return;

            if (method.value === "PickupAtStore") {
                if (storePanel) storePanel.classList.remove("d-none");
                if (shipPanel) shipPanel.classList.add("d-none");

                currentShippingFee = 0;
                updateTotal();
            } else {
                if (storePanel) storePanel.classList.add("d-none");
                if (shipPanel) shipPanel.classList.remove("d-none");

                if (currentProvinceCode) {
                    quoteShipping(currentProvinceCode, currentDistrictCode);
                } else {
                    currentShippingFee = 0;
                    updateTotal();
                }
            }
        }

        // ====== Tổng tiền ======
        function updateTotal() {
            const subtotal = computeSubtotal();

            const subtotalElement = document.querySelector(".subtotal-amount");
            if (subtotalElement) subtotalElement.textContent = subtotal.toLocaleString('vi-VN') + ' VNĐ';

            let priceAfterDiscount = subtotal - (discountFromServer || 0);
            if (priceAfterDiscount < 0) priceAfterDiscount = 0;

            let vatAmount = Math.round(priceAfterDiscount * 0.10);

            const methodEl = document.querySelector("input[name='DeliveryMethod']:checked");
            const method = methodEl ? methodEl.value : "ShipToHome";
            const shipFee = (method === "ShipToHome") ? (currentShippingFee || 0) : 0;

            let total = priceAfterDiscount + vatAmount + shipFee;

            const beforeTaxElement = document.querySelector(".before-tax-amount");
            if (beforeTaxElement) beforeTaxElement.textContent = priceAfterDiscount.toLocaleString('vi-VN') + ' VNĐ';

            const vatElement = document.querySelector(".vat-amount");
            if (vatElement) vatElement.textContent = vatAmount.toLocaleString('vi-VN') + ' VNĐ';

            const shipEl = document.querySelector(".ship-fee-amount");
            if (shipEl) shipEl.textContent = shipFee.toLocaleString('vi-VN') + ' VNĐ';

            const finalTotalElement = document.querySelector(".final-total");
            if (finalTotalElement) finalTotalElement.textContent = total.toLocaleString('vi-VN') + ' VNĐ';

            // update hidden Amount for payment forms
            document.querySelectorAll(".payment-amount").forEach(input => {
                input.value = total;
            });

            const prov = (method === "ShipToHome") ? (currentProvinceCode || "") : "";
            const dist = (method === "ShipToHome") ? (currentDistrictCode || "") : "";

            // VNPay hidden
            document.getElementById("vnpProvince") && (document.getElementById("vnpProvince").value = prov);
            document.getElementById("vnpDistrict") && (document.getElementById("vnpDistrict").value = dist);
            document.getElementById("vnpShipFee") && (document.getElementById("vnpShipFee").value = shipFee);
            document.getElementById("vnpShipMethod") && (document.getElementById("vnpShipMethod").value = currentShipMethod);

            // MoMo hidden
            document.getElementById("momoProvince") && (document.getElementById("momoProvince").value = prov);
            document.getElementById("momoDistrict") && (document.getElementById("momoDistrict").value = dist);
            document.getElementById("momoShipFee") && (document.getElementById("momoShipFee").value = shipFee);
            document.getElementById("momoShipMethod") && (document.getElementById("momoShipMethod").value = currentShipMethod);

            // delivery method/store for momo
            document.getElementById("momoDeliveryMethod") && (document.getElementById("momoDeliveryMethod").value = method);
            const storeSelect = document.getElementById("StoreId");
            const storeId = storeSelect ? storeSelect.value : "";
            document.getElementById("momoStoreId") && (document.getElementById("momoStoreId").value = storeId);

            // vnp delivery/store
            document.getElementById("vnpDeliveryMethod") && (document.getElementById("vnpDeliveryMethod").value = method);
            document.getElementById("vnpStoreId") && (document.getElementById("vnpStoreId").value = storeId);

            // ✅ Update PayPal URL
            const paypalBtn = document.getElementById("paypalBtn");
            if (paypalBtn) {
                const url = new URL(paypalBaseUrl, window.location.origin);
                url.searchParams.set("amount", total);

                url.searchParams.set("deliveryMethod", method);
                if (storeId) url.searchParams.set("storeId", storeId);

                if (prov) url.searchParams.set("provinceCode", prov);
                if (dist) url.searchParams.set("districtCode", dist);
                url.searchParams.set("shippingFee", shipFee);

                url.searchParams.set("shipMethod", currentShipMethod);

                paypalBtn.href = url.toString();
            }
        }

        // ===== VNPay Submit =====
        function submitVNPay() {
            updateTotal();

            const form = document.getElementById("vnpayForm");
            if (form) form.submit();
        }
        window.submitVNPay = submitVNPay;

        document.addEventListener("DOMContentLoaded", async function () {
            // coupon quick pick
            document.querySelectorAll(".coupon-btn").forEach(btn => {
                btn.addEventListener("click", function () {
                    const code = this.getAttribute("data-code");
                    const input = document.getElementById("CouponCodeInput");
                    const form = document.getElementById("ApplyCouponForm");
                    if (input) input.value = code;
                    if (form) form.submit();
                });
            });

            // delivery method change
            document.querySelectorAll("input[name='DeliveryMethod']").forEach(function (el) {
                el.addEventListener("change", function () {
                    togglePanels();
                    updateTotal();
                });
            });

            // store change
            const storeSelect = document.getElementById("StoreId");
            if (storeSelect) {
                storeSelect.addEventListener("change", function () {
                    updateTotal();
                });
            }

            // qty +/- buttons
            document.querySelectorAll(".quantity-btn").forEach(button => {
                button.addEventListener("click", function () {
                    let input = this.parentElement.querySelector(".quantity-input");
                    let value = parseInt(input.value, 10) || 0;
                    const maxQty = parseInt(input.getAttribute("data-max-qty"), 10) || 9999;

                    if (this.innerText.trim() === "+" && value < maxQty) {
                        input.value = value + 1;
                    } else if (this.innerText.trim() === "-" && value > 1) {
                        input.value = value - 1;
                    }

                    // đổi số lượng => quote lại ship để free-ship đúng
                    if (currentProvinceCode) quoteShipping(currentProvinceCode, currentDistrictCode);
                    else updateTotal();
                });
            });

            // ship method init + bind
            const shipMethodSelect = document.getElementById("shipMethodSelect");
            if (shipMethodSelect) {
                shipMethodSelect.addEventListener("change", async function () {
                    currentShipMethod = this.value || "standard";
                    saveShipSelection();
                    if (currentProvinceCode) await quoteShipping(currentProvinceCode, currentDistrictCode);
                    else updateTotal();
                });
            }

            // ===== init shipping dropdowns + remember =====
            try {
                const saved = loadShipSelection();

                currentShipMethod = saved.method || "standard";
                if (shipMethodSelect) shipMethodSelect.value = currentShipMethod;

                await loadProvinces(saved.prov);

                const provSel = document.getElementById("shipProvince");
                const distSel = document.getElementById("shipDistrict");

                if (provSel) {
                    provSel.addEventListener("change", async function () {
                        currentProvinceCode = this.value || "";
                        currentDistrictCode = "";
                        saveShipSelection();

                        await loadDistricts(currentProvinceCode, "");
                        await quoteShipping(currentProvinceCode, "");
                    });
                }

                if (distSel) {
                    distSel.addEventListener("change", async function () {
                        currentDistrictCode = this.value || "";
                        saveShipSelection();
                        await quoteShipping(currentProvinceCode, currentDistrictCode);
                    });
                }

                currentProvinceCode = saved.prov || "";
                currentDistrictCode = saved.dist || "";

                if (currentProvinceCode) {
                    await loadDistricts(currentProvinceCode, currentDistrictCode);
                    await quoteShipping(currentProvinceCode, currentDistrictCode);
                } else {
                    setShipUI(null, "—");
                }
            } catch (e) {
                console.warn("Shipping init error:", e);
            }

            togglePanels();
            updateTotal();
        });

        window.onload = function () {
            var adBanner = document.querySelector('.carousel');
            if (adBanner) adBanner.style.display = 'none';
        };
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
