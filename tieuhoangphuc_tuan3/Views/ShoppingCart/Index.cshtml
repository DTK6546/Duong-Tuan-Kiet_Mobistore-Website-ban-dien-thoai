@using WebBanDienThoai.Models
@model WebBanDienThoai.Models.ShoppingCart
@using System.Globalization

@if (TempData["PaymentError"] != null)
{
    <div class="alert alert-danger" id="paymentError">
        @TempData["PaymentError"]
    </div>

    <script>
        setTimeout(function () {
            var errorMessage = document.getElementById("paymentError");
            if (errorMessage) {
                errorMessage.style.display = "none";
            }
        }, 3000);
    </script>
}

@if (TempData["CouponError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 p-2 mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["CouponError"]
        <button type="button" class="btn-close shadow-none" style="padding: 0.75rem;" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["CouponSuccess"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 p-2 mb-3" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["CouponSuccess"]
        <button type="button" class="btn-close shadow-none" style="padding: 0.75rem;" data-bs-dismiss="alert"></button>
    </div>
}

@{
    ViewData["Title"] = "Giỏ hàng của bạn";

    decimal subtotal = Model.Items.Sum(i =>
    {
        var warrantyPerItem = i.Warranties?.Sum(w => w.Price) ?? 0;
        return (i.Price + warrantyPerItem) * i.Quantity;
    });

    decimal discount = Model.DiscountAmount;
    if (discount < 0) { discount = 0; }

    decimal priceAfterDiscount = subtotal - discount;
    if (priceAfterDiscount < 0) { priceAfterDiscount = 0; }

    decimal vatRate = 0.10m;
    decimal vatAmount = Math.Round(priceAfterDiscount * vatRate, 0);

    decimal shippingFee = 0;
    decimal finalTotal = priceAfterDiscount + vatAmount + shippingFee;

    var vi = CultureInfo.GetCultureInfo("vi-VN");
    var stores = ViewBag.Stores as List<Store>;
    var saveLaterItems = ViewBag.SaveLaterItems as List<CartItem> ?? new List<CartItem>();
    var currentUser = ViewBag.CurrentUser as ApplicationUser;
}

<style>
    .checkout-steps {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .checkout-steps .step {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-width: 90px;
        opacity: 0.55;
    }

    .checkout-steps .step.active {
        opacity: 1;
        font-weight: 700;
    }

    .checkout-steps .circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 2px solid #0ea5e9;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        color: #0ea5e9;
        font-weight: 700;
    }

    .checkout-steps .step.active .circle {
        background: #0ea5e9;
        color: #fff;
    }

    .checkout-steps .label {
        margin-top: 6px;
        font-size: 13px;
        text-align: center;
    }

    .checkout-steps .line {
        height: 2px;
        width: 60px;
        background: #e5e7eb;
        margin-top: -16px;
    }

    @Html.Raw("@media") (max-width: 576px) {
        .checkout-steps .line {
            width: 30px;
        }

        .checkout-steps .step {
            min-width: 70px;
        }
    }
</style>

<div class="container mt-5">
    <div class="checkout-steps mb-3">
        <div class="step active"><div class="circle">1</div><div class="label">Giỏ hàng</div></div>
        <div class="line"></div>
        <div class="step"><div class="circle">2</div><div class="label">Thông tin</div></div>
        <div class="line"></div>
        <div class="step"><div class="circle">3</div><div class="label">Thanh toán</div></div>
        <div class="line"></div>
        <div class="step"><div class="circle">4</div><div class="label">Hoàn tất</div></div>
    </div>

    <h2 class="text-center mb-4">🛒 Giỏ hàng của bạn</h2>

    <form id="ajaxAntiForgeryForm" method="post" style="display:none;">
        @Html.AntiForgeryToken()
    </form>
    <div id="cartMsg" class="alert d-none" role="alert"></div>

    @if (Model.Items.Count == 0 && !saveLaterItems.Any())
    {
        <p class="text-center text-muted">Giỏ hàng của bạn đang trống! 🛍️</p>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                @if (Model.Items.Any())
                {
                    <table class="table table-bordered align-middle text-center">
                        <thead class="table-dark">
                            <tr>
                                <th>Hình ảnh</th>
                                <th style="width: 35%">Tên sản phẩm</th>
                                <th>Giá</th>
                                <th>Số lượng</th>
                                <th>Thành tiền</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                var warrantyPerItem = item.Warranties?.Sum(w => w.Price) ?? 0;
                                var lineTotal = (item.Price + warrantyPerItem) * item.Quantity;

                                <tr>
                                    <td><img src="@item.ImageUrl" class="cart-image img-fluid" style="width: 80px; height: 80px; object-fit: contain;"></td>
                                    <td class="text-start">
                                        <strong>@item.Name</strong>
                                        <p class="text-muted m-0 small">Mã SP: @item.ProductId</p>

                                        @{
                                            var allWarrantyOptions = ViewBag.WarrantyOptions as List<WarrantyOption>;
                                            var optionsForProduct = allWarrantyOptions?.Where(w => w.ProductId == item.ProductId && w.IsActive).ToList();
                                            var selectedIds = item.Warranties?.Select(w => w.WarrantyOptionId).ToHashSet() ?? new HashSet<int>();
                                        }

                                        @if (optionsForProduct != null && optionsForProduct.Any())
                                        {
                                            <div class="mt-2 p-2 border rounded bg-white">
                                                <form asp-action="UpdateWarranties" asp-controller="ShoppingCart" method="post">
                                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                                    <input type="hidden" name="variantId" value="@(item.VariantId?.ToString() ?? "")" />
                                                    <div class="small fw-semibold mb-1">Gói bảo hành thêm:</div>
                                                    @foreach (var w in optionsForProduct)
                                                    {
                                                        var checkId = $"w_{item.ProductId}_{w.Id}";
                                                        var isChecked = selectedIds.Contains(w.Id);
                                                        <div class="form-check small">
                                                            <input class="form-check-input" type="checkbox" name="warrantyOptionIds" value="@w.Id" id="@checkId" @(isChecked ? "checked" : "") onchange="this.form.submit()" />
                                                            <label class="form-check-label" for="@checkId">@w.Name (+@w.Price.ToString("N0", vi) đ)</label>
                                                        </div>
                                                    }
                                                </form>
                                            </div>
                                        }
                                    </td>
                                    <td>@item.Price.ToString("N0", vi) đ</td>
                                    <td>
                                        <div class="input-group input-group-sm m-auto" style="width: 100px;">
                                            <button class="btn btn-outline-secondary quantity-btn" type="button">-</button>
                                            <input type="text" class="form-control text-center quantity-input" value="@item.Quantity"
                                                   data-product-id="@item.ProductId" data-variant-id="@(item.VariantId?.ToString() ?? "")"
                                                   data-unit-price="@item.Price" data-warranty-price="@warrantyPerItem" data-max-qty="@item.AvailableStock">
                                            <button class="btn btn-outline-secondary quantity-btn" type="button">+</button>
                                        </div>
                                    </td>
                                    <td><strong class="line-total">@lineTotal.ToString("N0", vi) đ</strong></td>
                                    <td>
                                        <div class="d-flex flex-column gap-1 align-items-center">
                                            <a asp-action="SaveForLater" asp-route-productId="@item.ProductId" asp-route-variantId="@item.VariantId" class="btn btn-sm btn-outline-warning text-dark px-2" title="Lưu mua sau">
                                                <i class="bi bi-star"></i> Lưu sau
                                            </a>
                                            <a asp-action="RemoveFromCart" asp-route-productId="@item.ProductId" asp-route-variantId="@item.VariantId" class="btn btn-sm btn-outline-danger px-2">
                                                <i class="bi bi-trash"></i> Xóa
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                @if (saveLaterItems.Any())
                {
                    <div class="mt-5 p-4 bg-light rounded-4 border border-secondary border-opacity-25 shadow-sm">
                        <h5 class="fw-bold text-secondary mb-3"><i class="bi bi-bookmark-star-fill text-warning me-1"></i> Sản phẩm đã lưu để mua sau (@saveLaterItems.Count)</h5>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle text-center bg-white rounded-3">
                                <thead>
                                    <tr class="table-secondary">
                                        <th>Hình ảnh</th>
                                        <th class="text-start">Tên sản phẩm</th>
                                        <th>Đơn giá</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sItem in saveLaterItems)
                                    {
                                        <tr>
                                            <td><img src="@sItem.ImageUrl" style="width:60px;height:60px;object-fit:contain;"></td>
                                            <td class="text-start"><span class="fw-semibold text-dark">@sItem.Name</span></td>
                                            <td class="text-danger fw-semibold">@sItem.Price.ToString("N0", vi) đ</td>
                                            <td>
                                                <div class="d-flex justify-content-center gap-2">
                                                    <a asp-action="MoveBackToCart" asp-route-productId="@sItem.ProductId" asp-route-variantId="@sItem.VariantId" class="btn btn-sm btn-success px-2 rounded-pill small fs-7"><i class="bi bi-cart-plus me-1"></i>Thêm lại vào giỏ</a>
                                                    <a asp-action="RemoveFromCart" asp-route-productId="@sItem.ProductId" asp-route-variantId="@sItem.VariantId" class="btn btn-sm btn-link text-danger text-decoration-none small">Xóa hẳn</a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <div class="d-flex flex-wrap gap-2 mt-3">
                    <a class="btn btn-outline-secondary btn-sm" asp-controller="Product" asp-action="Index">← Tiếp tục mua hàng</a>
                    @if (Model.Items.Any())
                    {
                        <button type="button" class="btn btn-primary btn-sm" onclick="saveCartQuantities()">Cập nhật giỏ hàng</button>
                        <form asp-action="ClearCart" asp-controller="ShoppingCart" method="post" onsubmit="return confirm('Bạn muốn xóa toàn bộ giỏ hàng?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm">Xóa tất cả</button>
                        </form>
                    }
                </div>

                <div class="mt-5">
                    <h4 class="fw-semibold mb-3"><i class="bi bi-star-half text-warning"></i> Có thể bạn cũng thích</h4>
                    <div class="row flex-nowrap overflow-auto pb-2" style="gap:24px;">
                        @if (ViewBag.SuggestedProducts != null)
                        {
                            foreach (var p in ViewBag.SuggestedProducts as List<Product>)
                            {
                                <div class="col-auto" style="min-width: 210px;">
                                    <div class="card border-0 shadow-sm h-100">
                                        <a href="@Url.Action("Display", "Product", new { id = p.Id })"><img src="@p.ImageUrl" class="card-img-top" style="height:120px;object-fit:contain"></a>
                                        <div class="card-body p-2 text-center">
                                            <div class="fw-semibold small mb-1" style="min-height:38px;">@p.Name</div>
                                            <div class="text-danger fw-bold mb-2">@p.Price.ToString("N0", vi) đ</div>
                                            <a href="@Url.Action("Display", "Product", new { id = p.Id })" class="btn btn-sm btn-outline-danger rounded-pill">Xem chi tiết</a>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm p-3">
                    <h6 class="border-bottom pb-2 mb-2">Thông tin người mua</h6>
                    @if (currentUser != null)
                    {
                        <p class="mb-1 small"><strong>Trạng thái:</strong> <span class="text-success">Đã đăng nhập</span></p>
                        <p class="mb-1 small"><strong>Họ tên:</strong> @currentUser.FullName</p>
                        <p class="mb-2 small"><strong>SĐT:</strong> @currentUser.PhoneNumber</p>
                        <p class="mb-2 small"><strong>Địa chỉ:</strong> @currentUser.Address</p>

                        <div class="card border border-success border-opacity-25 bg-success bg-opacity-10 p-2 rounded shadow-sm my-2">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <div class="small fw-bold text-success"><i class="bi bi-coin"></i> Điểm tích lũy: <b>@currentUser.CurrentPoints</b> điểm</div>
                                    <div class="text-muted" style="font-size: 11px;">Hạng: <span class="badge bg-primary">@currentUser.MemberTier</span> (Đặc quyền giảm @(currentUser.TierDiscountRate * 100)%)</div>
                                </div>
                                @if (currentUser.CurrentPoints > 0)
                                {
                                    <div class="form-check form-switch mb-0">
                                        <input class="form-check-input" type="checkbox" id="pointsToggle">
                                        <label class="form-check-label small fw-bold text-success" for="pointsToggle">Dùng</label>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info small mb-2">Bạn chưa đăng nhập. <a asp-area="Identity" asp-page="/Account/Login">Đăng nhập ngay</a></div>
                    }

                    <h6 class="border-bottom pb-2 mt-3 mb-2">Phương thức nhận hàng</h6>
                    <div class="small">
                        <div class="form-check"><input class="form-check-input" type="radio" name="DeliveryMethod" value="ShipToHome" id="shipHome" checked /><label class="form-check-label" for="shipHome">Giao hàng tận nơi</label></div>
                        <div class="form-check mt-2"><input class="form-check-input" type="radio" name="DeliveryMethod" value="PickupAtStore" id="pickupStore" /><label class="form-check-label" for="pickupStore">Nhận tại cửa hàng</label></div>
                        <div id="shippingPanel" class="mt-3 border rounded p-2">
                            <select class="form-select form-select-sm" id="shipProvince"><option value="">-- Chọn Tỉnh/TP --</option></select>
                            <select class="form-select form-select-sm mt-2" id="shipDistrict" disabled><option value="">-- Chọn Quận/Huyện --</option></select>
                            <select id="shipMethodSelect" class="form-select form-select-sm mt-2"><option value="standard" selected>Tiêu chuẩn</option><option value="express">Nhanh</option></select>
                            <div class="mt-2 small"><div>Phí ship: <b id="shipFee">—</b></div><div>Giao dự kiến: <b id="shipEta">—</b></div></div>
                        </div>
                        <div id="storePanel" class="mt-3 border rounded p-2 d-none">
                            <select name="StoreId" id="StoreId" class="form-control form-control-sm">
                                <option value="">-- Chọn cửa hàng --</option>
                                @if (stores != null)
                                {
                                    foreach (var s in stores)
                                    {
                                        <option value="@s.Id">@s.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mt-3 mb-2">Tóm tắt đơn hàng</h6>
                    <form id="ApplyCouponForm" asp-action="ApplyCoupon" asp-controller="ShoppingCart" method="post" class="mb-3">
                        <div class="input-group input-group-sm">
                            <input type="text" id="CouponCodeInput" name="couponCode" class="form-control" placeholder="Mã giảm giá" value="@(Model.CouponCode ?? string.Empty)" />
                            <button type="submit" class="btn btn-outline-success">Áp dụng</button>
                        </div>
                    </form>

                    <div class="d-flex justify-content-between small"><span>Tạm tính:</span><strong class="subtotal-amount">@subtotal.ToString("N0", vi) đ</strong></div>
                    <div class="d-flex justify-content-between small text-success"><span>Giảm giá Voucher:</span><strong class="discount-amount">-(@discount.ToString("N0", vi) đ)</strong></div>

                    <div class="d-flex justify-content-between small text-primary">
                        <span>Ưu đãi VIP Tier:</span>
                        <strong id="vipDiscountText">0 đ</strong>
                    </div>

                    <div class="d-flex justify-content-between small text-success">
                        <span>Khấu trừ điểm:</span>
                        <strong id="pointsDiscountText">0 đ</strong>
                    </div>

                    <div class="d-flex justify-content-between small"><span>Thành tiền:</span><strong class="before-tax-amount">@priceAfterDiscount.ToString("N0", vi) đ</strong></div>
                    <div class="d-flex justify-content-between small"><span>VAT (10%):</span><strong class="vat-amount">@vatAmount.ToString("N0", vi) đ</strong></div>
                    <div class="d-flex justify-content-between small"><span>Phí ship:</span><strong class="ship-fee-amount">0 đ</strong></div>
                    <hr />
                    <div class="d-flex justify-content-between small mb-2"><span><strong>Tổng cộng:</strong></span><strong class="final-total">@finalTotal.ToString("N0", vi) đ</strong></div>

                    @if (Model.Items.Any())
                    {
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="ShoppingCart" asp-action="Checkout" class="btn btn-danger w-100 btn-sm mt-2">🚀 Tiến hành thanh toán</a>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="/ShoppingCart/Checkout" class="btn btn-danger w-100 btn-sm mt-2">🔑 Đăng nhập để thanh toán</a>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // ✅ ÉP SỬA DẤU CHẤM THẬP PHÂN: Không cho C# tự sinh dấu phẩy vào JavaScript
        var discountFromServer = @discount.ToString(System.Globalization.CultureInfo.InvariantCulture);
        let currentShippingFee = 0;
        let currentProvinceCode = "";
        let currentDistrictCode = "";
        let currentShipMethod = "standard";

        let userPoints = @(currentUser?.CurrentPoints ?? 0);
        let tierRate = @((currentUser?.TierDiscountRate ?? 0m).ToString(System.Globalization.CultureInfo.InvariantCulture)); // ✅ Đã sửa dứt điểm lỗi 645

        function computeSubtotal() {
            let subtotal = 0;
            document.querySelectorAll(".quantity-input").forEach(input => {
                const quantity = parseInt(input.value, 10) || 0;
                const unitPrice = parseFloat(input.getAttribute("data-unit-price")) || 0;
                const warrantyPrice = parseFloat(input.getAttribute("data-warranty-price")) || 0;
                subtotal += quantity * (unitPrice + warrantyPrice);
            });
            return subtotal;
        }

        function setShipUI(fee, etaText) {
            const feeEl = document.getElementById("shipFee");
            const etaEl = document.getElementById("shipEta");
            if (feeEl) feeEl.textContent = (fee ?? 0).toLocaleString('vi-VN') + " VNĐ";
            if (etaEl) etaEl.textContent = etaText || "—";
        }

        function saveShipSelection() {
            localStorage.setItem("ship_province_code", currentProvinceCode || "");
            localStorage.setItem("ship_district_code", currentDistrictCode || "");
            localStorage.setItem("ship_method", currentShipMethod || "standard");
        }

        function loadShipSelection() {
            return {
                prov: localStorage.getItem("ship_province_code") || "",
                dist: localStorage.getItem("ship_district_code") || "",
                method: localStorage.getItem("ship_method") || "standard"
            };
        }

        async function fetchJson(url) {
            const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            return await res.json();
        }

        async function loadProvinces(selectedCode) {
            const provSel = document.getElementById("shipProvince"); if (!provSel) return;
            provSel.innerHTML = `<option value="">-- Chọn Tỉnh/TP --</option>`;
            const list = await fetchJson("/Shipping/Provinces");
            list.forEach(p => {
                const opt = document.createElement("option"); opt.value = p.code; opt.textContent = p.name;
                if (selectedCode === p.code) opt.selected = true;
                provSel.appendChild(opt);
            });
        }

        async function loadDistricts(provinceCode, selectedDistrict) {
            const distSel = document.getElementById("shipDistrict"); if (!distSel) return;
            distSel.innerHTML = `<option value="">-- Chọn Quận/Huyện --</option>`; distSel.disabled = true;
            if (!provinceCode) return;
            const list = await fetchJson(`/Shipping/Districts?provinceCode=${provinceCode}`);
            list.forEach(d => {
                const opt = document.createElement("option"); opt.value = d.code; opt.textContent = d.name;
                if (selectedDistrict === d.code) opt.selected = true;
                distSel.appendChild(opt);
            });
            distSel.disabled = false;
        }

        async function quoteShipping(provinceCode, districtCode) {
            if (!provinceCode) { currentShippingFee = 0; setShipUI(null, "—"); updateTotal(); return; }
            const orderValueAfterDiscount = Math.max(0, computeSubtotal() - (discountFromServer || 0));
            const data = await fetchJson(`/Shipping/Quote?provinceCode=${provinceCode}&districtCode=${districtCode}&method=${currentShipMethod}&orderValue=${orderValueAfterDiscount}`);
            if (data && data.ok === false) { currentShippingFee = 0; setShipUI(0, data.message || "—"); updateTotal(); return; }
            currentShippingFee = Number(data.fee || 0);
            let etaText = "—"; if (data.etaFrom && data.etaTo) etaText = `${data.etaFrom} - ${data.etaTo}`;
            setShipUI(currentShippingFee, etaText);
            updateTotal();
        }

        function togglePanels() {
            var method = document.querySelector("input[name='DeliveryMethod']:checked");
            var storePanel = document.getElementById("storePanel"); var shipPanel = document.getElementById("shippingPanel");
            if (!method) return;
            if (method.value === "PickupAtStore") {
                if (storePanel) storePanel.classList.remove("d-none"); if (shipPanel) shipPanel.classList.add("d-none");
                currentShippingFee = 0; updateTotal();
            } else {
                if (storePanel) storePanel.classList.add("d-none"); if (shipPanel) shipPanel.classList.remove("d-none");
                if (currentProvinceCode) quoteShipping(currentProvinceCode, currentDistrictCode);
            }
        }

        function updateTotal() {
            const subtotal = computeSubtotal();
            document.querySelectorAll(".quantity-input").forEach(input => {
                const quantity = parseInt(input.value, 10) || 0;
                const unitPrice = parseFloat(input.getAttribute("data-unit-price")) || 0;
                const warrantyPrice = parseFloat(input.getAttribute("data-warranty-price")) || 0;
                const row = input.closest("tr"); const lineTotalEl = row ? row.querySelector(".line-total") : null;
                if (lineTotalEl) lineTotalEl.textContent = (quantity * (unitPrice + warrantyPrice)).toLocaleString('vi-VN') + " đ";
            });

            if (document.querySelector(".subtotal-amount")) document.querySelector(".subtotal-amount").textContent = subtotal.toLocaleString('vi-VN') + ' đ';

            let couponDiscount = discountFromServer || 0;

            let vipDiscount = Math.round((subtotal - couponDiscount) * tierRate);
            if(vipDiscount < 0) vipDiscount = 0;
            document.getElementById("vipDiscountText").textContent = "-" + vipDiscount.toLocaleString('vi-VN') + " đ";

            let pointsDiscount = 0;
            const pointsToggle = document.getElementById("pointsToggle");
            if (pointsToggle && pointsToggle.checked) {
                pointsDiscount = userPoints * 1000;
            }
            document.getElementById("pointsDiscountText").textContent = "-" + pointsDiscount.toLocaleString('vi-VN') + " đ";

            let priceAfterDiscount = subtotal - couponDiscount - vipDiscount - pointsDiscount;
            if (priceAfterDiscount < 0) priceAfterDiscount = 0;

            let vatAmount = Math.round(priceAfterDiscount * 0.10);
            const method = document.querySelector("input[name='DeliveryMethod']:checked")?.value || "ShipToHome";
            const shipFee = (method === "ShipToHome") ? (currentShippingFee || 0) : 0;

            if (document.querySelector(".before-tax-amount")) document.querySelector(".before-tax-amount").textContent = priceAfterDiscount.toLocaleString('vi-VN') + ' đ';
            if (document.querySelector(".vat-amount")) document.querySelector(".vat-amount").textContent = vatAmount.toLocaleString('vi-VN') + ' đ';
            if (document.querySelector(".ship-fee-amount")) document.querySelector(".ship-fee-amount").textContent = shipFee.toLocaleString('vi-VN') + ' đ';
            if (document.querySelector(".final-total")) document.querySelector(".final-total").textContent = (priceAfterDiscount + vatAmount + shipFee).toLocaleString('vi-VN') + ' đ';
        }

        function showCartMsg(type, text) {
            const el = document.getElementById("cartMsg"); if (!el) return;
            el.classList.remove("d-none", "alert-success", "alert-danger"); el.classList.add(type === "success" ? "alert-success" : "alert-danger"); el.textContent = text;
            setTimeout(() => el.classList.add("d-none"), 3500);
        }

        async function saveCartQuantities() {
            const token = document.querySelector("#ajaxAntiForgeryForm input[name='__RequestVerificationToken']")?.value;
            const inputs = Array.from(document.querySelectorAll(".quantity-input"));
            const items = inputs.map(input => {
                return {
                    productId: parseInt(input.getAttribute("data-product-id"), 10),
                    variantId: input.getAttribute("data-variant-id") ? parseInt(input.getAttribute("data-variant-id"), 10) : null,
                    quantity: parseInt(input.value, 10) || 1
                };
            });
            const res = await fetch("/ShoppingCart/UpdateCartQuantities", {
                method: "POST", headers: { "Content-Type": "application/json", "RequestVerificationToken": token, "X-Requested-With": "XMLHttpRequest" },
                body: JSON.stringify(items)
            });
            const data = await res.json();
            if (data?.success) { showCartMsg("success", data.message); setTimeout(() => window.location.reload(), 600); }
            else { showCartMsg("error", data?.message); }
        }

        document.addEventListener("DOMContentLoaded", async function () {
            document.getElementById("pointsToggle")?.addEventListener("change", updateTotal);

            document.querySelectorAll(".coupon-btn").forEach(btn => {
                btn.addEventListener("click", function () {
                    document.getElementById("CouponCodeInput").value = this.getAttribute("data-code");
                    document.getElementById("ApplyCouponForm").submit();
                });
            });

            document.querySelectorAll("input[name='DeliveryMethod']").forEach(el => el.addEventListener("change", () => { togglePanels(); }));
            document.getElementById("StoreId")?.addEventListener("change", updateTotal);

            document.querySelectorAll(".quantity-btn").forEach(button => {
                button.addEventListener("click", function () {
                    let input = this.parentElement.querySelector(".quantity-input"); let value = parseInt(input.value, 10) || 0;
                    const maxQty = parseInt(input.getAttribute("data-max-qty"), 10) || 9999;
                    if (this.innerText.trim() === "+" && value < maxQty) input.value = value + 1;
                    else if (this.innerText.trim() === "-" && value > 1) input.value = value - 1;
                    updateTotal();
                });
            });

            const saved = loadShipSelection(); currentShipMethod = saved.method || "standard";
            if (document.getElementById("shipMethodSelect")) document.getElementById("shipMethodSelect").value = currentShipMethod;
            await loadProvinces(saved.prov);

            const provSel = document.getElementById("shipProvince"); const distSel = document.getElementById("shipDistrict");
            provSel?.addEventListener("change", async function () {
                currentProvinceCode = this.value; currentDistrictCode = ""; saveShipSelection();
                await loadDistricts(currentProvinceCode, ""); await quoteShipping(currentProvinceCode, "");
            });
            distSel?.addEventListener("change", async function () {
                currentDistrictCode = this.value; saveShipSelection(); await quoteShipping(currentProvinceCode, currentDistrictCode);
            });

            currentProvinceCode = saved.prov || ""; currentDistrictCode = saved.dist || "";
            if (currentProvinceCode) { await loadDistricts(currentProvinceCode, currentDistrictCode); await quoteShipping(currentProvinceCode, currentDistrictCode); }
            togglePanels(); updateTotal();
        });
    </script>
}